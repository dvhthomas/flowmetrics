{% extends "base.html.jinja" %}

{% block subtitle %}
<p class="subtitle">
  for
  {%- if repo_url %} <a href="{{ repo_url }}">{{ report.input.repo }}</a>
  {%- else %} {{ report.input.repo }}
  {%- endif %} ·
  {{ report.input.start }} → {{ report.input.stop }} ·
  <span class="stamp">generated {{ generated_at.strftime("%Y-%m-%d %H:%M %Z").strip() }}</span>
</p>
{% endblock %}

{# Suppress auto-rendered top-of-page blocks; the scatterplot itself
   plus the slowest-finishers list IS the report. Minimal head like
   Aging. #}
{% block headline %}{% endblock %}
{% block definition %}{% endblock %}
{% block banner %}{% endblock %}
{% block key_insight %}{% endblock %}
{% block next_actions %}{% endblock %}
{% block caveats %}{% endblock %}
{% block reproduce %}{% endblock %}
{% block vocabulary %}{% endblock %}

{% block content %}
{% if not report.points %}
<p>No completed items in this window.</p>
{% else %}

<div class="headline">
{{ interpretation.headline }}
</div>

<div id="scatterplot-chart" class="chart tall"
     role="img"
     aria-label="Cycle-time scatterplot with P50, P70, P85, P95 percentile lines"></div>
<script src="https://cdn.jsdelivr.net/npm/vega@5"></script>
<script src="https://cdn.jsdelivr.net/npm/vega-lite@5"></script>
<script src="https://cdn.jsdelivr.net/npm/vega-embed@6"></script>
<script>
  vegaEmbed("#scatterplot-chart", {{ vega_spec_json | safe }}, {
    actions: {export: true, source: false, compiled: false, editor: false},
    renderer: "svg"
  }).catch(function(err) {
    document.getElementById("scatterplot-chart").innerText =
      "Interactive chart failed to render: " + err;
  });
</script>

<p class="footnote-tight">
Hover any dot to see the item that finished there. Click a dot to
open its PR / issue. Horizontal lines mark percentile thresholds —
a new item entering the system has the matching probability of
finishing in that time or less.
</p>

{# Slowest finishers — the deep-tail items worth retrospecting. #}
{% if slowest %}
<h2>Slowest items in this window</h2>
<div>
{% for p in slowest %}
  <div class="intervention">
    <span class="id">
      {%- if p.pr_url -%}
        <a href="{{ p.pr_url }}">{{ p.item_id }}</a>
      {%- else -%}
        {{ p.item_id }}
      {%- endif -%}
    </span>
    <span class="age">{{ "%.1f"|format(p.cycle_time_days) }}d</span>
    <span class="state">{{ p.completed_at }}</span>
    <span class="title">{{ p.title[:100] }}</span>
  </div>
{% endfor %}
</div>
{% endif %}

{% endif %}
{% endblock %}

{% block detail %}
<details>
<summary>Reproduce this report</summary>
<table>
  <tr><th>Repo</th><td>{{ report.input.repo }}</td></tr>
  <tr><th>Window</th><td>{{ report.input.start }} → {{ report.input.stop }}</td></tr>
  <tr><th>Completed items</th><td>{{ report.points|length }}</td></tr>
</table>
<div class="invocation">{{ invocation }}</div>
</details>

<details>
<summary>About this report</summary>
<p><strong>What this shows.</strong> {{ definition }}</p>

<p><strong>How to read the percentile lines.</strong></p>
<ul class="compact-prose">
  <li>The lines are EMPIRICAL — drawn at the cycle times that
      separate the finished items into ranked groups. P50 = half
      the items finished at or below this number of days; P85 =
      85% of items finished at or below this number; etc.</li>
  <li>By definition, a new item entering the system has the matching
      probability of finishing in that time or less. P85 ({{ "%.1f"|format(report.cycle_time_percentiles[85]) }}d
      for this window) is the conventional external-commitment line.</li>
  <li>The deep tail (above P95) is where retrospectives find the
      most leverage — what happened with each of those items, and
      can we prevent it next time?</li>
</ul>

{% if interpretation.key_insight %}
<p><strong>Key insight.</strong> {{ interpretation.key_insight }}</p>
{% endif %}

{% if interpretation.next_actions %}
<p><strong>Next actions</strong></p>
<ol class="compact-prose">
{% for action in interpretation.next_actions %}
  <li>{{ action }}</li>
{% endfor %}
</ol>
{% endif %}

{% if interpretation.caveats %}
<p><strong>Caveats</strong></p>
<ul class="footnote-wider">
{% for c in interpretation.caveats %}
  <li>{{ c }}</li>
{% endfor %}
</ul>
{% endif %}

<p><strong>Vocabulary</strong></p>
<dl>
{% for term, defn in vocabulary.items() %}
  <dt><strong>{{ term }}</strong></dt>
  <dd>{{ defn }}</dd>
{% endfor %}
</dl>
</details>
{% endblock %}
