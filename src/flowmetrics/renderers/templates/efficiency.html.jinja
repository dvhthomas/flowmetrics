{% extends "base.html.jinja" %}

{% block subtitle %}
<p class="subtitle">
  for
  {%- if repo_url %} <a href="{{ repo_url }}">{{ report.input.repo }}</a>
  {%- else %} {{ report.input.repo }}
  {%- endif %} ·
  {{ report.input.start }} → {{ report.input.stop }} ·
  <span class="stamp">generated {{ generated_at.strftime("%Y-%m-%d %H:%M %Z").strip() }}</span>
</p>
{% endblock %}

{# Suppress auto-rendered base sections — they fold into collapsibles below. #}
{% block key_insight %}{% endblock %}
{% block next_actions %}{% endblock %}
{% block caveats %}{% endblock %}
{% block reproduce %}{% endblock %}
{% block vocabulary %}{% endblock %}

{% block content %}
{% if report.result.pr_count == 0 %}
<p>No PRs merged in this window.</p>
{% else %}

{# Headline numbers (plain prose, no colored box). #}
<p style="font-size:1.05rem;">
<strong>Portfolio FE: {{ "%.1f"|format(report.result.portfolio_efficiency * 100) }}%</strong>
across {{ report.result.pr_count }} PRs
{%- if report.result.bot_pr_count %}
 ({{ report.result.human_pr_count }} human, {{ report.result.bot_pr_count }} bot)
{%- endif -%}.
{{ fmt_duration(report.result.total_cycle) }} cycle,
{{ fmt_duration(report.result.total_active) }} active.
</p>

{# Assumptions callout — the GitHub API does not expose "active" vs
   "wait" time directly, so active time is INFERRED from event
   timings. The two parameters below drive that inference and can
   swing FE meaningfully. Promote them out of the About collapsible
   so the reader sees them before treating FE as a measurement. #}
<div style="background: #fff8e1; border-left: 4px solid #d4a72c;
            padding: 0.7rem 1rem; margin: 0.8rem 0 1.2rem;
            font-size: 0.92rem; color: #5a4313; max-width: 70ch;">
  <strong>Active time here is an estimate, not a measurement.</strong>
  GitHub does not record when a PR is being worked on vs. waiting in
  review. We infer activity by clustering events (commits, reviews,
  comments) into work sessions: events more than
  <strong>{{ report.input.gap_hours }}h</strong> apart start a new
  session, and a lone event counts for at least
  <strong>{{ report.input.min_cluster_minutes }} min</strong> so it
  isn't zero. Both numbers are assumptions you can tune with
  <code>--gap-hours</code> and <code>--min-cluster-minutes</code> —
  raising the gap usually <em>raises</em> FE; lowering it usually
  <em>lowers</em> FE. Treat the number as directional.
</div>

{# Top slowest PRs — the system bottleneck. #}
<h2>Top slowest PRs</h2>
<p style="font-size:0.9rem; color:#666; max-width:60ch">
These PRs drove the portfolio's cycle-time tail. Improving any one of
them moves the portfolio number more than improving a typical PR.
</p>
<div>
{% for p in per_pr_by_cycle[:5] %}
  <div class="intervention">
    <span class="id">
      {%- if pr_urls.get(p.item_id) -%}
        <a href="{{ pr_urls[p.item_id] }}">{{ p.item_id }}</a>
      {%- else -%}
        {{ p.item_id }}
      {%- endif -%}
    </span>
    <span class="age">{{ fmt_duration(p.cycle_time) }}</span>
    <span class="state"><span class="pill">FE {{ "%.1f"|format(p.efficiency * 100) }}%</span></span>
    <span class="title">{{ p.title[:90] }}</span>
  </div>
{% endfor %}
</div>

<div id="efficiency-chart" style="width:100%;"></div>
<script src="https://cdn.jsdelivr.net/npm/vega@5"></script>
<script src="https://cdn.jsdelivr.net/npm/vega-lite@5"></script>
<script src="https://cdn.jsdelivr.net/npm/vega-embed@6"></script>
<script>
  vegaEmbed("#efficiency-chart", {{ vega_spec_json | safe }}, {
    actions: {export: true, source: false, compiled: false, editor: false},
    renderer: "svg"
  }).catch(function(err) {
    document.getElementById("efficiency-chart").innerText =
      "Interactive chart failed to render: " + err;
  });
</script>

<p style="font-size:0.9rem; color:#666; max-width:60ch">
<strong>Why are so many PRs at 100%?</strong>
A PR scores 100% when its entire cycle fits inside one activity cluster
(default: 4-hour quiet-period threshold). Short PRs — automated version
bumps, fast community fixes, dependabot updates — trivially fit inside
one cluster because there's no time for a queue to form. The signal is
in the <strong>portfolio number</strong> in the headline and the PRs
above, not in the 100%-bar tail.
</p>
{% endif %}
{% endblock %}

{% block detail %}
{% if report.result.pr_count > 0 %}
<details>
<summary>Show all {{ per_pr_sorted|length }} PRs (slowest first)</summary>
<table>
<thead><tr><th>#</th><th>Cycle</th><th>Active</th><th>FE</th><th>Title</th></tr></thead>
<tbody>
{% for p in per_pr_sorted %}
  <tr>
    <td>
      {%- if pr_urls.get(p.item_id) -%}
        <a href="{{ pr_urls[p.item_id] }}">{{ p.item_id }}</a>
      {%- else -%}
        {{ p.item_id }}
      {%- endif -%}
    </td>
    <td class="num">{{ fmt_duration(p.cycle_time) }}</td>
    <td class="num">{{ fmt_duration(p.active_time) }}</td>
    <td class="num">{{ "%.1f"|format(p.efficiency * 100) }}%</td>
    <td>{{ p.title[:80] }}</td>
  </tr>
{% endfor %}
</tbody>
</table>
</details>
{% endif %}

<details>
<summary>Reproduce this report</summary>
<table>
  <tr><th>Repo</th><td>{{ report.input.repo }}</td></tr>
  <tr><th>Window</th><td>{{ report.input.start }} → {{ report.input.stop }}</td></tr>
  <tr><th>Active-time gap</th><td>{{ report.input.gap_hours }}h</td></tr>
  <tr><th>Min cluster</th><td>{{ report.input.min_cluster_minutes }}min</td></tr>
</table>
<div class="invocation">{{ invocation }}</div>
</details>

<details>
<summary>About this report</summary>
<p><strong>What this shows.</strong> {{ definition }}</p>

<p><strong>How active time was calculated.</strong>
We grouped each PR's events (commits, reviews, comments) into work sessions:
events more than <strong>{{ report.input.gap_hours }} hours</strong> apart start a new
session, and a single isolated event counts as at least
<strong>{{ report.input.min_cluster_minutes }} minutes</strong> of active time (so a
lone comment isn't counted as zero work).</p>

{% if report.result.pr_count > 0 %}
<p><strong>Per-PR distribution (median / mean).</strong>
Reported because people ask for them, but the <strong>portfolio</strong>
number above is the right one. Mean of per-PR ratios is inflated by a
long tail of tiny fast PRs; median tells you what a typical PR looks
like in isolation but doesn't reflect the system.</p>
<table>
  <tr><th>Median per-PR FE</th><td class="num">{{ "%.1f"|format(report.result.median_efficiency * 100) }}%</td></tr>
  <tr><th>Mean per-PR FE</th><td class="num">{{ "%.1f"|format(report.result.mean_efficiency * 100) }}%</td></tr>
</table>
{% endif %}

{% if interpretation.key_insight %}
<p><strong>Key insight.</strong> {{ interpretation.key_insight }}</p>
{% endif %}

{% if interpretation.next_actions %}
<p><strong>Next actions</strong></p>
<ol style="font-size:0.95rem;">
{% for action in interpretation.next_actions %}
  <li>{{ action }}</li>
{% endfor %}
</ol>
{% endif %}

{% if interpretation.caveats %}
<p><strong>Caveats</strong></p>
<ul style="font-size:0.9rem; color:#555">
{% for c in interpretation.caveats %}
  <li>{{ c }}</li>
{% endfor %}
</ul>
{% endif %}

<p><strong>Vocabulary</strong></p>
<dl>
{% for term, defn in vocabulary.items() %}
  <dt><strong>{{ term }}</strong></dt>
  <dd>{{ defn }}</dd>
{% endfor %}
</dl>
</details>
{% endblock %}
