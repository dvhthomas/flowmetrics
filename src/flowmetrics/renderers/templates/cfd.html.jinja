{% extends "base.html.jinja" %}

{% block subtitle %}
<p class="subtitle">
  for
  {%- if repo_url %} <a href="{{ repo_url }}">{{ report.input.repo }}</a>
  {%- else %} {{ report.input.repo }}
  {%- endif %} ·
  {{ report.input.start }} → {{ report.input.stop }} ·
  <span class="stamp">generated {{ generated_at.strftime("%Y-%m-%d %H:%M %Z").strip() }}</span>
</p>
{% endblock %}

{% block key_insight %}{% endblock %}
{% block next_actions %}{% endblock %}
{% block caveats %}{% endblock %}
{% block reproduce %}{% endblock %}
{% block vocabulary %}{% endblock %}

{% block content %}
{% if not report.points %}
<p>No CFD samples for this window.</p>
{% else %}

{# WIP trend banner: the actionable read. Only conditional coloured
   chrome on the page. #}
{% if wip_trend.direction != "flat" %}
<div class="banner" style="background:
    {%- if wip_trend.direction == 'widening' %} #fef2f2; border-left-color: #cc3333; color: #7f1d1d
    {%- else %} #ecfdf5; border-left-color: #10b981; color: #064e3b
    {%- endif %};">
  {% if wip_trend.direction == "widening" -%}
  ⚠ WIP gap is <strong>widening</strong>: started at {{ wip_trend.start_wip }} items,
  ended at {{ wip_trend.end_wip }} (+{{ wip_trend.delta }} over the window).
  Arrivals are outpacing departures — the queue is growing.
  {%- else -%}
  ✓ WIP gap is <strong>narrowing</strong>: started at {{ wip_trend.start_wip }} items,
  ended at {{ wip_trend.end_wip }} ({{ wip_trend.delta }} over the window).
  Departures are outpacing arrivals — the queue is shrinking.
  {%- endif %}
</div>
{% endif %}

<img alt="Cumulative Flow Diagram" src="data:image/png;base64,{{ chart_cfd_b64 }}" />

<p style="font-size:0.85rem; color:#666">
{{ end_counts[report.input.workflow[0]] }} arrivals,
{{ end_counts[report.input.workflow[-1]] }} departures,
<strong>{{ wip_trend.end_wip }}</strong> WIP at end of window
({{ report.points|length }} samples).
</p>

{% endif %}
{% endblock %}

{% block detail %}
<details>
<summary>Reproduce this report</summary>
<table>
  <tr><th>Repo</th><td>{{ report.input.repo }}</td></tr>
  <tr><th>Workflow</th><td>
    {% for s in report.input.workflow %}<span class="pill">{{ s }}</span>{% if not loop.last %} → {% endif %}{% endfor %}
  </td></tr>
  <tr><th>Window</th><td>{{ report.input.start }} → {{ report.input.stop }}</td></tr>
  <tr><th>Sample interval</th><td>{{ report.input.interval_days }} day(s)</td></tr>
</table>
<div class="invocation">{{ invocation }}</div>
</details>

<details>
<summary>About this report</summary>
<p><strong>What this shows.</strong> {{ definition }}</p>

<p><strong>Reading the chart.</strong> Each band's vertical thickness at
a sample date is the WIP in that workflow state (Vacanti's property #3).
The slope of any line measures the rate at which items entered that
state-or-later over time (property #6). The horizontal distance between
two adjacent lines at a given y-level is the approximate average cycle
time through the bands between them (property #4).</p>

{% if interpretation.key_insight %}
<p><strong>Key insight.</strong> {{ interpretation.key_insight }}</p>
{% endif %}

{% if interpretation.next_actions %}
<p><strong>Next actions</strong></p>
<ol style="font-size:0.95rem;">
{% for action in interpretation.next_actions %}
  <li>{{ action }}</li>
{% endfor %}
</ol>
{% endif %}

{% if interpretation.caveats %}
<p><strong>Caveats</strong></p>
<ul style="font-size:0.9rem; color:#555">
{% for c in interpretation.caveats %}
  <li>{{ c }}</li>
{% endfor %}
</ul>
{% endif %}

<p><strong>Vocabulary</strong></p>
<dl>
{% for term, defn in vocabulary.items() %}
  <dt><strong>{{ term }}</strong></dt>
  <dd>{{ defn }}</dd>
{% endfor %}
</dl>
</details>

<details>
<summary>Show all {{ report.points|length }} sample points</summary>
<table>
<thead>
<tr><th>Date</th>{% for s in report.input.workflow %}<th>{{ s }}</th>{% endfor %}</tr>
</thead>
<tbody>
{% for p in report.points %}
  <tr>
    <td>{{ p.sampled_on }}</td>
    {% for s in report.input.workflow %}
      <td class="num">{{ p.counts_by_state.get(s, 0) }}</td>
    {% endfor %}
  </tr>
{% endfor %}
</tbody>
</table>
</details>
{% endblock %}
