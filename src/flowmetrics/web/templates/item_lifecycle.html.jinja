{% extends "_base.html.jinja" %}

{% block content %}
  {% set _headline -%}
    {{ data.events|length }} stage event{% if data.events|length != 1 %}s{% endif %}
    {%- if data.url %} · <a href="{{ data.url }}" target="_blank" rel="noopener">open {{ data.source }}</a>{% endif %}
  {%- endset %}
  {% with summary = {"title": data.title or data.item_id, "headline": _headline} %}
    {% include "_partials/metric_summary.html.jinja" %}
  {% endwith %}

  {# Cycle time strip: surface both numbers — the per-day metric
     the rest of the system uses (Vacanti's `FD - SD + 1`, whole
     calendar days, both endpoints inclusive) AND the wall-clock
     elapsed time the timeline above shows. Reconciles the two so
     a viewer doesn't read "1d" on the metric and "10 hours" on
     the chart and wonder which is right. #}
  <div class="lifecycle-metric-strip">
    <span class="lifecycle-metric-strip-label">Cycle time</span>
    <span class="lifecycle-metric-strip-value">{{ data.cycle_time_days|int }}d</span>
    <span class="lifecycle-metric-strip-formula">elapsed {{ data.elapsed_display }} · calendar days, ends inclusive (Vacanti)</span>
  </div>
  {% if data.percentile_source_count > 0 %}
  <div class="lifecycle-percentile-strip">
    <span class="lifecycle-percentile-label">Team thresholds</span>
    <span class="lifecycle-percentile-cell">P50 {{ data.p50_days|round(1) }}d</span>
    <span class="lifecycle-percentile-cell">P85 {{ data.p85_days|round(1) }}d</span>
    <span class="lifecycle-percentile-cell">P95 {{ data.p95_days|round(1) }}d</span>
    <span class="lifecycle-percentile-source">from {{ data.percentile_source_count }} completed items</span>
  </div>
  {% endif %}

  {% if data.is_chartable %}
    <div class="metric">
      {% include "_partials/lifecycle_chart.html.jinja" %}
    </div>
  {% else %}
    {% include "_partials/lifecycle_summary.html.jinja" %}
  {% endif %}

  <section class="detail-extras">
    <h2>Events</h2>
    <table class="work-items-grid">
      <thead>
        <tr>
          <th>Stage</th>
          <th>Entered (UTC)</th>
          <th style="text-align:right;">Dwell (d)</th>
          <th>Signal</th>
        </tr>
      </thead>
      <tbody>
        {% for e in data.events %}
        <tr>
          <td>{{ e.stage }}</td>
          <td>{{ e.entered_at_display }}</td>
          <td class="num">{% if e.dwell_days is not none %}{{ "%.2f"|format(e.dwell_days) }}{% else %}—{% endif %}</td>
          <td><code>{{ e.signal }}</code></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <a class="back-link" href="{{ ("/workflows/" ~ contract.name ~ "/") | keep_filters }}">← Back to dashboard</a>
{% endblock %}
