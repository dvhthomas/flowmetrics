{% extends "_base.html.jinja" %}

{# New-contract wizard. Three fieldsets visible at once (no
   navigation between steps) — name + source + window. Source
   probe fires on blur of the repo / jira_project field. Save
   validates, PUTs, and redirects to the new dashboard. #}

{% block filter_bar %}{% endblock %}
{% block data_source_strip %}{% endblock %}

{% block content %}
<style>
  .wizard {
    max-width: 38rem;
    margin: 1.5rem 0;
  }
  .wizard fieldset {
    border: 0.0625rem solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem 0.5rem 1.25rem;
    margin: 0 0 1.25rem 0;
  }
  .wizard legend {
    font-family: var(--head-font);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-600);
    padding: 0 0.4rem;
  }
  .wizard label {
    display: block;
    margin: 0.4rem 0;
    font-size: 0.875rem;
    color: var(--muted);
  }
  .wizard label > input,
  .wizard label > select {
    display: block;
    width: 100%;
    margin-top: 0.2rem;
    padding: 0.4rem 0.5rem;
    border: 0.0625rem solid var(--border);
    border-radius: 0.25rem;
    font-size: 1rem;
    color: var(--fg);
    background: var(--white);
  }
  .source-fields[data-source="jira"] .source-github,
  .source-fields[data-source="github"] .source-jira {
    display: none;
  }
  .probe-status {
    font-size: 0.8125rem;
    margin-top: 0.3rem;
    min-height: 1.1rem;
  }
  .probe-status--ok { color: var(--p-600); }
  .probe-status--fail { color: var(--t-700); }
  .wizard-actions {
    display: flex;
    gap: 0.75rem;
    margin: 0 0 1rem 0;
  }
  .wizard-actions button[type="submit"] {
    background: var(--p-500);
    color: var(--white);
    border: 0;
    padding: 0.45rem 1.1rem;
    border-radius: 0.3rem;
    font-weight: 600;
    cursor: pointer;
  }
  .wizard-actions button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .wizard-errors {
    color: var(--t-700);
    font-size: 0.875rem;
    margin: 0.5rem 0 0 0;
    min-height: 1.2rem;
  }
</style>

{% if wizard_mode == "edit" %}
<h1>Edit workflow: {{ edit_id }}</h1>
{% else %}
<h1>New workflow</h1>
{% endif %}

<form class="wizard" id="wizard">
  <fieldset>
    <legend>Identity</legend>
    <label>Routing ID (lowercase, dashes only)
      <input type="text" name="name" required pattern="[a-z0-9-]+"
             placeholder="astral-uv-week">
    </label>
    <label>Display label (optional)
      <input type="text" name="label" placeholder="Astral uv weekly">
    </label>
  </fieldset>

  <fieldset class="source-fields" data-source="github" id="source-fieldset">
    <legend>Source</legend>
    <label>Source kind
      <select name="source" onchange="document.getElementById('source-fieldset').dataset.source=this.value; refreshSourceKindLabel(); probeVocab();">
        <option value="github" selected>GitHub</option>
        <option value="jira">Jira</option>
      </select>
    </label>

    <div class="source-github">
      <label>Repository (owner/name)
        <input type="text" name="repo" placeholder="astral-sh/uv"
               onblur="probeSource()">
      </label>
    </div>

    <div class="source-jira">
      <label>Jira base URL
        <input type="text" name="jira_url"
               placeholder="https://issues.apache.org/jira"
               onblur="probeSource()">
      </label>
      <label>Project key
        <input type="text" name="jira_project" placeholder="BIGTOP"
               onblur="probeSource()">
      </label>
    </div>

    <div class="probe-status" id="probe-status"></div>
  </fieldset>

  <fieldset id="steps-fieldset">
    <legend>Steps</legend>
    <ol id="steps-list"
        style="list-style: none; padding: 0; margin: 0; border: 0.0625rem solid var(--border); border-radius: 0.25rem;"></ol>
    <div style="margin-top: 0.6rem; display: flex; gap: 0.4rem; align-items: center;">
      <input type="text" id="new-step-name" placeholder="Step name (e.g. In Progress)"
             style="flex: 1; padding: 0.3rem 0.5rem; border: 0.0625rem solid var(--border); border-radius: 0.25rem;">
      <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.875rem;">
        <input type="checkbox" id="new-step-wip" checked>
        WIP
      </label>
      <button type="button" id="add-step" onclick="addStep()">+ Add step</button>
      <span class="probe-status" id="stages-status"></span>
    </div>

    <div id="suggestions-panel" style="margin-top: 1rem;">
      <div class="sugg-group" style="margin-bottom: 0.4rem;">
        <strong style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">In your warehouse</strong>
        <div id="sugg-warehouse" class="sugg-chips" style="display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.2rem; min-height: 1.4rem;"></div>
      </div>
      <div class="sugg-group" style="margin-bottom: 0.4rem;">
        <strong id="sugg-labels-label" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">Labels in the source</strong>
        <div id="sugg-labels" class="sugg-chips" style="display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.2rem; min-height: 1.4rem;"></div>
      </div>
      <div class="sugg-group">
        <strong style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">Lifecycle events</strong>
        <div id="sugg-lifecycle" class="sugg-chips" style="display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.2rem; min-height: 1.4rem;"></div>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Window (optional)</legend>
    <label>Start (YYYY-MM-DD)
      <input type="date" name="start">
    </label>
    <label>Stop (YYYY-MM-DD)
      <input type="date" name="stop">
    </label>
  </fieldset>

  <div class="wizard-actions">
    <button type="submit">{% if wizard_mode == "edit" %}Save{% else %}Save &amp; open{% endif %}</button>
    <a href="/" class="filter-reset">Cancel</a>
    {% if wizard_mode == "edit" %}
    <button type="button" id="archive-btn"
            style="margin-left: auto; background: transparent; border: 0.0625rem solid var(--t-700); color: var(--t-700); padding: 0.4rem 1rem; border-radius: 0.3rem; cursor: pointer;"
            onclick="confirmArchive()">Archive</button>
    {% endif %}
  </div>
  <p class="wizard-errors" id="wizard-errors"></p>
</form>

<script>
  // -----------------------------------------------------------------
  // Steps editor: one ordered list, each row = {name, wip}.
  // READY / WIP / DONE badges derive from order + wip flag on render.
  // -----------------------------------------------------------------

  function readSteps() {
    var rows = document.querySelectorAll('#steps-list li[data-step]');
    var out = [];
    rows.forEach(function (li) {
      var name = li.querySelector('input.step-name').value.trim();
      if (!name) return;
      // The row's matches list is stored as a JSON array on a
      // data attribute; the chip subrow displays it.
      var raw = li.dataset.matches || '[]';
      var matches = [];
      try { matches = JSON.parse(raw); } catch (e) { matches = []; }
      out.push({
        name: name,
        wip: li.querySelector('input.step-wip').checked,
        matches: matches,
      });
    });
    return out;
  }

  function categoryBadge(idx, steps) {
    // Walk forward; the first WIP row ends READY. After any WIP
    // is seen, every non-WIP row is DONE.
    var seenWip = false;
    for (var i = 0; i <= idx; i++) {
      if (steps[i].wip) seenWip = true;
    }
    if (steps[idx].wip) return { text: 'WIP', color: 'var(--p-600)' };
    return seenWip
      ? { text: 'DONE', color: 'var(--muted)' }
      : { text: 'READY', color: 'var(--muted)' };
  }

  function refreshBadges() {
    var steps = readSteps();
    var rows = document.querySelectorAll('#steps-list li[data-step]');
    rows.forEach(function (li, idx) {
      var span = li.querySelector('.step-badge');
      if (!span || idx >= steps.length) return;
      var b = categoryBadge(idx, steps);
      span.textContent = b.text;
      span.style.color = b.color;
    });
  }

  function renderMatchPills(li, matches) {
    // Re-render the per-row match chips from the row's data-matches.
    var holder = li.querySelector('.step-matches');
    if (!holder) return;
    holder.innerHTML = '';
    if (!matches || matches.length === 0) {
      var hint = document.createElement('em');
      hint.className = 'step-no-match';
      hint.textContent = '⚠ no source match — items won\'t map here';
      hint.style.cssText = 'font-size: 0.7rem; color: var(--t-700);';
      holder.appendChild(hint);
      return;
    }
    matches.forEach(function (m, idx) {
      var pill = document.createElement('span');
      pill.className = 'step-match';
      pill.style.cssText = 'display: inline-flex; align-items: center; ' +
        'gap: 0.25rem; padding: 0.1rem 0.4rem; border-radius: 0.5rem; ' +
        'background: var(--p-50); color: var(--p-700); font-size: 0.7rem; ' +
        'border: 0.0625rem solid var(--p-200);';
      pill.appendChild(document.createTextNode(m));
      var x = document.createElement('button');
      x.type = 'button';
      x.textContent = '×';
      x.style.cssText = 'background: transparent; border: 0; cursor: pointer; ' +
        'padding: 0; font-size: 0.7rem; color: var(--p-700);';
      x.onclick = function () {
        var ms = JSON.parse(li.dataset.matches || '[]');
        ms.splice(idx, 1);
        li.dataset.matches = JSON.stringify(ms);
        renderMatchPills(li, ms);
      };
      pill.appendChild(x);
      holder.appendChild(pill);
    });
  }

  function renderStepRow(name, wip, matches) {
    var li = document.createElement('li');
    li.dataset.step = '1';
    li.dataset.matches = JSON.stringify(matches || []);
    li.style.cssText = 'display: grid; ' +
      'grid-template-columns: 3rem 1fr auto auto auto auto; ' +
      'gap: 0.4rem; align-items: center; ' +
      'padding: 0.4rem 0.5rem; ' +
      'border-bottom: 0.0625rem solid var(--border); ' +
      'background: var(--white);';

    var badge = document.createElement('span');
    badge.className = 'step-badge';
    badge.style.cssText = 'font-size: 0.65rem; font-weight: 600; ' +
      'letter-spacing: 0.08em; text-transform: uppercase;';
    li.appendChild(badge);

    var center = document.createElement('div');
    center.style.cssText = 'display: flex; flex-direction: column; gap: 0.25rem;';
    var nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.className = 'step-name';
    nameInput.value = name;
    nameInput.style.cssText = 'padding: 0.2rem 0.4rem; ' +
      'border: 0.0625rem solid var(--border); border-radius: 0.2rem;';
    center.appendChild(nameInput);
    var matchHolder = document.createElement('div');
    matchHolder.className = 'step-matches';
    matchHolder.style.cssText = 'display: flex; flex-wrap: wrap; gap: 0.25rem; ' +
      'align-items: center; min-height: 1.1rem;';
    center.appendChild(matchHolder);
    li.appendChild(center);

    var wipLabel = document.createElement('label');
    wipLabel.style.cssText = 'display: flex; align-items: center; gap: 0.25rem; font-size: 0.8125rem;';
    var wipInput = document.createElement('input');
    wipInput.type = 'checkbox';
    wipInput.className = 'step-wip';
    wipInput.checked = !!wip;
    wipInput.addEventListener('change', refreshBadges);
    wipLabel.appendChild(wipInput);
    wipLabel.appendChild(document.createTextNode('WIP'));
    li.appendChild(wipLabel);

    function mkBtn(text, click) {
      var b = document.createElement('button');
      b.type = 'button';
      b.textContent = text;
      b.style.cssText = 'font-size: 0.8rem; padding: 0.15rem 0.4rem;';
      b.onclick = click;
      return b;
    }
    li.appendChild(mkBtn('↑', function () {
      var prev = li.previousElementSibling;
      if (prev) li.parentElement.insertBefore(li, prev);
      refreshBadges();
    }));
    li.appendChild(mkBtn('↓', function () {
      var next = li.nextElementSibling;
      if (next) li.parentElement.insertBefore(next, li);
      refreshBadges();
    }));
    li.appendChild(mkBtn('×', function () {
      li.parentElement.removeChild(li);
      refreshBadges();
    }));

    renderMatchPills(li, matches || []);
    return li;
  }

  // Track the most recently focused step row — chip clicks append
  // to it if present, otherwise create a new step.
  var FOCUSED_STEP = null;
  document.addEventListener('focusin', function (ev) {
    var li = ev.target.closest && ev.target.closest('#steps-list li[data-step]');
    if (li) FOCUSED_STEP = li;
  });

  function addStep(name, wip, matches) {
    if (name === undefined) {
      var input = document.getElementById('new-step-name');
      name = (input.value || '').trim();
      if (!name) return;
      wip = document.getElementById('new-step-wip').checked;
      input.value = '';
      matches = [];  // custom typed → no source mapping yet
    }
    var li = renderStepRow(name, !!wip, matches || []);
    document.getElementById('steps-list').appendChild(li);
    refreshBadges();
    FOCUSED_STEP = li;
  }

  function addMatchToFocusedStep(match) {
    // Append `match` to the most-recently-focused step row's
    // matches. If no row is focused, create a new step whose name
    // == match and matches == [match].
    if (FOCUSED_STEP && FOCUSED_STEP.parentElement) {
      var existing = JSON.parse(FOCUSED_STEP.dataset.matches || '[]');
      if (existing.indexOf(match) === -1) existing.push(match);
      FOCUSED_STEP.dataset.matches = JSON.stringify(existing);
      renderMatchPills(FOCUSED_STEP, existing);
      return;
    }
    addStep(match, true, [match]);
  }

  function renderChip(container, item) {
    // `item` = {name, wip}. Two click targets:
    //   - chip body → add as a MATCH to the focused step row
    //     (or create a new step if none is focused).
    //   - "as new step" right-side affordance → always create a
    //     fresh step row with name == match, matches == [match].
    var wrap = document.createElement('span');
    wrap.className = 'sugg-chip';
    wrap.style.cssText = 'display: inline-flex; align-items: center; ' +
      'border: 0.0625rem solid var(--border); border-radius: 0.6rem; ' +
      'background: var(--surface); overflow: hidden;';

    var addMatch = document.createElement('button');
    addMatch.type = 'button';
    addMatch.textContent = '+ ' + item.name;
    addMatch.title = 'Add as a match to the focused step';
    addMatch.style.cssText = 'font-size: 0.75rem; padding: 0.15rem 0.5rem; ' +
      'border: 0; background: transparent; cursor: pointer;';
    addMatch.onclick = function () {
      addMatchToFocusedStep(item.name);
    };
    wrap.appendChild(addMatch);

    var asStep = document.createElement('button');
    asStep.type = 'button';
    asStep.textContent = '⇢ step';
    asStep.title = 'Create a new step whose name = this match';
    asStep.style.cssText = 'font-size: 0.7rem; padding: 0.15rem 0.4rem; ' +
      'border: 0; border-left: 0.0625rem solid var(--border); ' +
      'background: transparent; color: var(--muted); cursor: pointer;';
    asStep.onclick = function () {
      addStep(item.name, !!item.wip, [item.name]);
    };
    wrap.appendChild(asStep);

    container.appendChild(wrap);
  }

  function probeVocab() {
    var data = readForm();
    var status = document.getElementById('stages-status');
    status.textContent = 'Discovering…';
    status.className = 'probe-status';
    fetch('/api/internal/contracts/_probe-source-vocab', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'fetch',
      },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      var warehouseDiv = document.getElementById('sugg-warehouse');
      var labelsDiv = document.getElementById('sugg-labels');
      var lifecycleDiv = document.getElementById('sugg-lifecycle');
      warehouseDiv.innerHTML = '';
      labelsDiv.innerHTML = '';
      lifecycleDiv.innerHTML = '';

      var warehouse = body.warehouse_stages || [];
      var labels = body.labels || [];
      var lifecycle = body.lifecycle_events || [];

      warehouse.forEach(function (item) { renderChip(warehouseDiv, item); });
      labels.forEach(function (item) { renderChip(labelsDiv, item); });
      lifecycle.forEach(function (item) { renderChip(lifecycleDiv, item); });

      if (warehouse.length === 0) {
        warehouseDiv.innerHTML = '<em class="muted" style="font-size: 0.75rem;">' +
          'no stages observed yet — materialise the workflow to populate this list' +
          '</em>';
      }
      if (labels.length === 0) {
        labelsDiv.innerHTML = '<em class="muted" style="font-size: 0.75rem;">' +
          (body.hint || 'no labels found') + '</em>';
      }

      var total = warehouse.length + labels.length + lifecycle.length;
      status.textContent = '✓ ' + total + ' suggestion' + (total === 1 ? '' : 's');
      status.className = 'probe-status probe-status--ok';
    }).catch(function (err) {
      status.textContent = 'probe failed: ' + err;
      status.className = 'probe-status probe-status--fail';
    });
  }

  function buildYaml(data) {
    // Compose the YAML body from the form fields. The server's
    // PUT endpoint re-parses this against parse_contract_text, so
    // anything malformed surfaces as a 422.
    var lines = ["contract:"];
    lines.push("  name: " + data.name);
    if (data.label) lines.push("  label: " + JSON.stringify(data.label));
    lines.push("  source: " + data.source);
    if (data.source === "github" && data.repo) {
      lines.push("  repo: " + data.repo);
    }
    if (data.source === "jira") {
      if (data.jira_url) lines.push("  jira_url: " + data.jira_url);
      if (data.jira_project) lines.push("  jira_project: " + data.jira_project);
    }
    if (data.start) lines.push("  start: " + data.start);
    if (data.stop) lines.push("  stop: " + data.stop);
    var steps = readSteps();
    if (steps.length) {
      lines.push("  steps:");
      steps.forEach(function (s) {
        lines.push("    - name: " + JSON.stringify(s.name));
        lines.push("      wip: " + (s.wip ? "true" : "false"));
        if (s.matches && s.matches.length) {
          lines.push("      matches:");
          s.matches.forEach(function (m) {
            lines.push("        - " + JSON.stringify(m));
          });
        }
      });
    }
    return lines.join("\n") + "\n";
  }

  function readForm() {
    var f = document.getElementById("wizard");
    var data = {};
    new FormData(f).forEach(function (v, k) { data[k] = v; });
    return data;
  }

  function probeSource() {
    var data = readForm();
    if (!data.source) return;
    var status = document.getElementById("probe-status");
    status.textContent = "Checking…";
    status.className = "probe-status";
    fetch("/api/internal/contracts/_probe-source", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "fetch",
      },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      if (body.ok) {
        status.textContent = "✓ " + (body.label || "target reachable");
        status.className = "probe-status probe-status--ok";
        // Once the source target validates, auto-load the suggestions
        // for the Steps editor (labels + lifecycle + warehouse). No
        // separate button to click.
        probeVocab();
      } else {
        status.textContent = "✗ " + (body.error || "target not reachable");
        status.className = "probe-status probe-status--fail";
      }
    }).catch(function (err) {
      status.textContent = "probe failed: " + err;
      status.className = "probe-status probe-status--fail";
    });
  }

  function refreshSourceKindLabel() {
    // Source dropdown changed → relabel the "Labels in the source"
    // section to match (Jira's vocab is "statuses", not "labels").
    var data = readForm();
    var labelEl = document.getElementById("sugg-labels-label");
    if (!labelEl) return;
    labelEl.textContent = data.source === "jira"
      ? "Statuses in the project"
      : "Labels in the repo";
  }

  var WIZARD_MODE = {{ wizard_mode | tojson }};
  var EDIT_ID = {{ edit_id | tojson }};

  function hydrateFromExisting(id) {
    fetch("/api/internal/contracts/" + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (body) {
        var form = document.getElementById("wizard");
        var p = body.parsed || {};
        function setField(name, value) {
          var el = form.elements[name];
          if (!el) return;
          if (value !== null && value !== undefined) el.value = value;
        }
        setField("name", p.name);
        setField("label", p.label);
        setField("source", p.source);
        setField("repo", p.repo);
        setField("jira_url", p.jira_url);
        setField("jira_project", p.jira_project);
        setField("start", p.start);
        setField("stop", p.stop);
        // Toggle conditional fields based on the loaded source.
        document.getElementById("source-fieldset").dataset.source = p.source || "github";
        // Hydrate steps from the canonical `steps:` list (each
        // row carries name + wip + matches). Falls back to the
        // legacy `states:` shim for older payloads.
        if (Array.isArray(p.steps) && p.steps.length) {
          p.steps.forEach(function (s) {
            addStep(s.name, !!s.wip, s.matches || []);
          });
        } else if (p.states) {
          (p.states.backlog || []).forEach(function (n) { addStep(n, false, [n]); });
          (p.states.wip || []).forEach(function (n) { addStep(n, true, [n]); });
          (p.states.done || []).forEach(function (n) { addStep(n, false, [n]); });
        }
        // The id is fixed in edit mode; lock the field.
        if (WIZARD_MODE === "edit") {
          form.elements.name.readOnly = true;
        }
      });
  }

  function confirmArchive() {
    // Archive (soft delete) — the contract goes to /admin/contracts/archive
    // where it can be restored or hard-deleted later. The warehouse data
    // is untouched by archive; permanent erasure is a separate flow.
    var reason = window.prompt(
      "Archive '" + EDIT_ID + "'? Optional reason for the audit log:",
      ""
    );
    if (reason === null) return; // cancelled
    fetch(
      "/api/internal/contracts/" + encodeURIComponent(EDIT_ID) + "/archive",
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-Requested-With": "fetch",
        },
        body: JSON.stringify({ reason: reason || null }),
      }
    ).then(function (r) {
      if (r.ok) { window.location.href = "/"; return; }
      r.json().then(function (body) {
        document.getElementById("wizard-errors").textContent =
          (body.detail && body.detail.message) || body.detail || "archive failed";
      });
    });
  }

  if (WIZARD_MODE === "edit" && EDIT_ID) {
    hydrateFromExisting(EDIT_ID);
  }

  // Always pre-fill the lifecycle chips (they're source-kind
  // constants — no API call). Warehouse + labels come from the
  // first probe after the user enters the repo / project.
  refreshSourceKindLabel();
  probeVocab();

  document.getElementById("wizard").addEventListener("submit", function (ev) {
    ev.preventDefault();
    var errs = document.getElementById("wizard-errors");
    errs.textContent = "";
    var data = readForm();
    var yamlText = buildYaml(data);
    fetch("/api/internal/contracts/" + encodeURIComponent(data.name), {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "fetch",
      },
      body: JSON.stringify({ yaml: yamlText }),
    }).then(function (r) {
      if (r.ok) {
        window.location.href = "/workflows/" + encodeURIComponent(data.name);
        return;
      }
      return r.json().then(function (body) {
        var msg = (body.detail && body.detail.message) || body.detail || "save failed";
        errs.textContent = msg;
      });
    });
  });
</script>
{% endblock %}
