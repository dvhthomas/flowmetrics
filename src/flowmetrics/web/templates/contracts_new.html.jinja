{% extends "_base.html.jinja" %}

{# New-contract wizard. Three fieldsets visible at once (no
   navigation between steps) — name + source + window. Source
   probe fires on blur of the repo / jira_project field. Save
   validates, PUTs, and redirects to the new dashboard. #}

{% block filter_bar %}{% endblock %}
{% block data_source_strip %}{% endblock %}

{% block content %}
<style>
  .wizard {
    max-width: 38rem;
    margin: 1.5rem 0;
  }
  .wizard fieldset {
    border: 0.0625rem solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem 0.5rem 1.25rem;
    margin: 0 0 1.25rem 0;
  }
  .wizard legend {
    font-family: var(--head-font);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-600);
    padding: 0 0.4rem;
  }
  .wizard label {
    display: block;
    margin: 0.4rem 0;
    font-size: 0.875rem;
    color: var(--muted);
  }
  .wizard label > input,
  .wizard label > select {
    display: block;
    width: 100%;
    margin-top: 0.2rem;
    padding: 0.4rem 0.5rem;
    border: 0.0625rem solid var(--border);
    border-radius: 0.25rem;
    font-size: 1rem;
    color: var(--fg);
    background: var(--white);
  }
  .source-fields[data-source="jira"] .source-github,
  .source-fields[data-source="github"] .source-jira {
    display: none;
  }
  .probe-status {
    font-size: 0.8125rem;
    margin-top: 0.3rem;
    min-height: 1.1rem;
  }
  .probe-status--ok { color: var(--p-600); }
  .probe-status--fail { color: var(--t-700); }
  .wizard-actions {
    display: flex;
    gap: 0.75rem;
    margin: 0 0 1rem 0;
  }
  .wizard-actions button[type="submit"] {
    background: var(--p-500);
    color: var(--white);
    border: 0;
    padding: 0.45rem 1.1rem;
    border-radius: 0.3rem;
    font-weight: 600;
    cursor: pointer;
  }
  .wizard-actions button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .wizard-errors {
    color: var(--t-700);
    font-size: 0.875rem;
    margin: 0.5rem 0 0 0;
    min-height: 1.2rem;
  }
</style>

{% if wizard_mode == "edit" %}
<h1>Edit workflow: {{ edit_id }}</h1>
<p class="muted">
  Save overwrites the existing YAML. Delete removes it (warehouse
  data on disk requires explicit purge — the button asks).
</p>
{% else %}
<h1>New workflow</h1>
<p class="muted">
  A workflow is a YAML file under <code>contracts/</code>. Fill in the
  fields below; we'll write it for you and open the dashboard.
</p>
{% endif %}

<form class="wizard" id="wizard">
  <fieldset>
    <legend>Identity</legend>
    <label>Routing ID (lowercase, dashes only)
      <input type="text" name="name" required pattern="[a-z0-9-]+"
             placeholder="astral-uv-week">
    </label>
    <label>Display label (optional)
      <input type="text" name="label" placeholder="Astral uv weekly">
    </label>
  </fieldset>

  <fieldset class="source-fields" data-source="github" id="source-fieldset">
    <legend>Source</legend>
    <label>Source kind
      <select name="source" onchange="document.getElementById('source-fieldset').dataset.source=this.value">
        <option value="github" selected>GitHub</option>
        <option value="jira">Jira</option>
      </select>
    </label>

    <div class="source-github">
      <label>Repository (owner/name)
        <input type="text" name="repo" placeholder="astral-sh/uv"
               onblur="probeSource()">
      </label>
    </div>

    <div class="source-jira">
      <label>Jira base URL
        <input type="text" name="jira_url"
               placeholder="https://issues.apache.org/jira"
               onblur="probeSource()">
      </label>
      <label>Project key
        <input type="text" name="jira_project" placeholder="BIGTOP"
               onblur="probeSource()">
      </label>
    </div>

    <div class="probe-status" id="probe-status"></div>
  </fieldset>

  <fieldset id="stages-fieldset">
    <legend>Stages (optional)</legend>
    <p class="muted" style="font-size: 0.8125rem; margin: 0 0 0.6rem 0;">
      Discover from the source, then click to move stages between
      Backlog / WIP / Done. WIP is the only required category.
    </p>
    <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
      <button type="button" class="filter-apply" onclick="probeStages()">Discover stages</button>
      <span class="probe-status" id="stages-status"></span>
    </div>
    <div class="stage-buckets" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;">
      <div data-bucket="backlog" id="stage-bucket-backlog">
        <strong style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">Backlog</strong>
        <ul class="stage-list" style="list-style: none; padding: 0.4rem; margin: 0.3rem 0; border: 0.0625rem dashed var(--border); min-height: 4rem; border-radius: 0.25rem;"></ul>
      </div>
      <div data-bucket="wip" id="stage-bucket-wip">
        <strong style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--p-600);">WIP</strong>
        <ul class="stage-list" style="list-style: none; padding: 0.4rem; margin: 0.3rem 0; border: 0.0625rem dashed var(--border); min-height: 4rem; border-radius: 0.25rem;"></ul>
      </div>
      <div data-bucket="done" id="stage-bucket-done">
        <strong style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">Done</strong>
        <ul class="stage-list" style="list-style: none; padding: 0.4rem; margin: 0.3rem 0; border: 0.0625rem dashed var(--border); min-height: 4rem; border-radius: 0.25rem;"></ul>
      </div>
    </div>
    <div style="margin-top: 0.6rem; display: flex; gap: 0.4rem;">
      <input type="text" id="custom-stage" placeholder="+ Add custom stage"
             style="flex: 1; padding: 0.3rem 0.5rem; border: 0.0625rem solid var(--border); border-radius: 0.25rem;">
      <button type="button" onclick="addCustomStage()">Add to WIP</button>
    </div>
  </fieldset>

  <fieldset>
    <legend>Window (optional)</legend>
    <label>Start (YYYY-MM-DD)
      <input type="date" name="start">
    </label>
    <label>Stop (YYYY-MM-DD)
      <input type="date" name="stop">
    </label>
  </fieldset>

  <div class="wizard-actions">
    <button type="submit">{% if wizard_mode == "edit" %}Save{% else %}Save &amp; open{% endif %}</button>
    <a href="/" class="filter-reset">Cancel</a>
    {% if wizard_mode == "edit" %}
    <button type="button" id="delete-btn"
            style="margin-left: auto; background: transparent; border: 0.0625rem solid var(--t-700); color: var(--t-700); padding: 0.4rem 1rem; border-radius: 0.3rem; cursor: pointer;"
            onclick="confirmDelete()">Delete</button>
    {% endif %}
  </div>
  <p class="wizard-errors" id="wizard-errors"></p>
</form>

<script>
  function readStages() {
    var out = { backlog: [], wip: [], done: [] };
    document.querySelectorAll('.stage-buckets [data-bucket]').forEach(function (el) {
      var bucket = el.dataset.bucket;
      el.querySelectorAll('.stage-list li').forEach(function (li) {
        out[bucket].push(li.dataset.stage);
      });
    });
    return out;
  }

  function renderStageChip(name, currentBucket) {
    var li = document.createElement('li');
    li.dataset.stage = name;
    li.style.cssText = 'display: flex; align-items: center; gap: 0.3rem; ' +
      'padding: 0.2rem 0.4rem; margin: 0.15rem 0; border-radius: 0.2rem; ' +
      'background: var(--surface); font-size: 0.875rem;';
    var label = document.createElement('span');
    label.textContent = name;
    label.style.flex = '1';
    li.appendChild(label);
    ['backlog', 'wip', 'done'].forEach(function (b) {
      if (b === currentBucket) return;
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = '→ ' + b[0].toUpperCase();
      btn.style.cssText = 'font-size: 0.7rem; padding: 0.1rem 0.3rem;';
      btn.onclick = function () {
        li.parentElement.removeChild(li);
        document.querySelector('#stage-bucket-' + b + ' .stage-list').appendChild(
          renderStageChip(name, b)
        );
      };
      li.appendChild(btn);
    });
    var del = document.createElement('button');
    del.type = 'button';
    del.textContent = '×';
    del.style.cssText = 'font-size: 0.7rem; padding: 0.1rem 0.3rem; color: var(--muted);';
    del.onclick = function () { li.parentElement.removeChild(li); };
    li.appendChild(del);
    return li;
  }

  function probeStages() {
    var data = readForm();
    var status = document.getElementById('stages-status');
    status.textContent = 'Discovering…';
    status.className = 'probe-status';
    fetch('/api/internal/contracts/_probe-stages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'fetch',
      },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      var stages = body.stages || [];
      var wipList = document.querySelector('#stage-bucket-wip .stage-list');
      stages.forEach(function (name) {
        wipList.appendChild(renderStageChip(name, 'wip'));
      });
      if (body.hint) {
        status.textContent = body.hint;
        status.className = 'probe-status';
      } else {
        status.textContent = '✓ ' + stages.length + ' stages discovered';
        status.className = 'probe-status probe-status--ok';
      }
    });
  }

  function addCustomStage() {
    var input = document.getElementById('custom-stage');
    var name = input.value.trim();
    if (!name) return;
    document.querySelector('#stage-bucket-wip .stage-list').appendChild(
      renderStageChip(name, 'wip')
    );
    input.value = '';
  }

  function buildYaml(data) {
    // Compose the YAML body from the form fields. The server's
    // PUT endpoint re-parses this against parse_contract_text, so
    // anything malformed surfaces as a 422.
    var lines = ["contract:"];
    lines.push("  name: " + data.name);
    if (data.label) lines.push("  label: " + JSON.stringify(data.label));
    lines.push("  source: " + data.source);
    if (data.source === "github" && data.repo) {
      lines.push("  repo: " + data.repo);
    }
    if (data.source === "jira") {
      if (data.jira_url) lines.push("  jira_url: " + data.jira_url);
      if (data.jira_project) lines.push("  jira_project: " + data.jira_project);
    }
    if (data.start) lines.push("  start: " + data.start);
    if (data.stop) lines.push("  stop: " + data.stop);
    var stages = readStages();
    if (stages.backlog.length || stages.wip.length || stages.done.length) {
      lines.push("  states:");
      ['backlog', 'wip', 'done'].forEach(function (b) {
        if (stages[b].length === 0) return;
        lines.push("    " + b + ":");
        stages[b].forEach(function (n) {
          lines.push("      - " + JSON.stringify(n));
        });
      });
    }
    return lines.join("\n") + "\n";
  }

  function readForm() {
    var f = document.getElementById("wizard");
    var data = {};
    new FormData(f).forEach(function (v, k) { data[k] = v; });
    return data;
  }

  function probeSource() {
    var data = readForm();
    if (!data.source) return;
    var status = document.getElementById("probe-status");
    status.textContent = "Checking…";
    status.className = "probe-status";
    fetch("/api/internal/contracts/_probe-source", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "fetch",
      },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      if (body.ok) {
        status.textContent = "✓ " + (body.label || "target reachable");
        status.className = "probe-status probe-status--ok";
      } else {
        status.textContent = "✗ " + (body.error || "target not reachable");
        status.className = "probe-status probe-status--fail";
      }
    }).catch(function (err) {
      status.textContent = "probe failed: " + err;
      status.className = "probe-status probe-status--fail";
    });
  }

  var WIZARD_MODE = {{ wizard_mode | tojson }};
  var EDIT_ID = {{ edit_id | tojson }};

  function hydrateFromExisting(id) {
    fetch("/api/internal/contracts/" + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (body) {
        var form = document.getElementById("wizard");
        var p = body.parsed || {};
        function setField(name, value) {
          var el = form.elements[name];
          if (!el) return;
          if (value !== null && value !== undefined) el.value = value;
        }
        setField("name", p.name);
        setField("label", p.label);
        setField("source", p.source);
        setField("repo", p.repo);
        setField("jira_url", p.jira_url);
        setField("jira_project", p.jira_project);
        setField("start", p.start);
        setField("stop", p.stop);
        // Toggle conditional fields based on the loaded source.
        document.getElementById("source-fieldset").dataset.source = p.source || "github";
        // Hydrate stages into the right buckets.
        if (p.states) {
          ['backlog', 'wip', 'done'].forEach(function (bucket) {
            var list = document.querySelector('#stage-bucket-' + bucket + ' .stage-list');
            (p.states[bucket] || []).forEach(function (name) {
              list.appendChild(renderStageChip(name, bucket));
            });
          });
        }
        // The id is fixed in edit mode; lock the field.
        if (WIZARD_MODE === "edit") {
          form.elements.name.readOnly = true;
        }
      });
  }

  function confirmDelete() {
    var typed = window.prompt(
      "Type the workflow id (" + EDIT_ID + ") to confirm delete. " +
      "If the warehouse has data, you'll be prompted again to purge."
    );
    if (typed !== EDIT_ID) return;
    fetch("/api/internal/contracts/" + encodeURIComponent(EDIT_ID), {
      method: "DELETE",
      headers: { "X-Requested-With": "fetch" },
    }).then(function (r) {
      if (r.ok) { window.location.href = "/"; return; }
      if (r.status === 409) {
        if (window.confirm(
          "Warehouse data exists for this workflow. Purge it too?"
        )) {
          return fetch(
            "/api/internal/contracts/" + encodeURIComponent(EDIT_ID) +
            "?purge_data=true",
            { method: "DELETE", headers: { "X-Requested-With": "fetch" } }
          ).then(function (r2) {
            if (r2.ok) window.location.href = "/";
          });
        }
        return;
      }
      r.json().then(function (body) {
        document.getElementById("wizard-errors").textContent =
          (body.detail && body.detail.message) || body.detail || "delete failed";
      });
    });
  }

  if (WIZARD_MODE === "edit" && EDIT_ID) {
    hydrateFromExisting(EDIT_ID);
  }

  document.getElementById("wizard").addEventListener("submit", function (ev) {
    ev.preventDefault();
    var errs = document.getElementById("wizard-errors");
    errs.textContent = "";
    var data = readForm();
    var yamlText = buildYaml(data);
    fetch("/api/internal/contracts/" + encodeURIComponent(data.name), {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "fetch",
      },
      body: JSON.stringify({ yaml: yamlText }),
    }).then(function (r) {
      if (r.ok) {
        window.location.href = "/workflows/" + encodeURIComponent(data.name);
        return;
      }
      return r.json().then(function (body) {
        var msg = (body.detail && body.detail.message) || body.detail || "save failed";
        errs.textContent = msg;
      });
    });
  });
</script>
{% endblock %}
