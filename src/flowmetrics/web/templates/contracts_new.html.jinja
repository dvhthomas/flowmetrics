{% extends "_base.html.jinja" %}

{# Contract builder. One scrolling form, sections gated so the user
   can't reach an action before its preconditions are met:
     Identity + Source are required → unlock Steps → unlock Save.
   `wizard_mode` is "new" or "edit"; `edit_id` is the locked id in
   edit mode. #}

{% block filter_bar %}{% endblock %}
{% block data_source_strip %}{% endblock %}

{% block content %}
<style>
  .wizard { max-width: 42rem; margin: 1.5rem 0; }

  .wizard fieldset {
    border: 0.0625rem solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin: 0 0 1.25rem 0;
  }
  .wizard legend {
    font-family: var(--head-font);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-600);
    padding: 0 0.4rem;
  }

  /* A section that's locked until its preconditions are met. */
  .wizard fieldset[data-locked="true"] { opacity: 0.55; }
  .wizard fieldset[data-locked="true"] .lock-note { display: block; }
  .lock-note {
    display: none;
    font-size: 0.8125rem;
    color: var(--t-700);
    margin: 0 0 0.5rem 0;
  }

  /* Consistent field grouping + inputs. */
  .field { margin: 0 0 0.75rem 0; }
  .field:last-child { margin-bottom: 0; }
  .field-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.25rem;
  }
  .field-hint { font-weight: 400; color: var(--muted); font-size: 0.75rem; }
  .req { color: var(--t-700); margin-left: 0.15rem; }
  .field-input {
    display: block;
    width: 100%;
    padding: 0.45rem 0.55rem;
    border: 0.0625rem solid var(--border);
    border-radius: 0.3rem;
    font-size: 0.9375rem;
    font-family: var(--body-font);
    color: var(--fg);
    background: var(--white);
    box-sizing: border-box;
  }
  .field-input:focus {
    outline: none;
    border-color: var(--p-500);
    box-shadow: 0 0 0 0.125rem var(--p-100);
  }

  /* Buttons — one scale, three intents. */
  .btn {
    font-family: var(--body-font);
    font-size: 0.875rem;
    padding: 0.4rem 0.9rem;
    border-radius: 0.3rem;
    border: 0.0625rem solid var(--border);
    background: var(--surface);
    color: var(--fg);
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn:hover:not([disabled]) { border-color: var(--muted); }
  .btn--primary {
    background: var(--p-500);
    color: var(--white);
    border-color: var(--p-500);
    font-weight: 600;
  }
  .btn--danger { color: var(--t-700); border-color: var(--t-700); }
  .btn--sm { font-size: 0.8rem; padding: 0.2rem 0.5rem; }
  .btn[disabled] { opacity: 0.45; cursor: not-allowed; }

  .probe-status { font-size: 0.8125rem; min-height: 1.1rem; }
  .probe-status--ok { color: var(--p-600); }
  .probe-status--fail { color: var(--t-700); }

  .source-fields[data-source="jira"] .source-github,
  .source-fields[data-source="github"] .source-jira { display: none; }

  /* Steps editor. */
  .steps-list {
    list-style: none; padding: 0; margin: 0 0 0.75rem 0;
    border: 0.0625rem solid var(--border); border-radius: 0.3rem;
  }
  .steps-list:empty { display: none; }
  .step-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto auto auto auto;
    gap: 0.5rem; align-items: center;
    padding: 0.5rem 0.6rem;
    border-bottom: 0.0625rem solid var(--border);
    background: var(--white);
  }
  .step-row:last-child { border-bottom: 0; }
  .step-badge {
    font-size: 0.625rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .step-center { display: flex; flex-direction: column; gap: 0.3rem; }
  .step-name-input {
    padding: 0.3rem 0.45rem;
    border: 0.0625rem solid var(--border); border-radius: 0.25rem;
    font-size: 0.9375rem; font-family: var(--body-font);
  }
  .step-matches {
    display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center;
    min-height: 1.1rem;
  }
  .match-pill {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.1rem 0.45rem; border-radius: 0.5rem;
    background: var(--p-50); color: var(--p-700);
    font-size: 0.7rem; border: 0.0625rem solid var(--p-200);
  }
  .match-pill button {
    background: transparent; border: 0; cursor: pointer;
    padding: 0; font-size: 0.75rem; color: var(--p-700); line-height: 1;
  }
  .step-by-name { font-size: 0.7rem; color: var(--muted); font-style: italic; }
  .step-wip-label {
    display: flex; align-items: center; gap: 0.3rem; font-size: 0.8125rem;
  }

  .add-step-row {
    display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;
  }
  .add-step-row .field-input { flex: 1; min-width: 12rem; width: auto; }

  /* Suggestion chips. */
  .sugg-group { margin-bottom: 0.6rem; }
  .sugg-group:last-child { margin-bottom: 0; }
  .sugg-group-title {
    font-size: 0.7rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--muted);
  }
  .sugg-chips {
    display: flex; flex-wrap: wrap; gap: 0.35rem;
    margin-top: 0.3rem; min-height: 1.4rem;
  }
  .sugg-chip {
    display: inline-flex; align-items: center;
    border: 0.0625rem solid var(--border); border-radius: 0.6rem;
    background: var(--surface); overflow: hidden;
  }
  .sugg-chip button {
    border: 0; background: transparent; cursor: pointer;
    font-size: 0.75rem; padding: 0.2rem 0.55rem;
  }
  .sugg-chip .sugg-chip__step {
    border-left: 0.0625rem solid var(--border);
    color: var(--muted); font-size: 0.7rem; padding: 0.2rem 0.45rem;
  }
  .sugg-empty { font-size: 0.75rem; color: var(--muted); font-style: italic; }

  .wizard-actions {
    display: flex; gap: 0.6rem; align-items: center;
    margin: 0 0 0.5rem 0; flex-wrap: wrap;
  }
  .wizard-hint { font-size: 0.8125rem; color: var(--muted); }
  .wizard-errors {
    color: var(--t-700); font-size: 0.875rem;
    margin: 0.25rem 0 0 0; min-height: 1.2rem;
  }

  /* Dry-run results. */
  .dr-section {
    margin: 0.6rem 0; border: 0.0625rem solid var(--border);
    border-radius: 0.3rem;
  }
  .dr-head {
    display: flex; align-items: baseline; gap: 0.5rem;
    padding: 0.4rem 0.6rem; background: var(--surface);
    border-bottom: 0.0625rem solid var(--border);
  }
  .dr-list { list-style: none; padding: 0; margin: 0; }
  .dr-item {
    padding: 0.3rem 0.6rem; border-bottom: 0.0625rem solid var(--border);
    display: flex; gap: 0.6rem; font-size: 0.8125rem;
  }
  .dr-item:last-child { border-bottom: 0; }
  .dr-stage {
    color: var(--muted); min-width: 9rem;
    font-family: var(--mono-font); font-size: 0.75rem;
  }
</style>

{% if wizard_mode == "edit" %}
<h1>Edit workflow: {{ edit_id }}</h1>
{% else %}
<h1>New workflow</h1>
<p class="wizard-hint">
  Fields marked <span class="req">*</span> are required. Define the
  source, then build the workflow's steps.
</p>
{% endif %}

<form class="wizard" id="wizard">
  <fieldset>
    <legend>Identity</legend>
    <div class="field">
      <label class="field-label" for="f-name">
        Routing ID <span class="req" aria-hidden="true">*</span>
        <span class="field-hint">— lowercase, dashes only; can't change later</span>
      </label>
      <input class="field-input" id="f-name" type="text" name="name"
             required aria-required="true" pattern="[a-z0-9-]+"
             placeholder="astral-uv-week">
    </div>
    <div class="field">
      <label class="field-label" for="f-label">
        Display label
        <span class="field-hint">— optional; shown in the dashboard</span>
      </label>
      <input class="field-input" id="f-label" type="text" name="label"
             placeholder="Astral uv weekly">
    </div>
  </fieldset>

  <fieldset class="source-fields" data-source="github" id="source-fieldset">
    <legend>Source</legend>
    <div class="field">
      <label class="field-label" for="f-source">
        Source kind <span class="req" aria-hidden="true">*</span>
      </label>
      <select class="field-input" id="f-source" name="source"
              aria-required="true" onchange="onSourceKindChange()">
        <option value="github" selected>GitHub</option>
        <option value="jira">Jira</option>
      </select>
    </div>

    <div class="source-github">
      <div class="field">
        <label class="field-label" for="f-repo">
          Repository <span class="req" aria-hidden="true">*</span>
          <span class="field-hint">— owner/name</span>
        </label>
        <input class="field-input" id="f-repo" type="text" name="repo"
               aria-required="true" placeholder="astral-sh/uv"
               oninput="updateValidity()" onblur="probeSource()">
      </div>
    </div>

    <div class="source-jira">
      <div class="field">
        <label class="field-label" for="f-jira-url">
          Jira base URL <span class="req" aria-hidden="true">*</span>
        </label>
        <input class="field-input" id="f-jira-url" type="text" name="jira_url"
               aria-required="true"
               placeholder="https://issues.apache.org/jira"
               oninput="updateValidity()" onblur="probeSource()">
      </div>
      <div class="field">
        <label class="field-label" for="f-jira-project">
          Project key <span class="req" aria-hidden="true">*</span>
        </label>
        <input class="field-input" id="f-jira-project" type="text"
               name="jira_project" aria-required="true" placeholder="CASSANDRA"
               oninput="updateValidity()" onblur="probeSource()">
      </div>
    </div>

    <div class="probe-status" id="probe-status"></div>
  </fieldset>

  <fieldset id="steps-fieldset">
    <legend>Steps</legend>
    <p class="lock-note" id="steps-lock-note">
      Define a valid source above first — steps map to that source's data.
    </p>
    <p class="field-hint" style="margin: 0 0 0.75rem 0;">
      A step is a stage in your workflow. By default a step captures
      items whose source stage matches the step's name; add explicit
      matches (chips below) to capture other labels / statuses / events.
      Toggle WIP per step.
    </p>

    <ol class="steps-list" id="steps-list"></ol>

    <div class="add-step-row">
      <input class="field-input" id="new-step-name" type="text"
             placeholder="New step name (e.g. In Progress)"
             oninput="updateValidity()"
             onkeydown="if(event.key==='Enter'){event.preventDefault();addStep();}">
      <label class="step-wip-label">
        <input type="checkbox" id="new-step-wip" checked> WIP
      </label>
      <button type="button" class="btn btn--sm" id="add-step"
              disabled onclick="addStep()">+ Add step</button>
      <span class="probe-status" id="stages-status"></span>
    </div>

    <div id="suggestions-panel" style="margin-top: 1rem;" hidden>
      <p class="field-hint" style="margin: 0 0 0.5rem 0;">
        Click a chip to bind it to the selected step (or
        <em>⇢ step</em> to make a new step from it).
      </p>
      {% if wizard_mode == "edit" %}
      <div class="sugg-group">
        <div class="sugg-group-title">Stages seen in imported data</div>
        <div id="sugg-warehouse" class="sugg-chips"></div>
      </div>
      {% endif %}
      <div class="sugg-group">
        <div class="sugg-group-title" id="sugg-labels-label">Labels in the repo</div>
        <div id="sugg-labels" class="sugg-chips"></div>
      </div>
      <div class="sugg-group">
        <div class="sugg-group-title">Lifecycle events</div>
        <div id="sugg-lifecycle" class="sugg-chips"></div>
      </div>
    </div>
  </fieldset>

  <fieldset id="dry-run-panel">
    <legend>Preview against live source</legend>
    <p class="lock-note" id="dry-run-lock-note">
      Add at least one step (and a valid source) to preview.
    </p>
    <p class="field-hint" style="margin: 0 0 0.75rem 0;">
      Test the workflow against real items — up to 200 (or 30 days).
      Nothing is written to the warehouse.
    </p>
    <div class="add-step-row" style="align-items: end;">
      <div class="field" style="margin: 0;">
        <label class="field-label" for="dry-run-since">From date</label>
        <input class="field-input" id="dry-run-since" type="date"
               style="width: auto; flex: none; min-width: 0;">
      </div>
      <button type="button" class="btn" id="dry-run-btn"
              disabled onclick="dryRun()">Dry run</button>
      <span class="probe-status" id="dry-run-status"></span>
    </div>
    <div id="dry-run-results"></div>
  </fieldset>

  <fieldset>
    <legend>Window (optional)</legend>
    <p class="field-hint" style="margin: 0 0 0.75rem 0;">
      Limit the date range materialise fetches. Leave blank for the
      source's full history.
    </p>
    <div class="field">
      <label class="field-label" for="f-start">Start</label>
      <input class="field-input" id="f-start" type="date" name="start"
             style="width: auto;">
    </div>
    <div class="field">
      <label class="field-label" for="f-stop">Stop</label>
      <input class="field-input" id="f-stop" type="date" name="stop"
             style="width: auto;">
    </div>
  </fieldset>

  <div class="wizard-actions">
    <button type="submit" class="btn btn--primary" id="save-btn" disabled>
      {% if wizard_mode == "edit" %}Save{% else %}Save &amp; open{% endif %}
    </button>
    <a href="/" class="btn">Cancel</a>
    {% if wizard_mode == "edit" %}
    <a id="download-yaml-btn" class="btn" style="margin-left: auto;"
       href="/api/internal/contracts/{{ edit_id }}/yaml">Download YAML</a>
    <button type="button" class="btn" id="copy-yaml-btn"
            onclick="copyYaml()">Copy YAML</button>
    <button type="button" class="btn btn--danger" id="archive-btn"
            onclick="confirmArchive()">Archive</button>
    {% endif %}
  </div>
  <p class="wizard-hint" id="save-blocker"></p>
  <p class="wizard-errors" id="wizard-errors"></p>
</form>

<script>
  var WIZARD_MODE = {{ wizard_mode | tojson }};
  var EDIT_ID = {{ edit_id | tojson }};

  function readForm() {
    var f = document.getElementById("wizard");
    var data = {};
    new FormData(f).forEach(function (v, k) { data[k] = v; });
    return data;
  }

  // -----------------------------------------------------------------
  // Validity gating — never let the user reach an impossible action.
  // -----------------------------------------------------------------
  function sourceTargetComplete(data) {
    if (data.source === "github") return !!(data.repo && data.repo.indexOf("/") > 0);
    if (data.source === "jira") return !!(data.jira_url && data.jira_project);
    return false;
  }

  function updateValidity() {
    var data = readForm();
    var nameOk = /^[a-z0-9-]+$/.test(data.name || "");
    var srcOk = sourceTargetComplete(data);
    var steps = readSteps();

    document.getElementById("steps-fieldset").dataset.locked = srcOk ? "false" : "true";

    var newName = (document.getElementById("new-step-name").value || "").trim();
    document.getElementById("add-step").disabled = !(srcOk && newName);

    document.getElementById("dry-run-panel").dataset.locked =
      (srcOk && steps.length) ? "false" : "true";
    document.getElementById("dry-run-btn").disabled = !(srcOk && steps.length);

    var saveOk = nameOk && srcOk && steps.length > 0;
    document.getElementById("save-btn").disabled = !saveOk;

    var missing = [];
    if (!nameOk) missing.push("a routing id (lowercase, dashes)");
    if (!srcOk) missing.push(
      data.source === "jira" ? "a Jira URL + project key"
                             : "a repository (owner/name)"
    );
    if (steps.length === 0) missing.push("at least one step");
    document.getElementById("save-blocker").textContent =
      missing.length ? "To save, add: " + missing.join(", ") + "." : "";
  }

  // -----------------------------------------------------------------
  // Steps editor.
  // -----------------------------------------------------------------
  function readSteps() {
    var rows = document.querySelectorAll('#steps-list li[data-step]');
    var out = [];
    rows.forEach(function (li) {
      var name = li.querySelector('input.step-name').value.trim();
      if (!name) return;
      var matches = [];
      try { matches = JSON.parse(li.dataset.matches || '[]'); } catch (e) {}
      out.push({
        name: name,
        wip: li.querySelector('input.step-wip').checked,
        matches: matches,
      });
    });
    return out;
  }

  function categoryBadge(idx, steps) {
    var seenWip = false;
    for (var i = 0; i <= idx; i++) { if (steps[i].wip) seenWip = true; }
    if (steps[idx].wip) return { text: 'WIP', color: 'var(--p-600)' };
    return seenWip ? { text: 'DONE', color: 'var(--muted)' }
                   : { text: 'READY', color: 'var(--muted)' };
  }

  function refreshBadges() {
    var steps = readSteps();
    var rows = document.querySelectorAll('#steps-list li[data-step]');
    rows.forEach(function (li, idx) {
      var span = li.querySelector('.step-badge');
      if (!span || idx >= steps.length) return;
      var b = categoryBadge(idx, steps);
      span.textContent = b.text;
      span.style.color = b.color;
    });
  }

  function renderMatchPills(li, matches) {
    var holder = li.querySelector('.step-matches');
    if (!holder) return;
    holder.innerHTML = '';
    if (!matches || matches.length === 0) {
      // No explicit matches → the step captures items whose source
      // stage equals the step NAME. Informational, not an error.
      var name = li.querySelector('input.step-name').value.trim() || '(unnamed)';
      var note = document.createElement('span');
      note.className = 'step-by-name';
      note.textContent = 'captures source stage “' + name + '”';
      holder.appendChild(note);
      return;
    }
    matches.forEach(function (m, idx) {
      var pill = document.createElement('span');
      pill.className = 'match-pill';
      pill.appendChild(document.createTextNode(m));
      var x = document.createElement('button');
      x.type = 'button';
      x.textContent = '×';
      x.title = 'Remove this match';
      x.onclick = function () {
        var ms = JSON.parse(li.dataset.matches || '[]');
        ms.splice(idx, 1);
        li.dataset.matches = JSON.stringify(ms);
        renderMatchPills(li, ms);
        updateValidity();
      };
      pill.appendChild(x);
      holder.appendChild(pill);
    });
  }

  function renderStepRow(name, wip, matches) {
    var li = document.createElement('li');
    li.dataset.step = '1';
    li.dataset.matches = JSON.stringify(matches || []);
    li.className = 'step-row';

    var badge = document.createElement('span');
    badge.className = 'step-badge';
    li.appendChild(badge);

    var center = document.createElement('div');
    center.className = 'step-center';
    var nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.className = 'step-name step-name-input';
    nameInput.value = name;
    nameInput.addEventListener('input', function () {
      if (JSON.parse(li.dataset.matches || '[]').length === 0) {
        renderMatchPills(li, []);
      }
      updateValidity();
    });
    center.appendChild(nameInput);
    var matchHolder = document.createElement('div');
    matchHolder.className = 'step-matches';
    center.appendChild(matchHolder);
    li.appendChild(center);

    var wipLabel = document.createElement('label');
    wipLabel.className = 'step-wip-label';
    var wipInput = document.createElement('input');
    wipInput.type = 'checkbox';
    wipInput.className = 'step-wip';
    wipInput.checked = !!wip;
    wipInput.addEventListener('change', refreshBadges);
    wipLabel.appendChild(wipInput);
    wipLabel.appendChild(document.createTextNode('WIP'));
    li.appendChild(wipLabel);

    function mkBtn(text, title, click) {
      var b = document.createElement('button');
      b.type = 'button'; b.className = 'btn btn--sm';
      b.textContent = text; b.title = title; b.onclick = click;
      return b;
    }
    li.appendChild(mkBtn('↑', 'Move up', function () {
      var prev = li.previousElementSibling;
      if (prev) li.parentElement.insertBefore(li, prev);
      refreshBadges();
    }));
    li.appendChild(mkBtn('↓', 'Move down', function () {
      var next = li.nextElementSibling;
      if (next) li.parentElement.insertBefore(next, li);
      refreshBadges();
    }));
    li.appendChild(mkBtn('×', 'Remove step', function () {
      li.parentElement.removeChild(li);
      refreshBadges();
      updateValidity();
    }));

    renderMatchPills(li, matches || []);
    return li;
  }

  var FOCUSED_STEP = null;
  function revealSuggestions() {
    document.getElementById('suggestions-panel').hidden = false;
  }
  // The Suggestions panel is contextual help for binding source
  // identifiers to a step — keep it out of sight until the user is
  // actually working in the Steps area (focuses the new-step input
  // or any existing step row). Once revealed it stays visible so
  // chips remain clickable.
  document.addEventListener('focusin', function (ev) {
    var inSteps = ev.target.closest &&
      ev.target.closest('#steps-fieldset');
    if (inSteps) revealSuggestions();
    var li = ev.target.closest && ev.target.closest('#steps-list li[data-step]');
    if (li) FOCUSED_STEP = li;
  });

  function addStep(name, wip, matches) {
    if (name === undefined) {
      var input = document.getElementById('new-step-name');
      name = (input.value || '').trim();
      if (!name) return;
      wip = document.getElementById('new-step-wip').checked;
      input.value = '';
      matches = [];
    }
    var li = renderStepRow(name, !!wip, matches || []);
    document.getElementById('steps-list').appendChild(li);
    refreshBadges();
    FOCUSED_STEP = li;
    revealSuggestions();
    updateValidity();
  }

  function addMatchToFocusedStep(match) {
    if (FOCUSED_STEP && FOCUSED_STEP.parentElement) {
      var existing = JSON.parse(FOCUSED_STEP.dataset.matches || '[]');
      if (existing.indexOf(match) === -1) existing.push(match);
      FOCUSED_STEP.dataset.matches = JSON.stringify(existing);
      renderMatchPills(FOCUSED_STEP, existing);
      updateValidity();
      return;
    }
    addStep(match, true, [match]);
  }

  function renderChip(container, item) {
    var wrap = document.createElement('span');
    wrap.className = 'sugg-chip';
    var addMatch = document.createElement('button');
    addMatch.type = 'button';
    addMatch.textContent = '+ ' + item.name;
    addMatch.title = 'Bind to the selected step';
    addMatch.onclick = function () { addMatchToFocusedStep(item.name); };
    wrap.appendChild(addMatch);
    var asStep = document.createElement('button');
    asStep.type = 'button';
    asStep.className = 'sugg-chip__step';
    asStep.textContent = '⇢ step';
    asStep.title = 'Create a new step from this';
    asStep.onclick = function () { addStep(item.name, !!item.wip, [item.name]); };
    wrap.appendChild(asStep);
    container.appendChild(wrap);
  }

  function probeVocab() {
    var data = readForm();
    if (!sourceTargetComplete(data)) return;
    var status = document.getElementById('stages-status');
    status.textContent = 'Discovering…';
    status.className = 'probe-status';
    fetch('/api/internal/contracts/_probe-source-vocab', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'fetch' },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      var labelsDiv = document.getElementById('sugg-labels');
      var lifecycleDiv = document.getElementById('sugg-lifecycle');
      labelsDiv.innerHTML = '';
      lifecycleDiv.innerHTML = '';
      var warehouse = body.warehouse_stages || [];
      var labels = body.labels || [];
      var lifecycle = body.lifecycle_events || [];

      var whDiv = document.getElementById('sugg-warehouse');
      if (whDiv) {
        whDiv.innerHTML = '';
        warehouse.forEach(function (it) { renderChip(whDiv, it); });
        if (warehouse.length === 0) {
          whDiv.innerHTML = '<span class="sugg-empty">appears after this ' +
            'workflow imports data</span>';
        }
      }
      labels.forEach(function (it) { renderChip(labelsDiv, it); });
      lifecycle.forEach(function (it) { renderChip(lifecycleDiv, it); });
      if (labels.length === 0) {
        labelsDiv.innerHTML = '<span class="sugg-empty">' +
          (body.hint || 'none found for this source') + '</span>';
      }

      var total = warehouse.length + labels.length + lifecycle.length;
      status.textContent = '✓ ' + total + ' suggestion' + (total === 1 ? '' : 's');
      status.className = 'probe-status probe-status--ok';
    }).catch(function (err) {
      status.textContent = 'probe failed: ' + err;
      status.className = 'probe-status probe-status--fail';
    });
  }

  function showLifecycleChips() {
    var div = document.getElementById('sugg-lifecycle');
    if (div.children.length) return;
    var data = readForm();
    var gh = [
      {name:'PR opened',wip:false},{name:'Marked ready for review',wip:true},
      {name:'Changes requested',wip:true},{name:'Review approved',wip:true},
      {name:'PR merged',wip:false},{name:'PR closed without merge',wip:false},
      {name:'Issue opened',wip:false},{name:'Issue closed',wip:false},
    ];
    var jira = [
      {name:'Issue created',wip:false},{name:'Assigned',wip:true},
      {name:'Resolved',wip:false},{name:'Reopened',wip:true},{name:'Closed',wip:false},
    ];
    (data.source === 'jira' ? jira : gh).forEach(function (it) { renderChip(div, it); });
  }

  function buildYaml(data) {
    var lines = ["contract:"];
    lines.push("  name: " + data.name);
    if (data.label) lines.push("  label: " + JSON.stringify(data.label));
    lines.push("  source: " + data.source);
    if (data.source === "github" && data.repo) lines.push("  repo: " + data.repo);
    if (data.source === "jira") {
      if (data.jira_url) lines.push("  jira_url: " + data.jira_url);
      if (data.jira_project) lines.push("  jira_project: " + data.jira_project);
    }
    if (data.start) lines.push("  start: " + data.start);
    if (data.stop) lines.push("  stop: " + data.stop);
    var steps = readSteps();
    if (steps.length) {
      lines.push("  steps:");
      steps.forEach(function (s) {
        lines.push("    - name: " + JSON.stringify(s.name));
        lines.push("      wip: " + (s.wip ? "true" : "false"));
        if (s.matches && s.matches.length) {
          lines.push("      matches:");
          s.matches.forEach(function (m) { lines.push("        - " + JSON.stringify(m)); });
        }
      });
    }
    return lines.join("\n") + "\n";
  }

  function onSourceKindChange() {
    var data = readForm();
    document.getElementById('source-fieldset').dataset.source = data.source;
    document.getElementById('sugg-labels-label').textContent =
      data.source === 'jira' ? 'Statuses in the project' : 'Labels in the repo';
    document.getElementById('sugg-lifecycle').innerHTML = '';
    showLifecycleChips();
    updateValidity();
    if (sourceTargetComplete(data)) probeVocab();
  }

  function probeSource() {
    var data = readForm();
    if (!sourceTargetComplete(data)) return;
    var status = document.getElementById("probe-status");
    status.textContent = "Checking…";
    status.className = "probe-status";
    fetch("/api/internal/contracts/_probe-source", {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-Requested-With": "fetch" },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      if (body.ok) {
        status.textContent = "✓ " + (body.label || "source reachable");
        status.className = "probe-status probe-status--ok";
        probeVocab();
      } else {
        status.textContent = "✗ " + (body.error || "source not reachable");
        status.className = "probe-status probe-status--fail";
      }
    }).catch(function (err) {
      status.textContent = "check failed: " + err;
      status.className = "probe-status probe-status--fail";
    });
  }

  function hydrateFromExisting(id) {
    fetch("/api/internal/contracts/" + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (body) {
        var form = document.getElementById("wizard");
        var p = body.parsed || {};
        function setField(name, value) {
          var el = form.elements[name];
          if (el && value !== null && value !== undefined) el.value = value;
        }
        setField("name", p.name);
        setField("label", p.label);
        setField("source", p.source);
        setField("repo", p.repo);
        setField("jira_url", p.jira_url);
        setField("jira_project", p.jira_project);
        setField("start", p.start);
        setField("stop", p.stop);
        document.getElementById("source-fieldset").dataset.source = p.source || "github";
        document.getElementById('sugg-labels-label').textContent =
          p.source === 'jira' ? 'Statuses in the project' : 'Labels in the repo';
        if (Array.isArray(p.steps) && p.steps.length) {
          p.steps.forEach(function (s) { addStep(s.name, !!s.wip, s.matches || []); });
        } else if (p.states) {
          (p.states.backlog || []).forEach(function (n) { addStep(n, false, [n]); });
          (p.states.wip || []).forEach(function (n) { addStep(n, true, [n]); });
          (p.states.done || []).forEach(function (n) { addStep(n, false, [n]); });
        }
        if (WIZARD_MODE === "edit") form.elements.name.readOnly = true;
        showLifecycleChips();
        updateValidity();
        if (sourceTargetComplete(readForm())) probeVocab();
      });
  }

  function copyYaml() {
    fetch("/api/internal/contracts/" + encodeURIComponent(EDIT_ID) + "/yaml")
      .then(function (r) { return r.text(); })
      .then(function (text) {
        if (navigator.clipboard) navigator.clipboard.writeText(text);
        var btn = document.getElementById("copy-yaml-btn");
        var orig = btn.textContent;
        btn.textContent = "Copied ✓";
        setTimeout(function () { btn.textContent = orig; }, 1500);
      });
  }

  function confirmArchive() {
    var reason = window.prompt(
      "Archive '" + EDIT_ID + "'? Optional reason for the audit log:", ""
    );
    if (reason === null) return;
    fetch("/api/internal/contracts/" + encodeURIComponent(EDIT_ID) + "/archive", {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-Requested-With": "fetch" },
      body: JSON.stringify({ reason: reason || null }),
    }).then(function (r) {
      if (r.ok) { window.location.href = "/"; return; }
      r.json().then(function (body) {
        document.getElementById("wizard-errors").textContent =
          (body.detail && body.detail.message) || body.detail || "archive failed";
      });
    });
  }

  (function () {
    var d = new Date();
    d.setUTCDate(d.getUTCDate() - 30);
    document.getElementById("dry-run-since").value = d.toISOString().slice(0, 10);
  })();

  function dryRun() {
    var data = readForm();
    var status = document.getElementById("dry-run-status");
    status.textContent = "Running…";
    status.className = "probe-status";
    var since = document.getElementById("dry-run-since").value;
    var contractBody = {
      name: data.name || "tmp", source: data.source,
      repo: data.repo || null, jira_url: data.jira_url || null,
      jira_project: data.jira_project || null, steps: readSteps(),
    };
    fetch("/api/internal/contracts/_dry-run", {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-Requested-With": "fetch" },
      body: JSON.stringify({ contract: contractBody, since: since, items_cap: 200 }),
    }).then(function (r) { return r.json(); }).then(function (body) {
      renderDryRunResults(body);
      if (body.error) {
        status.textContent = "✗ " + body.error;
        status.className = "probe-status probe-status--fail";
      } else {
        status.textContent = "✓ " + body.items_fetched +
          " items (stopped by " + body.stopped_by + ")";
        status.className = "probe-status probe-status--ok";
      }
    });
  }

  function renderDryRunResults(body) {
    var container = document.getElementById("dry-run-results");
    container.innerHTML = "";
    if (!body.per_step) return;
    body.per_step.forEach(function (bucket) {
      var section = document.createElement("section");
      section.className = "dr-section";
      var head = document.createElement("div");
      head.className = "dr-head";
      var label = document.createElement("strong");
      if (bucket.step_name === "_unmatched") {
        label.textContent = "Unmatched"; label.style.color = "var(--t-700)";
      } else {
        label.textContent = bucket.step_name;
        label.style.color = bucket.wip ? "var(--p-700)" : "var(--fg)";
      }
      head.appendChild(label);
      var count = document.createElement("span");
      count.textContent = bucket.count + " item" + (bucket.count === 1 ? "" : "s");
      count.style.cssText = "color: var(--muted); font-size: 0.8125rem;";
      head.appendChild(count);
      if (bucket.step_name === "_unmatched" && bucket.count > 0) {
        var hint = document.createElement("em");
        hint.textContent = "your workflow may be missing a step";
        hint.style.cssText = "color: var(--muted); font-size: 0.75rem; margin-left: auto;";
        head.appendChild(hint);
      }
      section.appendChild(head);
      if (bucket.count > 0) {
        var list = document.createElement("ul");
        list.className = "dr-list";
        bucket.items.slice(0, 10).forEach(function (it) {
          var li = document.createElement("li");
          li.className = "dr-item";
          var stage = document.createElement("code");
          stage.className = "dr-stage";
          stage.textContent = it.current_stage;
          li.appendChild(stage);
          var title = document.createElement("span");
          title.textContent = it.title || it.id;
          title.style.flex = "1";
          li.appendChild(title);
          list.appendChild(li);
        });
        if (bucket.items.length > 10) {
          var more = document.createElement("li");
          more.className = "dr-item";
          more.textContent = "… and " + (bucket.items.length - 10) + " more";
          more.style.color = "var(--muted)";
          list.appendChild(more);
        }
        section.appendChild(list);
      }
      container.appendChild(section);
    });
  }

  // ---- init ----
  document.getElementById("f-name").addEventListener("input", updateValidity);
  onSourceKindChange();
  showLifecycleChips();
  if (WIZARD_MODE === "edit" && EDIT_ID) hydrateFromExisting(EDIT_ID);
  updateValidity();

  document.getElementById("wizard").addEventListener("submit", function (ev) {
    ev.preventDefault();
    var errs = document.getElementById("wizard-errors");
    errs.textContent = "";
    var data = readForm();
    fetch("/api/internal/contracts/" + encodeURIComponent(data.name), {
      method: "PUT",
      headers: { "Content-Type": "application/json", "X-Requested-With": "fetch" },
      body: JSON.stringify({ yaml: buildYaml(data) }),
    }).then(function (r) {
      if (r.ok) { window.location.href = "/workflows/" + encodeURIComponent(data.name); return; }
      return r.json().then(function (body) {
        var msg = (body.detail && body.detail.message) || body.detail || "save failed";
        errs.textContent = msg;
      });
    });
  });
</script>
{% endblock %}
