{% extends "_base.html.jinja" %}

{# Contract builder — an Alpine component. All client state (steps,
   matches, validity gating, suggestions) lives in `contractBuilder`;
   the markup is declarative (x-model / x-for / x-show / :disabled).
   htmx is intentionally NOT used here — this is a stateful client
   widget, not a server-rendered fragment swap. Server round-trips
   (probe, dry-run, save, archive) are plain fetch() calls. #}

{% block filter_bar %}{% endblock %}
{% block data_source_strip %}{% endblock %}

{% block content %}
<style>
  [x-cloak] { display: none !important; }
  .wizard { max-width: 42rem; margin: 1.5rem 0; }

  .wizard fieldset {
    border: 0.0625rem solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin: 0 0 1.25rem 0;
  }
  .wizard legend {
    font-family: var(--head-font);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-600);
    padding: 0 0.4rem;
  }

  /* A section that's locked until its preconditions are met. */
  .wizard fieldset[data-locked="true"] { opacity: 0.55; }
  .lock-note { font-size: 0.8125rem; color: var(--t-700); margin: 0 0 0.5rem 0; }

  /* Consistent field grouping + inputs. */
  .field { margin: 0 0 0.75rem 0; }
  .field:last-child { margin-bottom: 0; }
  .field-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.25rem;
  }
  .field-hint { font-weight: 400; color: var(--muted); font-size: 0.75rem; }
  .req { color: var(--t-700); margin-left: 0.15rem; }
  .field-input {
    display: block;
    width: 100%;
    padding: 0.45rem 0.55rem;
    border: 0.0625rem solid var(--border);
    border-radius: 0.3rem;
    font-size: 0.9375rem;
    font-family: var(--body-font);
    color: var(--fg);
    background: var(--white);
    box-sizing: border-box;
  }
  .field-input:focus {
    outline: none;
    border-color: var(--p-500);
    box-shadow: 0 0 0 0.125rem var(--p-100);
  }

  /* Buttons — one scale, three intents. Scoped under `.builder` so they
     beat the global `button.btn` in _base (which is element-qualified,
     0,1,1, and would otherwise override these class-only rules). */
  .builder .btn {
    font-family: var(--body-font);
    font-size: 0.875rem;
    padding: 0.4rem 0.9rem;
    border-radius: 0.3rem;
    border: 0.0625rem solid var(--border);
    background: var(--surface);
    color: var(--fg);
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  /* Plain (secondary) button hover: just nudge the border. */
  .builder .btn:hover:not([disabled]) {
    border-color: var(--muted); background: var(--white);
  }
  .builder .btn--primary {
    background: var(--p-500);
    color: var(--white);
    border-color: var(--p-500);
    font-weight: 600;
  }
  /* Primary hover darkens the fill (doesn't inherit the grey border). */
  .builder .btn--primary:hover:not([disabled]) {
    background: var(--p-600);
    border-color: var(--p-600);
  }
  .builder .btn--danger { color: var(--t-700); border-color: var(--t-700); }
  .builder .btn--danger:hover:not([disabled]) {
    background: var(--t-700);
    color: var(--white);
    border-color: var(--t-700);
  }
  .builder .btn--sm { font-size: 0.8rem; padding: 0.2rem 0.5rem; }
  .builder .btn[disabled] { opacity: 0.55; cursor: not-allowed; }
  /* A disabled primary reads as the (currently unavailable) CTA — a
     muted light-green — instead of ghosting lighter than Cancel. */
  .builder .btn--primary[disabled] {
    opacity: 1;
    background: var(--p-100);
    color: var(--muted);
    border-color: var(--p-100);
  }

  .probe-status { font-size: 0.8125rem; min-height: 1.1rem; }
  .probe-status--ok { color: var(--p-600); }
  .probe-status--fail { color: var(--t-700); }

  /* Steps editor. */
  .steps-list {
    list-style: none; padding: 0; margin: 0 0 0.75rem 0;
    border: 0.0625rem solid var(--border); border-radius: 0.3rem;
  }
  .steps-list:empty { display: none; }
  .step-row {
    padding: 0.5rem 0.6rem;
    border-bottom: 0.0625rem solid var(--border);
    background: var(--white);
  }
  .step-row__controls {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto auto auto auto;
    gap: 0.5rem; align-items: center;
  }
  /* Per-step suggestion area, shown only inside the active row. */
  .step-suggestions {
    margin-top: 0.6rem;
    padding-top: 0.6rem;
    border-top: 0.0625rem dashed var(--p-200);
  }
  .step-suggestions .binding-target { margin: 0 0 0.5rem 0; }
  .step-row:last-child { border-bottom: 0; }
  .step-row--active {
    background: var(--p-50);
    box-shadow: inset 0.1875rem 0 0 var(--p-500);
  }
  /* Brief pulse when a chip lands a match on this row. */
  .step-row--flash { animation: step-flash 0.7s ease-out; }
  @keyframes step-flash {
    0% { background: var(--p-200); }
    100% { background: var(--white); }
  }
  .step-badge {
    font-size: 0.625rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .step-center { display: flex; flex-direction: column; gap: 0.3rem; }
  .step-name-input {
    padding: 0.3rem 0.45rem;
    border: 0.0625rem solid var(--border); border-radius: 0.25rem;
    font-size: 0.9375rem; font-family: var(--body-font);
  }
  .step-matches {
    display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center;
    min-height: 1.1rem;
  }
  .match-pill {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.1rem 0.45rem; border-radius: 0.5rem;
    background: var(--p-50); color: var(--p-700);
    font-size: 0.7rem; border: 0.0625rem solid var(--p-200);
  }
  .match-pill button {
    background: transparent; border: 0; cursor: pointer;
    padding: 0; font-size: 0.75rem; color: var(--p-700); line-height: 1;
  }
  .step-by-name { font-size: 0.7rem; color: var(--muted); font-style: italic; }
  .step-wip-label {
    display: flex; align-items: center; gap: 0.3rem; font-size: 0.8125rem;
  }

  /* The "add a step" control is framed + labelled so it reads as a
     create affordance, not as another committed step row. */
  .add-step-panel {
    margin-top: 0.85rem;
    padding: 0.6rem 0.7rem;
    border: 0.0625rem dashed var(--border);
    border-radius: 0.4rem;
    background: var(--surface);
  }
  .add-step-panel__title {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); margin-bottom: 0.45rem;
  }
  .add-step-row {
    display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;
  }
  .add-step-row .field-input { flex: 1; min-width: 12rem; width: auto; }

  /* Suggestion chips. */
  .sugg-group { margin-bottom: 0.6rem; }
  .sugg-group:last-child { margin-bottom: 0; }
  .sugg-group-title {
    font-size: 0.7rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--muted);
  }
  .sugg-chips {
    display: flex; flex-wrap: wrap; gap: 0.35rem;
    margin-top: 0.3rem; min-height: 1.4rem;
  }
  .sugg-chip {
    border: 0.0625rem solid var(--border); border-radius: 0.6rem;
    background: var(--surface); cursor: pointer;
    font-size: 0.75rem; padding: 0.2rem 0.6rem;
    font-family: var(--body-font); color: var(--fg);
  }
  .sugg-chip:hover { border-color: var(--p-500); background: var(--p-50); }
  .sugg-empty { font-size: 0.75rem; color: var(--muted); font-style: italic; }

  .wizard-actions {
    display: flex; gap: 0.6rem; align-items: center;
    margin: 0 0 0.5rem 0; flex-wrap: wrap;
  }
  .wizard-hint { font-size: 0.8125rem; color: var(--muted); }
  .wizard-errors {
    color: var(--t-700); font-size: 0.875rem;
    margin: 0.25rem 0 0 0; min-height: 1.2rem;
  }

  .saved-panel {
    max-width: 42rem; margin: 1.5rem 0;
    border: 0.0625rem solid var(--p-200); border-radius: 0.5rem;
    background: var(--p-50); padding: 1.25rem;
  }
  .saved-panel__msg { margin: 0 0 0.9rem 0; color: var(--fg); }

  /* Dry-run results. */
  .dr-section {
    margin: 0.6rem 0; border: 0.0625rem solid var(--border);
    border-radius: 0.3rem;
  }
  .dr-head {
    display: flex; align-items: baseline; gap: 0.5rem;
    padding: 0.4rem 0.6rem; background: var(--surface);
    border-bottom: 0.0625rem solid var(--border);
  }
  .dr-list { list-style: none; padding: 0; margin: 0; }
  .dr-item {
    padding: 0.3rem 0.6rem; border-bottom: 0.0625rem solid var(--border);
    display: flex; gap: 0.6rem; font-size: 0.8125rem;
  }
  .dr-item:last-child { border-bottom: 0; }
  .dr-stage {
    color: var(--muted); min-width: 9rem;
    font-family: var(--mono-font); font-size: 0.75rem;
  }
</style>

<div class="builder"
     x-data='contractBuilder({mode: {{ wizard_mode | tojson }}, editId: {{ edit_id | tojson }}})'
     x-cloak>
  {% if wizard_mode == "edit" %}
  <h1>Edit workflow: {{ edit_id }}</h1>
  {% else %}
  <h1>New workflow</h1>
  <p class="wizard-hint">
    Fields marked <span class="req">*</span> are required. Define the
    source, then build the workflow's steps.
  </p>
  {% endif %}

  <form class="wizard" id="wizard" x-show="!saved" @submit.prevent="save()">
    <fieldset>
      <legend>Identity</legend>
      <div class="field">
        <label class="field-label" for="f-name">
          Routing ID <span class="req" aria-hidden="true">*</span>
          <span class="field-hint">— lowercase, dashes only; can't change later</span>
        </label>
        <input class="field-input" id="f-name" name="name" type="text"
               x-model="name" :readonly="mode === 'edit'"
               required aria-required="true" pattern="[a-z0-9-]+"
               placeholder="astral-uv-week">
      </div>
      <div class="field">
        <label class="field-label" for="f-label">
          Display label
          <span class="field-hint">— optional; shown in the dashboard</span>
        </label>
        <input class="field-input" id="f-label" name="label" type="text"
               x-model="label" placeholder="Astral uv weekly">
      </div>
    </fieldset>

    <fieldset>
      <legend>Source</legend>
      <div class="field">
        <label class="field-label" for="f-source">
          Source kind <span class="req" aria-hidden="true">*</span>
        </label>
        <select class="field-input" id="f-source" name="source"
                x-model="source" aria-required="true"
                @change="onSourceKindChange()">
          <option value="github">GitHub</option>
          <option value="jira">Jira</option>
        </select>
      </div>

      <div x-show="source === 'github'">
        <div class="field">
          <label class="field-label" for="f-repo">
            Repository <span class="req" aria-hidden="true">*</span>
            <span class="field-hint">— owner/name</span>
          </label>
          <input class="field-input" id="f-repo" name="repo" type="text"
                 x-model="repo" aria-required="true"
                 placeholder="astral-sh/uv"
                 @input="onSourceChanged()" @blur="probeSource()">
        </div>
      </div>

      <div x-show="source === 'jira'">
        <div class="field">
          <label class="field-label" for="f-jira-url">
            Jira base URL <span class="req" aria-hidden="true">*</span>
          </label>
          <input class="field-input" id="f-jira-url" name="jira_url" type="text"
                 x-model="jiraUrl" aria-required="true"
                 placeholder="https://issues.apache.org/jira"
                 @input="onSourceChanged()" @blur="probeSource()">
        </div>
        <div class="field">
          <label class="field-label" for="f-jira-project">
            Project key <span class="req" aria-hidden="true">*</span>
          </label>
          <input class="field-input" id="f-jira-project" name="jira_project" type="text"
                 x-model="jiraProject" aria-required="true"
                 placeholder="CASSANDRA"
                 @input="onSourceChanged()" @blur="probeSource()">
        </div>
      </div>

      <div class="probe-status" id="probe-status"
           :class="probeClass" x-text="probeStatus"></div>
    </fieldset>

    <fieldset id="steps-fieldset">
      <legend>Steps</legend>
      <p class="lock-note" x-show="!sourceVerified">
        Enter a source above that we can reach — steps map to that
        source's data, so the source has to resolve first.
      </p>
      <div x-show="sourceVerified">
      <p class="field-hint" style="margin: 0 0 0.75rem 0;">
        A step is a stage in your workflow. By default a step captures
        items whose source stage matches the step's name; add explicit
        matches (chips below) to capture other labels / statuses /
        events. Toggle WIP per step.
      </p>

      <ol class="steps-list" id="steps-list">
        <template x-for="(step, idx) in steps" :key="idx">
          <li class="step-row"
              :class="{ 'step-row--active': idx === activeIdx, 'step-row--flash': idx === flashIdx }"
              @click="activeIdx = idx">
            <div class="step-row__controls">
              <span class="step-badge"
                    :style="`color: ${badge(idx).color}`"
                    x-text="badge(idx).text"></span>
              <div class="step-center">
                <input class="step-name-input" type="text" x-model="step.name"
                       placeholder="Name this step (e.g. In Progress)"
                       @focus="activeIdx = idx"
                       @keydown.enter.prevent="addStep()">
                <div class="step-matches">
                  <template x-if="step.matches.length === 0">
                    <span class="step-by-name"
                          x-text="`captures source stage “${step.name || '(unnamed)'}”`"></span>
                  </template>
                  <template x-for="(m, mi) in step.matches" :key="mi">
                    <span class="match-pill" :title="m.kind">
                      <span x-text="m.label || m.value"></span>
                      <button type="button" title="Remove this match"
                              @click.stop="step.matches.splice(mi, 1)">×</button>
                    </span>
                  </template>
                </div>
              </div>
              <label class="step-wip-label">
                <input type="checkbox" x-model="step.wip"> WIP
              </label>
              <button type="button" class="btn btn--sm" title="Move up"
                      @click.stop="moveStep(idx, -1)">↑</button>
              <button type="button" class="btn btn--sm" title="Move down"
                      @click.stop="moveStep(idx, 1)">↓</button>
              <button type="button" class="btn btn--sm" title="Remove step"
                      @click.stop="removeStep(idx)">×</button>
            </div>

            {# Suggestion chips live inside the step they bind to. Only
               the selected (green) row renders them, so a chip can only
               ever land on the step the user is looking at. #}
            <template x-if="idx === activeIdx">
              <div class="step-suggestions" id="suggestions-panel">
                <p class="field-hint binding-target">
                  Add labels &amp; lifecycle events to this step:
                </p>
                {% if wizard_mode == "edit" %}
                <div class="sugg-group">
                  <div class="sugg-group-title">Stages seen in imported data</div>
                  <div id="sugg-warehouse" class="sugg-chips">
                    <template x-for="item in vocab.warehouse" :key="item.name">
                      <button type="button" class="sugg-chip"
                              @click.stop="addMatch({kind: 'stage', value: item.name, label: item.name})"
                              x-text="`+ ${item.name}`"></button>
                    </template>
                    <span class="sugg-empty" x-show="vocab.warehouse.length === 0">appears after this workflow imports data</span>
                  </div>
                </div>
                {% endif %}
                <div class="sugg-group">
                  <div class="sugg-group-title" x-text="labelsTitle"></div>
                  <div id="sugg-labels" class="sugg-chips">
                    <template x-for="item in vocab.labels" :key="item.name">
                      <button type="button" class="sugg-chip"
                              @click.stop="addMatch({kind: labelKind, value: item.name, label: item.name})"
                              x-text="`+ ${item.name}`"></button>
                    </template>
                    <span class="sugg-empty" x-show="vocab.labels.length === 0"
                          x-text="vocabHint || 'none found for this source'"></span>
                  </div>
                </div>
                <div class="sugg-group">
                  <div class="sugg-group-title">Lifecycle events</div>
                  <div id="sugg-lifecycle" class="sugg-chips">
                    <template x-for="item in lifecycleChips" :key="item.code">
                      <button type="button" class="sugg-chip"
                              @click.stop="addMatch({kind: 'event', value: item.code, label: item.name})"
                              x-text="`+ ${item.name}`"></button>
                    </template>
                  </div>
                </div>
              </div>
            </template>
          </li>
        </template>
      </ol>

      <div class="add-step-panel">
        <div class="add-step-panel__title">Add a step</div>
        <div class="add-step-row">
          <button type="button" class="btn" id="add-step"
                  :disabled="!canAddStep" @click="addStep()">+ Add step</button>
          <span class="field-hint" x-show="steps.length === 0">
            Adds a row below — name it and tag its labels &amp; events right there.
          </span>
          <span class="field-hint" x-show="steps.length > 0 && !canAddStep">
            Name the current step before adding another.
          </span>
          <span class="probe-status" id="stages-status"
                :class="vocabClass" x-text="vocabStatus"></span>
        </div>
      </div>
      </div>
    </fieldset>

    <fieldset id="dry-run-panel" :data-locked="!canDryRun">
      <legend>Preview against live source</legend>
      <p class="lock-note" x-show="!canDryRun">
        Add at least one step (and a valid source) to preview.
      </p>
      <p class="field-hint" style="margin: 0 0 0.75rem 0;">
        Test the workflow against real items — up to 200 (or 30 days).
        Nothing is written to the warehouse.
      </p>
      <div class="add-step-row" style="align-items: end;">
        <div class="field" style="margin: 0;">
          <label class="field-label" for="dry-run-since">From date</label>
          <input class="field-input" id="dry-run-since" type="date"
                 x-model="drySince" style="width: auto; flex: none; min-width: 0;">
        </div>
        <button type="button" class="btn" id="dry-run-btn"
                :disabled="!canDryRun" @click="dryRun()">Dry run</button>
        <span class="probe-status" id="dry-run-status"
              :class="dryClass" x-text="dryStatus"></span>
      </div>
      <div id="dry-run-results">
        <template x-for="bucket in (dryResults || [])" :key="bucket.step_name">
          <section class="dr-section">
            <div class="dr-head">
              <strong :style="bucket.step_name === '_unmatched' ? 'color: var(--t-700)' : (bucket.wip ? 'color: var(--p-700)' : '')"
                      x-text="bucket.step_name === '_unmatched' ? 'Unmatched' : bucket.step_name"></strong>
              <span style="color: var(--muted); font-size: 0.8125rem;"
                    x-text="`${bucket.count} item${bucket.count === 1 ? '' : 's'}`"></span>
              <em x-show="bucket.step_name === '_unmatched' && bucket.count > 0"
                  style="color: var(--muted); font-size: 0.75rem; margin-left: auto;">your workflow may be missing a step</em>
            </div>
            <ul class="dr-list" x-show="bucket.count > 0">
              <template x-for="it in bucket.items.slice(0, 10)" :key="it.id">
                <li class="dr-item">
                  <code class="dr-stage" x-text="it.current_stage"></code>
                  <span style="flex: 1;" x-text="it.title || it.id"></span>
                </li>
              </template>
              <li class="dr-item" x-show="bucket.items.length > 10"
                  style="color: var(--muted);"
                  x-text="`… and ${bucket.items.length - 10} more`"></li>
            </ul>
          </section>
        </template>
      </div>
    </fieldset>

    <div class="wizard-actions">
      <button type="submit" class="btn btn--primary" id="save-btn" :disabled="!canSave">
        {% if wizard_mode == "edit" %}Save{% else %}Save &amp; open{% endif %}
      </button>
      <a href="/" class="btn">Cancel</a>
      {% if wizard_mode == "edit" %}
      <a id="download-yaml-btn" class="btn" style="margin-left: auto;"
         href="/api/internal/contracts/{{ edit_id }}/yaml">Download YAML</a>
      <button type="button" class="btn" id="copy-yaml-btn" @click="copyYaml()"
              x-text="copied ? 'Copied ✓' : 'Copy YAML'">Copy YAML</button>
      <button type="button" class="btn btn--danger" id="archive-btn"
              @click="archive()">Archive</button>
      {% endif %}
    </div>
    <p class="wizard-hint" x-text="blocker"></p>
    <p class="wizard-errors" x-text="errors"></p>
  </form>

  {# Post-save: the contract is defined but the warehouse is empty. Send
     the user to the Data Source page to fetch data (its backfill picks
     the date range), rather than dropping them on an empty dashboard. #}
  <div class="saved-panel" x-show="saved" x-cloak>
    <p class="saved-panel__msg">
      ✓ Workflow “<span x-text="savedName"></span>” saved.
      No data has been imported yet.
    </p>
    <div class="wizard-actions">
      <a class="btn btn--primary"
         :href="`/workflows/${encodeURIComponent(savedName)}/data-source`">
        Fetch data →
      </a>
      <a class="btn" :href="`/workflows/${encodeURIComponent(savedName)}`">
        Open dashboard
      </a>
    </div>
  </div>
</div>

<script>
  // Lifecycle chips: `name` is the friendly label shown on the chip;
  // `code` is the stable matcher code stored (signals.event_codes_for).
  const GH_LIFECYCLE = [
    {name: 'PR opened', code: 'pr-opened', wip: false},
    {name: 'Ready for review', code: 'pr-ready', wip: true},
    {name: 'Changes requested', code: 'changes-requested', wip: true},
    {name: 'Review approved', code: 'approved', wip: true},
    {name: 'PR merged', code: 'pr-merged', wip: false},
    {name: 'Issue opened', code: 'issue-opened', wip: false},
    {name: 'Issue closed', code: 'issue-closed', wip: false},
  ];
  const JIRA_LIFECYCLE = [
    {name: 'Issue created', code: 'created', wip: false},
    {name: 'Status changed', code: 'status-changed', wip: true},
    {name: 'Resolved', code: 'resolved', wip: false},
  ];
  // Map an event code back to its friendly label (for hydrate).
  const EVENT_LABELS = Object.fromEntries(
    [...GH_LIFECYCLE, ...JIRA_LIFECYCLE].map((e) => [e.code, e.name])
  );
  const HEADERS = {
    'Content-Type': 'application/json', 'X-Requested-With': 'fetch',
  };

  document.addEventListener('alpine:init', () => {
    Alpine.data('contractBuilder', (cfg) => ({
      mode: cfg.mode,
      editId: cfg.editId,
      // form state
      name: '', label: '', source: 'github',
      repo: '', jiraUrl: '', jiraProject: '',
      steps: [],                 // [{name, wip, matches: []}]
      saved: false, savedName: '',   // post-save "fetch data" panel
      activeIdx: null,
      flashIdx: null,            // step row to pulse after a chip click
      // probe state
      sourceVerified: false,     // source actually resolved (not just well-formed)
      probeStatus: '', probeClass: 'probe-status',
      vocab: { labels: [], warehouse: [] },
      vocabStatus: '', vocabClass: 'probe-status', vocabHint: '',
      // dry-run
      drySince: '', dryStatus: '', dryClass: 'probe-status', dryResults: null,
      // misc
      errors: '', copied: false,

      // ---- computed ----
      get sourceComplete() {
        if (this.source === 'github') return this.repo.includes('/');
        if (this.source === 'jira') return !!(this.jiraUrl && this.jiraProject);
        return false;
      },
      get nameOk() { return /^[a-z0-9-]+$/.test(this.name); },
      // A new (blank) step row can be added once the source resolves; but
      // don't stack blank rows — the last step must be named first.
      get canAddStep() {
        if (!this.sourceVerified) return false;
        if (this.steps.length === 0) return true;
        return this.steps[this.steps.length - 1].name.trim() !== '';
      },
      get canDryRun() { return this.sourceVerified && this.steps.length > 0; },
      get canSave() { return this.nameOk && this.sourceVerified && this.steps.length > 0; },
      get blocker() {
        const missing = [];
        if (!this.nameOk) missing.push('a routing id (lowercase, dashes)');
        if (!this.sourceVerified) missing.push(
          this.source === 'jira'
            ? 'a Jira URL + project key we can reach'
            : 'a repository (owner/name) we can reach');
        if (this.steps.length === 0) missing.push('at least one step');
        return missing.length ? 'To save, add: ' + missing.join(', ') + '.' : '';
      },
      get lifecycleChips() {
        return this.source === 'jira' ? JIRA_LIFECYCLE : GH_LIFECYCLE;
      },
      get labelsTitle() {
        return this.source === 'jira' ? 'Statuses in the project' : 'Labels in the repo';
      },
      get labelKind() {
        return this.source === 'jira' ? 'status' : 'label';
      },

      // ---- lifecycle ----
      init() {
        const d = new Date();
        d.setUTCDate(d.getUTCDate() - 30);
        this.drySince = d.toISOString().slice(0, 10);
        if (this.mode === 'edit' && this.editId) this.hydrate();
      },

      badge(idx) {
        let seenWip = false;
        for (let i = 0; i <= idx; i++) if (this.steps[i].wip) seenWip = true;
        if (this.steps[idx].wip) return { text: 'WIP', color: 'var(--p-600)' };
        return seenWip
          ? { text: 'DONE', color: 'var(--muted)' }
          : { text: 'READY', color: 'var(--muted)' };
      },

      // ---- steps ----
      // "+ Add step" appends a fresh, blank row and makes it active so the
      // user names it and tags its labels / events inline. Everything about
      // a step happens in the step's own row.
      addStep() {
        if (!this.canAddStep) return;
        this.steps.push({ name: '', wip: true, matches: [] });
        this.activeIdx = this.steps.length - 1;
        this.$nextTick(() => {
          const inputs = document.querySelectorAll('#steps-list .step-name-input');
          const el = inputs[this.activeIdx];
          if (el) { el.focus(); el.scrollIntoView({ block: 'nearest' }); }
        });
      },
      removeStep(idx) {
        this.steps.splice(idx, 1);
        if (this.activeIdx === idx) {
          this.activeIdx = this.steps.length ? this.steps.length - 1 : null;
        } else if (this.activeIdx > idx) {
          this.activeIdx -= 1;
        }
      },
      moveStep(idx, dir) {
        const j = idx + dir;
        if (j < 0 || j >= this.steps.length) return;
        const [row] = this.steps.splice(idx, 1);
        this.steps.splice(j, 0, row);
        this.activeIdx = j;
      },
      // Chips live inside the active step, so they only ever bind to it.
      // `matcher` is a typed {kind, value, label}.
      addMatch(matcher) {
        const idx = this.activeIdx;
        if (idx === null || !this.steps[idx]) return;
        const m = this.steps[idx].matches;
        const dup = m.some(
          (x) => x.kind === matcher.kind && x.value === matcher.value
        );
        if (!dup) m.push(matcher);
        this.flashStep(idx);
      },
      flashStep(idx) {
        this.flashIdx = idx;
        this.$nextTick(() => {
          const rows = document.querySelectorAll('#steps-list .step-row');
          if (rows[idx]) rows[idx].scrollIntoView({ block: 'nearest' });
        });
        setTimeout(() => { if (this.flashIdx === idx) this.flashIdx = null; }, 700);
      },

      // ---- source probing ----
      // Editing any source field invalidates a prior verification — the
      // steps UI re-locks until the new source resolves.
      onSourceChanged() {
        this.sourceVerified = false;
        this.probeStatus = ''; this.probeClass = 'probe-status';
      },
      async onSourceKindChange() {
        this.vocab = { labels: [], warehouse: [] };
        this.onSourceChanged();
        if (this.sourceComplete) this.probeSource();
      },
      async probeSource() {
        if (!this.sourceComplete) return;
        this.probeStatus = 'Checking…'; this.probeClass = 'probe-status';
        try {
          const r = await fetch('/api/internal/contracts/_probe-source', {
            method: 'POST', headers: HEADERS, body: JSON.stringify(this._target()),
          });
          const body = await r.json();
          this.sourceVerified = !!body.ok;
          if (body.ok) {
            this.probeStatus = '✓ ' + (body.label || 'source reachable');
            this.probeClass = 'probe-status probe-status--ok';
            this.probeVocab();
          } else {
            this.probeStatus = '✗ ' + (body.error || 'source not reachable');
            this.probeClass = 'probe-status probe-status--fail';
          }
        } catch (e) {
          this.sourceVerified = false;
          this.probeStatus = 'check failed: ' + e;
          this.probeClass = 'probe-status probe-status--fail';
        }
      },
      async probeVocab() {
        if (!this.sourceComplete) return;
        this.vocabStatus = 'Discovering…'; this.vocabClass = 'probe-status';
        try {
          const r = await fetch('/api/internal/contracts/_probe-source-vocab', {
            method: 'POST', headers: HEADERS, body: JSON.stringify(this._target()),
          });
          const body = await r.json();
          this.vocab.labels = body.labels || [];
          this.vocab.warehouse = body.warehouse_stages || [];
          this.vocabHint = body.hint || '';
          const total = this.vocab.labels.length + this.vocab.warehouse.length +
                        this.lifecycleChips.length;
          this.vocabStatus = `✓ ${total} suggestion${total === 1 ? '' : 's'}`;
          this.vocabClass = 'probe-status probe-status--ok';
        } catch (e) {
          this.vocabStatus = 'probe failed: ' + e;
          this.vocabClass = 'probe-status probe-status--fail';
        }
      },

      // ---- save / dry-run / archive ----
      _target() {
        return {
          source: this.source, repo: this.repo || null,
          jira_url: this.jiraUrl || null, jira_project: this.jiraProject || null,
        };
      },
      _contractBody() {
        return { name: this.name || 'tmp', ...this._target(), steps: this.steps };
      },
      buildYaml() {
        const q = (s) => JSON.stringify(s);
        const lines = ['contract:', `  name: ${this.name}`];
        if (this.label) lines.push(`  label: ${q(this.label)}`);
        lines.push(`  source: ${this.source}`);
        if (this.source === 'github' && this.repo) lines.push(`  repo: ${this.repo}`);
        if (this.source === 'jira') {
          if (this.jiraUrl) lines.push(`  jira_url: ${this.jiraUrl}`);
          if (this.jiraProject) lines.push(`  jira_project: ${this.jiraProject}`);
        }
        if (this.steps.length) {
          lines.push('  steps:');
          for (const s of this.steps) {
            lines.push(`    - name: ${q(s.name)}`);
            lines.push(`      wip: ${s.wip ? 'true' : 'false'}`);
            if (s.matches.length) {
              lines.push('      matches:');
              for (const m of s.matches) {
                lines.push(`        - ${m.kind}: ${q(m.value)}`);
              }
            }
          }
        }
        return lines.join('\n') + '\n';
      },
      async save() {
        this.errors = '';
        const r = await fetch('/api/internal/contracts/' + encodeURIComponent(this.name), {
          method: 'PUT', headers: HEADERS, body: JSON.stringify({ yaml: this.buildYaml() }),
        });
        if (r.ok) { this.savedName = this.name; this.saved = true; return; }
        const body = await r.json();
        this.errors = (body.detail && body.detail.message) || body.detail || 'save failed';
      },
      async dryRun() {
        this.dryStatus = 'Running…'; this.dryClass = 'probe-status';
        const r = await fetch('/api/internal/contracts/_dry-run', {
          method: 'POST', headers: HEADERS,
          body: JSON.stringify({ contract: this._contractBody(), since: this.drySince, items_cap: 200 }),
        });
        const body = await r.json();
        this.dryResults = body.per_step || [];
        if (body.error) {
          this.dryStatus = '✗ ' + body.error;
          this.dryClass = 'probe-status probe-status--fail';
        } else {
          this.dryStatus = `✓ ${body.items_fetched} items (stopped by ${body.stopped_by})`;
          this.dryClass = 'probe-status probe-status--ok';
        }
      },
      async copyYaml() {
        const r = await fetch('/api/internal/contracts/' + encodeURIComponent(this.editId) + '/yaml');
        const text = await r.text();
        if (navigator.clipboard) await navigator.clipboard.writeText(text);
        this.copied = true;
        setTimeout(() => { this.copied = false; }, 1500);
      },
      async archive() {
        const reason = window.prompt(
          `Archive '${this.editId}'? Optional reason for the audit log:`, '');
        if (reason === null) return;
        const r = await fetch('/api/internal/contracts/' + encodeURIComponent(this.editId) + '/archive', {
          method: 'POST', headers: HEADERS, body: JSON.stringify({ reason: reason || null }),
        });
        if (r.ok) { window.location.href = '/'; return; }
        const body = await r.json();
        this.errors = (body.detail && body.detail.message) || body.detail || 'archive failed';
      },

      // ---- edit-mode hydration ----
      async hydrate() {
        const r = await fetch('/api/internal/contracts/' + encodeURIComponent(this.editId));
        const body = await r.json();
        const p = body.parsed || {};
        this.name = p.name || '';
        this.label = p.label || '';
        this.source = p.source || 'github';
        this.repo = p.repo || '';
        this.jiraUrl = p.jira_url || '';
        this.jiraProject = p.jira_project || '';
        if (Array.isArray(p.steps) && p.steps.length) {
          this.steps = p.steps.map((s) => ({
            name: s.name, wip: !!s.wip,
            matches: (s.matches || []).map((m) => ({
              kind: m.kind, value: m.value,
              // Event codes show their friendly label; others show value.
              label: m.kind === 'event'
                ? (EVENT_LABELS[m.value] || m.value) : m.value,
            })),
          }));
        } else if (p.states) {
          const add = (names, wip) => (names || []).forEach(
            (n) => this.steps.push({
              name: n, wip,
              matches: [{ kind: 'stage', value: n, label: n }],
            }));
          add(p.states.backlog, false);
          add(p.states.wip, true);
          add(p.states.done, false);
        }
        // The contract was saved with a working source; trust it so the
        // steps stay editable even if the network probe is flaky right now.
        this.sourceVerified = this.sourceComplete;
        if (this.steps.length) this.activeIdx = 0;
        if (this.sourceComplete) this.probeVocab();
      },
    }));
  });
</script>
{% endblock %}
