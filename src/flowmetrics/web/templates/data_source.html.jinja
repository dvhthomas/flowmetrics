{% extends "_base.html.jinja" %}

{# The Data Source page is about the warehouse itself, not a
   metric window — no Period filter bar. #}
{% block filter_bar %}{% endblock %}
{# This IS the data-source page — the header strip would be a
   redundant pointer back to itself. #}
{% block data_source_strip %}{% endblock %}

{% block content %}
  <style>
    /* One consistent vertical rhythm; everything shares the container's
       left edge. */
    .ds-section { margin: 2rem 0; }
    .ds-section > h2 { margin: 0 0 0.25rem 0; }
    .ds-section > .ds-hint { margin: 0 0 1rem 0; }
    .ds-coverage-chart { width: 100%; min-height: 11rem; }
    .ds-hint { font-size: 0.875rem; color: var(--muted); }

    /* Backfill control: labelled fields + button, all the SAME height,
       bottom-aligned on one baseline — no choppy vertical drift. */
    .ds-backfill {
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      background: var(--surface);
      padding: 1rem 1.1rem;
    }
    .ds-backfill-form {
      display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;
      margin: 0;
    }
    .ds-field { display: flex; flex-direction: column; gap: 0.3rem; }
    .ds-field-label {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--muted);
    }
    .ds-control, .ds-static {
      height: 2.25rem; box-sizing: border-box;
      display: inline-flex; align-items: center;
      font-family: inherit; font-size: 0.875rem;
    }
    .ds-control {
      padding: 0 0.55rem;
      border: 0.0625rem solid var(--border); border-radius: 0.3rem;
      background: var(--white); color: var(--fg);
    }
    .ds-static { color: var(--muted); }
    .ds-static strong { color: var(--fg); font-weight: 600; }
    .ds-backfill-form .btn { height: 2.25rem; }
    .backfill-progress {
      margin-top: 1rem; padding: 0.5rem 0.75rem;
      border-radius: 0.3rem; font-size: 0.875rem;
      display: flex; gap: 0.6rem; align-items: center;
    }
    .backfill-progress--running,
    .backfill-progress--failed {
      background: var(--surface);
      border-left: 0.25rem solid var(--p-500);
    }
    .backfill-progress--done {
      background: var(--p-50);
      border-left: 0.25rem solid var(--p-500);
    }
    .backfill-spinner {
      flex: none; width: 0.85rem; height: 0.85rem;
      border: 0.15rem solid var(--border);
      border-top-color: var(--p-500); border-radius: 50%;
      animation: ds-spin 0.8s linear infinite;
    }
    @keyframes ds-spin { to { transform: rotate(360deg); } }
    .backfill-dismiss {
      margin-left: auto;
      background: transparent;
      border: none;
      cursor: pointer;
      font-size: 1.1rem;
      line-height: 1;
      color: var(--muted);
      padding: 0.2rem 0.4rem;
    }
    .backfill-dismiss:hover { color: var(--fg); }
    .ds-headline {
      margin: 0.8rem 0 0.4rem 0;
      font-size: 0.875rem;
      color: var(--fg);
    }
  </style>

  <p class="ds-headline">{{ coverage.headline }}</p>

  <section class="ds-section">
    <div id="ds-coverage" class="ds-coverage-chart"></div>
    {% if coverage.days %}
    <script>
      (function () {
        const spec = {{ vega_spec(coverage) | safe }};
        vegaEmbed("#ds-coverage", window.applyTheme(spec), {
          actions: false, renderer: "svg"
        }).catch(function (err) {
          document.getElementById("ds-coverage").innerText =
            "Chart render failed: " + err;
        });
      })();
    </script>
    {% endif %}
  </section>

  <section class="ds-section">
    <h2>Backfill</h2>
    <p class="ds-hint">
      Import history into the warehouse — pick a window and run it.
      (Data is also imported automatically every day.)
    </p>
    <div class="ds-backfill">
      <form class="ds-backfill-form"
            hx-post="/api/internal/backfill"
            hx-target="#backfill-progress"
            hx-swap="innerHTML">
        <input type="hidden" name="workflow" value="{{ contract.name }}">
        {# since / until are derived (read-only) from window + anchor. #}
        <input type="hidden" name="since" id="ds-since">
        <input type="hidden" name="until" id="ds-until">
        <label class="ds-field">
          <span class="ds-field-label">Window</span>
          <select id="ds-days" class="ds-control" onchange="dsRecalc()">
            <option value="1">1 day</option>
            <option value="7">7 days</option>
            <option value="30" selected>30 days</option>
            <option value="60">60 days</option>
            <option value="90">90 days</option>
          </select>
        </label>
        <label class="ds-field">
          <span class="ds-field-label">Up to &amp; including</span>
          <input type="date" id="ds-anchor" class="ds-control"
                 max="{{ today }}" value="{{ today }}"
                 onchange="dsRecalc()">
        </label>
        <div class="ds-field">
          <span class="ds-field-label">Will fetch</span>
          <span class="ds-static" id="ds-range"></span>
        </div>
        <button type="submit" class="btn btn--primary">Backfill</button>
      </form>
    </div>
    <div id="backfill-progress">
      {% include "_partials/backfill_progress.html.jinja" %}
    </div>
  </section>

  <a class="back-link"
     href="{{ ('/workflows/' ~ contract.name ~ '/') | keep_filters }}">← Back to dashboard</a>

  <script>
    // The window length + anchor date resolve to an explicit
    // [since, until] range — shown read-only and submitted as the
    // hidden inputs. "N days up to and including the anchor."
    function dsRecalc() {
      var days = parseInt(document.getElementById("ds-days").value, 10);
      var anchor = document.getElementById("ds-anchor").value;
      if (!anchor) return;
      var until = new Date(anchor + "T00:00:00Z");
      var since = new Date(until);
      since.setUTCDate(since.getUTCDate() - (days - 1));
      var sinceStr = since.toISOString().slice(0, 10);
      document.getElementById("ds-since").value = sinceStr;
      document.getElementById("ds-until").value = anchor;
      document.getElementById("ds-range").innerHTML =
        "<strong>" + sinceStr + "</strong> → <strong>" + anchor + "</strong>";
    }
    dsRecalc();
  </script>
{% endblock %}
