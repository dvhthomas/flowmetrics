{% extends "_base.html.jinja" %}

{% block filter_bar %}{# no filter bar on the home page — no workflow context #}{% endblock %}

{% block content %}
  <section class="home-intro">
    <h1>Workflows</h1>
    <p class="home-subtitle">Pick a workflow to view its flow metrics.</p>
    <p>
      <a class="filter-apply" href="/admin/contracts/new">+ New workflow</a>
    </p>
    {% if archived_count and archived_count > 0 %}
    <p style="font-size: 0.8125rem;">
      <a href="/admin/contracts/archive" style="color: var(--muted);">View archived ({{ archived_count }})</a>
    </p>
    {% endif %}
  </section>

  {% if workflows %}
    <ul class="home-workflow-list">
      {% for w in workflows %}
        <li class="home-workflow-item">
          <a class="home-workflow-link" href="/workflows/{{ w.name }}">
            <span class="home-workflow-label">
              <span class="home-workflow-name">{{ w.label }}</span>
              {% if w.label != w.name %}
                <span class="home-workflow-id">{{ w.name }}</span>
              {% endif %}
            </span>
            <span class="home-workflow-arrow" aria-hidden="true">→</span>
          </a>
          <a class="home-workflow-edit" href="/admin/contracts/{{ w.name }}/edit"
             title="Edit this workflow (rename, change steps, archive / delete)">Edit</a>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="aging-empty">
      <strong class="aging-empty-headline">No workflows yet.</strong>
      <span class="aging-empty-sub">
        Add a contract YAML under
        <code>{{ contracts_dir_display }}</code> — the directory
        this server is scanning. (Point elsewhere with
        <code>flow serve --workflows-dir PATH</code>.) Once a YAML
        appears here, open it and use the Data Source page to
        fetch data into the warehouse.
      </span>
    </p>
  {% endif %}
{% endblock %}
