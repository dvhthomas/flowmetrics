<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title|default("flowmetrics") }}</title>
  <link rel="icon" href="data:,">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;600&display=swap" rel="stylesheet">
  <style>
    /* Knox design system — single-hue derivation.
       See ~/projects/awm/kno/docs/design-system.md */
    :root {
      --hue: 290; /* plum-violet — locked */

      --p-50:  hsla(var(--hue), 32%, 96%, 1);
      --p-100: hsla(var(--hue), 34%, 88%, 1);
      --p-200: hsla(var(--hue), 38%, 78%, 1);
      --p-400: hsla(var(--hue), 42%, 58%, 1);
      --p-500: hsla(var(--hue), 46%, 48%, 1);
      --p-700: hsla(var(--hue), 52%, 30%, 1);
      --p-900: hsla(var(--hue), 58%, 14%, 1);

      --s-100: hsla(calc(var(--hue) + 60), 36%, 90%, 1);
      --s-500: hsla(calc(var(--hue) + 60), 44%, 56%, 1);
      --s-700: hsla(calc(var(--hue) + 60), 50%, 34%, 1);

      --t-100: hsla(calc(var(--hue) - 60), 30%, 90%, 1);
      --t-500: hsla(calc(var(--hue) - 60), 32%, 54%, 1);
      --t-700: hsla(calc(var(--hue) - 60), 38%, 32%, 1);

      /* Neutrals — TRUE grays (saturation: 0). Page chrome and
         body text should not carry a hue tint; that would compete
         with the actual accent colours (`--p-*` for the import
         CTA, the P85 commitment line). Knox's hue-tinted neutrals
         were the source of the "everything looks plum" feedback;
         deliberately desaturating them here lets the accent
         palette do its job. */
      --bg:      hsl(0, 0%, 97%);
      --surface: hsl(0, 0%, 94%);
      --border:  hsl(0, 0%, 84%);
      --fg:      hsl(0, 0%, 13%);
      --muted:   hsl(0, 0%, 46%);

      --white: #ffffff;
      --black: #111111;

      --head-font: "Rubik", sans-serif;
      --body-font: -apple-system, BlinkMacSystemFont, "Segoe UI",
                   Roboto, Helvetica, Arial, sans-serif;
      --mono-font: ui-monospace, SFMono-Regular, "SF Mono",
                   Menlo, Consolas, monospace;
    }

    /* All sizing — fonts, padding, borders, radii — uses rem so a
       single change to the html font-size (or the user's browser
       font-size preference) scales the whole UI consistently. The
       only px-based scale is hairlines under 1rem (0.0625rem). */

    * { box-sizing: border-box; }

    body {
      font-family: var(--body-font);
      /* Inherit from :root — no explicit px lock. This honors a
         user's browser font-size preference (accessibility) and is
         the anchor for every rem value below. */
      font-size: 1rem;
      line-height: 1.6;
      background: var(--white);
      color: var(--fg);
      margin: 0;
    }

    h1, h2, h3 { font-family: var(--head-font); font-weight: 600; }
    h1 { font-size: 2.25rem; line-height: 1.15; letter-spacing: -0.02em; color: var(--fg); margin: 0; }
    h2 {
      /* Section eyebrow — UPPERCASE, muted */
      font-size: 0.8125rem;
      line-height: 1.4;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 1.4rem 0 0.4rem 0;
    }
    h3 {
      font-size: 1.0625rem;
      line-height: 1.3;
      letter-spacing: -0.005em;
      color: var(--fg);
      margin: 0;
    }

    /* Default link styling — neutral. The page reserves coloured
       affordances for explicit CTAs (`.btn--primary`) and the
       single most-meaningful chart accent (P85). Body links read
       as text-with-underline-on-hover, not coloured-by-default. */
    a {
      color: inherit;
      text-decoration: underline;
      text-decoration-color: var(--border);
      text-underline-offset: 0.15em;
    }
    a:hover {
      text-decoration-color: var(--muted);
    }

    code, .mono { font-family: var(--mono-font); font-size: 0.84375rem; }
    code {
      background: var(--surface);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
    }

    .container {
      max-width: 75rem;
      margin: 0 auto;
      padding: 1.5rem 1.25rem;
    }

    /* ─────── Site header ─────── */
    header.site-header {
      background: var(--white);
      border-bottom: 0.0625rem solid var(--border);
    }
    header.site-header .container {
      display: flex;
      align-items: baseline;
      gap: 0.7rem;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
    header.site-header .brand {
      /* Brand mark — neutral. Chrome should fade into the
         background so colored elements (the import CTA, the P85
         commitment line) are unambiguous. */
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.25rem;
      letter-spacing: -0.01em;
      color: var(--fg);
      text-decoration: none;
    }
    header.site-header .brand:hover {
      color: var(--muted);
      text-decoration: none;
    }
    header.site-header .stamp {
      font-family: var(--mono-font);
      font-size: 0.75rem;
      color: var(--muted);
      background: var(--surface);
      padding: 0.1875rem 0.4375rem;
      border-radius: 0.25rem;
      text-decoration: none;
    }
    /* `a.stamp` is a clickable breadcrumb back to the workflow's
       dashboard — make it visibly tappable. */
    header.site-header a.stamp:hover {
      color: var(--fg);
      background: var(--border);
    }
    /* The current page's chip — looks the same but isn't a link. */
    header.site-header .stamp--current {
      color: var(--fg);
      background: var(--border);
    }
    header.site-header .header-sep {
      color: var(--border);
      font-size: 0.875rem;
      user-select: none;
    }
    header.site-header .header-metric-name {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.0625rem;
      letter-spacing: -0.005em;
      color: var(--fg);
    }

    /* ─────── Home page (workflow picker) ─────── */
    .home-intro {
      margin: 1.4rem 0 1rem 0;
    }
    .home-intro h1 {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.5rem;
      letter-spacing: -0.01em;
      margin: 0 0 0.3rem 0;
    }
    .home-subtitle {
      color: var(--muted);
      font-size: 0.9375rem;
      margin: 0;
    }
    .home-workflow-list {
      list-style: none;
      padding: 0;
      margin: 0.5rem 0;
    }
    .home-workflow-item {
      margin: 0;
      border-bottom: 0.0625rem solid var(--border);
    }
    .home-workflow-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 0.3rem;
      color: var(--fg);
      text-decoration: none;
      font-family: var(--mono-font);
      font-size: 0.9375rem;
    }
    .home-workflow-link:hover {
      background: var(--surface);
    }
    .home-workflow-arrow {
      color: var(--muted);
    }

    /* ─────── Filter bar ─────── */
    .filter-bar {
      position: sticky;
      top: 0;
      z-index: 10;
      background: var(--white);
      border-bottom: 0.0625rem solid var(--border);
    }
    .filter-bar .container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
      align-items: center;
      padding-top: 0.7rem;
      padding-bottom: 0.7rem;
      font-size: 0.875rem;
    }
    .filter-bar label {
      display: inline-flex;
      gap: 0.35rem;
      align-items: center;
      color: var(--muted);
    }
    .filter-bar input,
    .filter-bar select {
      font-size: 0.875rem;
      padding: 0.2rem 0.45rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      background: var(--white);
      font-family: inherit;
      color: var(--fg);
    }
    .filter-bar input:focus,
    .filter-bar select:focus {
      /* High-contrast neutral focus ring — meets WCAG's "focus
         indicator must be visible" without competing colours. */
      outline: 0.125rem solid var(--fg);
      outline-offset: -0.0625rem;
      border-color: var(--fg);
    }
    .filter-bar .note {
      color: var(--muted);
      font-style: italic;
      margin-left: auto;
      font-size: 0.75rem;
    }
    .filter-bar-form {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      align-items: center;
      width: 100%;
    }
    .filter-window {
      border: 0.0625rem solid var(--border);
      border-radius: 0.3rem;
      padding: 0.25rem 0.6rem 0.4rem 0.6rem;
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      margin: 0;
    }
    .filter-window legend {
      color: var(--fg);
      font-weight: 600;
      font-size: 0.78125rem;
      padding: 0 0.3rem;
    }
    .filter-hint {
      color: var(--muted);
      font-weight: 400;
      font-style: italic;
    }
    .filter-apply {
      background: var(--p-500);
      color: var(--white);
      border: 0;
      border-radius: 0.25rem;
      padding: 0.35rem 0.85rem;
      font-family: inherit;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
    }
    .filter-apply:hover { background: var(--p-700); }
    .filter-reset {
      color: var(--muted);
      font-size: 0.8125rem;
      text-decoration: none;
    }
    .filter-reset:hover { color: var(--fg); text-decoration: underline; }

    /* ─────── Metric summary (above charts) ─────── */
    .metric-summary {
      margin: 1.2rem 0 0.6rem 0;
      padding: 0 0.2rem;
    }
    .metric-summary-title {
      /* H3 with larger treatment for top-of-section presence.
         Explicit text-transform: none to defeat any cascade. */
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.5rem;
      line-height: 1.2;
      letter-spacing: -0.015em;
      color: var(--fg);
      margin: 0;
      text-transform: none;
    }
    .metric-summary-headline {
      margin: 0.25rem 0 0 0;
      color: var(--muted);
      font-size: 0.875rem;
    }

    /* ─────── Chart tile ─────── */
    .metric {
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      padding: 1rem 1.2rem 1.1rem 1.2rem;
      margin: 0.6rem 0 1.4rem 0;
    }
    .metric-header {
      display: flex;
      align-items: baseline;
      justify-content: flex-end;
      margin-bottom: 0.4rem;
      min-height: 1.6rem;
    }
    .metric-header-controls {
      display: flex;
      gap: 0.55rem;
      align-items: center;
    }
    .metric-chart {
      width: 100%;
    }
    .metric--link-only {
      /* Tile that's just a link, no chart. Keeps the border +
         padding so it looks like a tile, but no min-height. */
      padding: 0.8rem 1.2rem;
    }

    /* ─────── Buttons ─────── */
    .reset-btn,
    button.btn {
      font-family: inherit;
      font-size: 0.75rem;
      padding: 0.22rem 0.6rem;
      background: var(--white);
      color: var(--muted);
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      cursor: pointer;
    }
    .reset-btn:hover,
    button.btn:hover {
      color: var(--fg);
      border-color: var(--muted);
    }
    .reset-btn.htmx-request,
    button.btn.htmx-request {
      opacity: 0.55;
      cursor: wait;
    }

    /* ─────── Links inside metric tiles ─────── */
    .details-link {
      /* Neutral, with underline on hover so it still reads as a
         link. CTA color is reserved for the import button. */
      font-size: 0.8125rem;
      color: var(--muted);
      text-decoration: none;
    }
    .details-link:hover {
      color: var(--fg);
      text-decoration: underline;
    }

    /* ─────── Detail page extras ─────── */
    .detail-extras h2 {
      /* Use the eyebrow style for in-page section headers */
      margin: 1.8rem 0 0.5rem 0;
    }
    .detail-extras p,
    .detail-extras ul {
      color: var(--fg);
      font-size: 0.9375rem;
      margin: 0.5rem 0;
    }
    .detail-extras p em {
      color: var(--muted);
    }

    .back-link {
      display: inline-block;
      margin-top: 1.6rem;
      color: var(--muted);
      font-size: 0.8125rem;
      text-decoration: none;
    }
    .back-link:hover {
      color: var(--fg);
      text-decoration: underline;
    }

    /* ─────── Work-items table ─────── */
    .work-items {
      margin: 0.6rem 0 1.4rem 0;
    }
    .work-items-controls {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      margin-bottom: 0.4rem;
    }
    .work-items-search {
      flex: 0 1 20rem;
      font-size: 0.875rem;
      padding: 0.3rem 0.55rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      background: var(--white);
      font-family: inherit;
      color: var(--fg);
    }
    .work-items-search:focus {
      outline: 0.125rem solid var(--fg);
      outline-offset: -0.0625rem;
      border-color: var(--fg);
    }
    .work-items-count {
      color: var(--muted);
      font-size: 0.75rem;
      margin-left: auto;
    }
    .work-items-active-filter {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.25rem 0.6rem;
      margin: 0 0 0.4rem 0;
      background: var(--surface);
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      font-size: 0.8125rem;
      color: var(--fg);
      width: fit-content;
    }
    .work-items-active-filter-label {
      color: var(--muted);
    }
    .work-items-active-filter-value {
      font-weight: 600;
    }
    .work-items-clear-filter {
      color: var(--muted);
      font-size: 0.75rem;
      margin-left: 0.3rem;
      cursor: pointer;
      text-decoration: underline;
    }
    .work-items-clear-filter:hover {
      color: var(--fg);
    }
    table.work-items-grid {
      width: 100%;
      border-collapse: collapse;
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      overflow: hidden;
      font-size: 0.875rem;
    }
    table.work-items-grid th {
      text-align: left;
      padding: 0.55rem 0.8rem;
      background: var(--surface);
      color: var(--muted);
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-bottom: 0.0625rem solid var(--border);
    }
    table.work-items-grid th a {
      color: inherit;
      text-decoration: none;
      display: inline-flex;
      gap: 0.25rem;
      align-items: center;
      cursor: pointer;
    }
    table.work-items-grid th a:hover {
      color: var(--fg);
    }
    table.work-items-grid th.sorted a {
      /* Active-sort column: stronger neutral, plus the arrow indicator
         carries the small accent. Avoid coloring the whole header in
         primary — the table should read as data, not decoration. */
      color: var(--fg);
    }
    table.work-items-grid th .sort-indicator {
      /* Neutral arrow — the sort column is the carrier of meaning
         on its own (active column gets stronger text contrast via
         th.sorted). Color here would compete with the page CTA. */
      font-size: 0.625rem;
      color: var(--muted);
    }
    table.work-items-grid td {
      padding: 0.5rem 0.8rem;
      border-bottom: 0.0625rem solid var(--border);
      vertical-align: top;
    }
    table.work-items-grid tr:last-child td {
      border-bottom: none;
    }
    table.work-items-grid td.num {
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-family: var(--mono-font);
    }
    table.work-items-grid td.id {
      font-family: var(--mono-font);
      font-size: 0.78125rem;
      color: var(--muted);
    }
    table.work-items-grid td.id a {
      /* Navigation link, not a CTA. Neutral so the page's single
         coloured action (the import button) reads as the obvious
         next step. Underline on hover preserves the affordance. */
      color: var(--fg);
      text-decoration: none;
    }
    table.work-items-grid td.id a:hover {
      text-decoration: underline;
    }
    table.work-items-grid td.title a {
      color: var(--fg);
    }
    table.work-items-grid td.title a:hover {
      color: var(--muted);
    }
    table.work-items-grid tr:hover td {
      /* Neutral surface for hover — the table is data, not chrome,
         so the hover affordance should not tint rows toward the
         brand color. */
      background: var(--surface);
    }
    /* ─────── Lifecycle metric strip ─────── */
    .lifecycle-metric-strip {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin: 0.4rem 0 0.8rem 0;
      padding: 0.5rem 0.8rem;
      background: var(--surface);
      border: 0.0625rem solid var(--border);
      border-radius: 0.375rem;
      font-size: 0.875rem;
    }
    .lifecycle-metric-strip-label {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.6875rem;
      font-weight: 600;
    }
    .lifecycle-metric-strip-value {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.25rem;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .lifecycle-metric-strip-formula {
      color: var(--muted);
      font-size: 0.78125rem;
    }

    /* ─────── Lifecycle summary (trivial-case alternative to chart) ─────── */
    .lifecycle-summary {
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      padding: 1.2rem 1.4rem;
      margin: 0.6rem 0 1.4rem 0;
    }
    .lifecycle-summary-duration {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }
    .lifecycle-summary-duration-value {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 2rem;
      line-height: 1.1;
      letter-spacing: -0.015em;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .lifecycle-summary-duration-label {
      color: var(--muted);
      font-size: 0.9375rem;
    }
    .lifecycle-summary-flow {
      margin-top: 0.8rem;
      padding-top: 0.7rem;
      border-top: 0.0625rem solid var(--border);
      color: var(--muted);
      font-size: 0.84375rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 0.8rem;
      align-items: baseline;
    }
    .lifecycle-summary-arrow {
      color: var(--muted);
    }
    .lifecycle-summary-to {
      color: var(--fg);
    }

    /* ─────── Forecast panels ─────── */
    .forecast-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(28rem, 1fr));
      gap: 1.4rem;
      margin: 1rem 0;
    }
    .forecast-panel {
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      padding: 1rem 1.2rem 1.2rem 1.2rem;
    }
    .forecast-panel-header h3 {
      margin: 0 0 0.2rem 0;
      font-size: 1.0625rem;
    }
    .forecast-panel-sub {
      color: var(--muted);
      font-size: 0.875rem;
      margin: 0 0 0.6rem 0;
    }
    .forecast-panel-sub output {
      font-weight: 600;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .forecast-slider-label {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.8125rem;
      color: var(--muted);
      margin: 0.4rem 0 0.6rem 0;
    }
    .forecast-slider-label input[type="range"] {
      flex: 1;
      accent-color: var(--p-500);
    }
    .forecast-summary {
      color: var(--muted);
      font-size: 0.84375rem;
      margin: 0.2rem 0 0.6rem 0;
      line-height: 1.5;
    }
    .forecast-percentiles {
      border-collapse: collapse;
      margin: 0.3rem 0 0.7rem 0;
      font-size: 0.875rem;
      color: var(--fg);
    }
    .forecast-percentiles td,
    .forecast-percentiles th {
      padding: 0.15rem 0.6rem 0.15rem 0;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }
    .forecast-percentile-swatch {
      width: 2.5rem;
      padding-right: 0.5rem !important;
    }
    .forecast-percentile-swatch .forecast-dash {
      display: inline-block;
      width: 2.25rem;
      height: 0.625rem;
      vertical-align: middle;
    }
    .forecast-percentile-label {
      font-weight: 600;
      width: 2.5rem;
    }
    .forecast-percentile-value {
      color: var(--muted);
    }

    /* ─────── Aging percentile-source smell ─────── */
    .aging-smell {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      padding: 0.7rem 0.9rem;
      margin: 0.4rem 0;
      background: var(--surface);
      border: 0.0625rem solid var(--fg);
      border-left-width: 0.25rem;
      border-radius: 0.25rem;
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--fg);
    }
    .aging-smell-icon {
      font-size: 1.125rem;
      line-height: 1;
      padding-top: 0.1rem;
    }
    .aging-smell-text {
      flex: 1;
    }

    /* ─────── Aging empty states ───────
       Three flavors with different visual weight:
       - --real      neutral. The answer is empty; no action.
       - --outside-window
                     warning-tinted. As-of is outside the workflow's
                     start/stop; pick a different as-of.
       - --stale     plum-tinted action card. Operator should run
                     `flow materialise` to refresh; we name the
                     exact command. */
    .aging-empty {
      padding: 1.4rem 1.6rem;
      margin: 0.4rem 0;
      border-radius: 0.5rem;
      font-size: 0.875rem;
      border: 0.0625rem solid var(--border);
      background: var(--surface);
    }
    .aging-empty-headline {
      margin: 0 0 0.35rem 0;
      font-weight: 600;
      color: var(--fg);
      font-size: 0.9375rem;
    }
    .aging-empty-sub {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
    }
    .aging-empty-cmd {
      margin: 0.7rem 0 0 0;
      padding: 0.55rem 0.75rem;
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      font-family: var(--mono-font);
      font-size: 0.8125rem;
      color: var(--fg);
      overflow-x: auto;
    }
    .aging-empty--gap {
      /* Coverage gap — neutral box. The CTA inside (the import
         button, in plum) carries the attention; the box around it
         doesn't need to compete. */
      background: var(--surface);
      border-color: var(--border);
    }
    .aging-empty--real {
      background: var(--surface);
      border-color: var(--border);
    }
    .aging-empty--error {
      /* Error backdrop — stronger neutral border. We rely on text
         ("Import failed.") rather than colour to communicate
         "this is bad," so the page stays monochrome. */
      background: var(--surface);
      border-color: var(--fg);
    }
    .aging-empty-actions {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      margin: 0.8rem 0 0.4rem 0;
    }
    .btn--primary {
      /* The page's single CTA. Plum is reserved for this kind of
         action; everything else is neutral so this button reads
         as the obvious next step. */
      display: inline-block;
      font-family: inherit;
      font-size: 0.9375rem;
      font-weight: 600;
      line-height: 1.4;
      padding: 0.5rem 1rem;
      background: var(--p-500);
      color: var(--white);
      border: 0.0625rem solid var(--p-500);
      border-radius: 0.25rem;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.15s, border-color 0.15s;
    }
    .btn--primary:hover {
      /* A11y: don't rely on color alone. Hover deepens BOTH
         background and border, so users who can't perceive the
         plum shift still see the border change. */
      background: var(--p-700);
      border-color: var(--p-900);
      color: var(--white);
    }
    .btn--primary:focus-visible {
      /* Keyboard focus ring — explicit, outside the button so
         it's visible against any nearby surface. */
      outline: 0.1875rem solid var(--p-200);
      outline-offset: 0.125rem;
    }
    .btn--primary:active {
      background: var(--p-900);
    }
    .btn--primary:disabled,
    .btn--primary.htmx-request {
      opacity: 0.6;
      cursor: wait;
    }
    .aging-empty-progress {
      color: var(--muted);
      font-size: 0.8125rem;
      font-style: italic;
    }
    .htmx-indicator {
      opacity: 0;
      transition: opacity 0.2s;
    }
    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator {
      opacity: 1;
    }
    .aging-empty-cli {
      margin-top: 0.8rem;
      color: var(--muted);
      font-size: 0.8125rem;
    }
    .aging-empty-cli summary {
      cursor: pointer;
      color: var(--muted);
      text-decoration: underline;
    }
    .aging-empty-cli summary:hover {
      color: var(--fg);
    }
    .text-muted {
      color: var(--muted);
      font-style: italic;
    }

    /* ─────── Work-items pager ─────── */
    .work-items-pager {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 0.6rem 0.2rem 0.2rem 0.2rem;
      font-size: 0.8125rem;
      color: var(--muted);
    }
    .work-items-pager-info {
      font-variant-numeric: tabular-nums;
    }
    .work-items-pager-controls {
      display: inline-flex;
      gap: 0.8rem;
    }
    .work-items-pager-controls a {
      color: var(--fg);
      text-decoration: none;
      padding: 0.2rem 0.55rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      background: var(--white);
    }
    .work-items-pager-controls a:hover {
      border-color: var(--muted);
      color: var(--fg);
    }
    .work-items-pager-disabled {
      color: var(--border);
      padding: 0.2rem 0.55rem;
      border: 0.0625rem solid transparent;
    }

    .work-items-empty {
      padding: 1.5rem;
      color: var(--muted);
      text-align: center;
      font-size: 0.875rem;
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/vega@5"></script>
  <script src="https://cdn.jsdelivr.net/npm/vega-lite@5"></script>
  <script src="https://cdn.jsdelivr.net/npm/vega-embed@6"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script>
    /* Theme bridge — single source of truth for chart colors.
       The CSS at `:root` defines tokens (--p-500, --t-500, etc.)
       derived from `--hue`. Vega-Lite specs use placeholder strings
       like `__theme:p-500__`; `applyTheme(spec)` substitutes them
       with the current CSS-variable values before vegaEmbed.

       Change `--hue` (or any individual token) in CSS and every
       chart on every page picks up the new value on next render —
       no Python or template change needed. */
    (function () {
      const cs = getComputedStyle(document.documentElement);
      const tokens = [
        "p-50", "p-100", "p-200", "p-400", "p-500", "p-700", "p-900",
        "s-100", "s-500", "s-700",
        "t-100", "t-500", "t-700",
        "muted", "fg", "bg", "surface", "border"
      ];
      const obj = {};
      for (const t of tokens) obj[t] = cs.getPropertyValue("--" + t).trim();
      window.flowmetricsTheme = obj;

      window.applyTheme = function (spec) {
        const s = JSON.stringify(spec);
        return JSON.parse(s.replace(
          /__theme:([a-z0-9-]+)__/g,
          function (_, key) { return window.flowmetricsTheme[key] || ""; }
        ));
      };
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/">flowmetrics</a>
      {% if contract %}
        <span class="header-sep" aria-hidden="true">·</span>
        {# Workflow name is a link to the workflow's dashboard,
           UNLESS we're already on that page (in which case it
           reads as the current breadcrumb). #}
        {% if metric_name %}
          <a class="stamp" href="/workflows/{{ contract.name }}">{{ contract.name }}</a>
        {% else %}
          <span class="stamp stamp--current">{{ contract.name }}</span>
        {% endif %}
      {% endif %}
      {% if metric_name %}
        <span class="header-sep" aria-hidden="true">·</span>
        <span class="header-metric-name">{{ metric_name }}</span>
      {% endif %}
    </div>
  </header>

  {% block filter_bar %}
  <nav class="filter-bar" aria-label="Filters">
    <div class="container">
      {# The workflow switcher only renders on the workflow's
         home page (the dashboard, where `metric_name` is unset).
         Detail pages use the breadcrumb to navigate. #}
      {% if not metric_name %}
      <label>Workflow
        <select name="workflow"
                onchange="(function(s){
                  if (!s.value || s.value === '{{ contract.name }}') return;
                  /* Preserve sub-route after /workflows/{id} so the
                     viewer keeps their current metric/page when
                     switching between workflows. */
                  location.pathname = location.pathname.replace(
                    /^\/workflows\/[^\/]+/,
                    '/workflows/' + encodeURIComponent(s.value)
                  );
                })(this)">
          {% for c in available_contracts %}
            <option value="{{ c }}"{% if c == contract.name %} selected{% endif %}>{{ c }}</option>
          {% endfor %}
        </select>
      </label>
      {% endif %}
      <form method="get" class="filter-bar-form" aria-label="Window controls">
        <fieldset class="filter-window">
          <legend>View window <span class="filter-hint">— chart x-axes (inclusive)</span></legend>
          <label>From <input type="date" name="view_from" value="{{ contract.view_from }}"></label>
          <label>To <input type="date" name="view_to" value="{{ contract.view_to }}"></label>
        </fieldset>
        <fieldset class="filter-window">
          <legend>Reference period <span class="filter-hint">— P-lines + MCS sample (inclusive)</span></legend>
          <label>From <input type="date" name="ref_from" value="{{ contract.ref_from }}"></label>
          <label>To <input type="date" name="ref_to" value="{{ contract.ref_to }}"></label>
        </fieldset>
        <button type="submit" class="filter-apply">Apply</button>
        <a class="filter-reset" href="{{ request.url.path }}">Reset to defaults</a>
      </form>
    </div>
  </nav>
  {% endblock %}

  <main class="container">
    {% block content %}{% endblock %}
  </main>
</body>
</html>
