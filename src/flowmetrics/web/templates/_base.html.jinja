<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title|default("flowmetrics") }}</title>
  <link rel="icon" href="data:,">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;600&display=swap" rel="stylesheet">
  <style>
    /* Knox design system — single-hue derivation.
       See ~/projects/awm/kno/docs/design-system.md */
    :root {
      --hue: 142; /* WhatsApp-style green — locked */

      --p-50:  hsla(var(--hue), 32%, 96%, 1);
      --p-100: hsla(var(--hue), 34%, 88%, 1);
      --p-200: hsla(var(--hue), 38%, 78%, 1);
      --p-400: hsla(var(--hue), 42%, 48%, 1);
      --p-500: hsla(var(--hue), 60%, 40%, 1);
      /* Lighter brand-green for TEXT (headings, breadcrumbs,
         labels). p-700 is too dark — it competes with the CTA
         (p-500 fill) and the P85 commitment line (p-900). */
      --p-600: hsla(var(--hue), 64%, 28%, 1);
      --p-700: hsla(var(--hue), 70%, 20%, 1);
      --p-900: hsla(var(--hue), 80%, 10%, 1);

      --s-100: hsla(calc(var(--hue) + 60), 36%, 90%, 1);
      --s-500: hsla(calc(var(--hue) + 60), 44%, 56%, 1);
      --s-700: hsla(calc(var(--hue) + 60), 50%, 34%, 1);

      /* Categorical band palette (CFD): nine hues evenly spaced (+40°)
         from the brand hue (142, locked), shared S/L — distinct but
         thematically linked. Concrete values (not calc(var(--hue)…))
         because CSS custom properties don't evaluate calc(), and Vega
         must receive a parseable colour. Charts reference these as
         `__theme:cfd-1__` … `__theme:cfd-9__`. */
      --cfd-1: hsl(142, 45%, 72%);
      --cfd-2: hsl(182, 45%, 72%);
      --cfd-3: hsl(222, 45%, 72%);
      --cfd-4: hsl(262, 45%, 72%);
      --cfd-5: hsl(302, 45%, 72%);
      --cfd-6: hsl(342, 45%, 72%);
      --cfd-7: hsl(22, 45%, 72%);
      --cfd-8: hsl(62, 45%, 72%);
      --cfd-9: hsl(102, 45%, 72%);
      /* Per-band "deep" variants — same hue, much lower lightness
         and a touch more saturation — used for the lead-time
         horizontal lines so the line visually belongs to the band
         whose lead time it measures. */
      --cfd-1-deep: hsl(142, 70%, 28%);
      --cfd-2-deep: hsl(182, 70%, 28%);
      --cfd-3-deep: hsl(222, 70%, 30%);
      --cfd-4-deep: hsl(262, 70%, 32%);
      --cfd-5-deep: hsl(302, 70%, 30%);
      --cfd-6-deep: hsl(342, 70%, 32%);
      --cfd-7-deep: hsl( 22, 80%, 36%);
      --cfd-8-deep: hsl( 62, 80%, 28%);
      --cfd-9-deep: hsl(102, 70%, 26%);
      /* Terminal stage on the CFD — darker / muted so the active
         WIP bands above it visually dominate. Same warm hue family
         as the cream canvas, dropped to mid-grey. */
      --cfd-terminal: hsl(45, 14%, 60%);
      /* The empty plot region above the highest band ("items not
         yet started"). Painted via a chart layer. */
      --cfd-above:    hsl(45, 8%, 28%);
      /* Boundary lines bracketing the WIP zone. The deep `p-700` /
         `t-700` shades blend with the band pastels they ride on
         top of; these dedicated tokens are tuned for contrast
         against both the band tops and the dark "above" zone. */
      --cfd-line-arrival:    hsl( 12, 88%, 48%);
      --cfd-line-throughput: hsl(248, 78%, 52%);

      --t-100: hsla(calc(var(--hue) - 60), 30%, 90%, 1);
      --t-500: hsla(calc(var(--hue) - 60), 32%, 54%, 1);
      --t-700: hsla(calc(var(--hue) - 60), 38%, 32%, 1);

      /* Neutrals — *very pale cream* tint (warm yellow hue at
         low saturation). Just enough warmth so the page doesn't
         read as sterile chip-white against the green accents,
         not so much that the cream competes with the brand
         palette. Borders and body text stay neutral grey so type
         contrast isn't tinted. */
      --bg:      hsl(45, 38%, 95%);
      --surface: hsl(45, 30%, 91%);
      --border:  hsl(0, 0%, 84%);
      --fg:      hsl(0, 0%, 13%);
      --muted:   hsl(0, 0%, 46%);

      --white: hsl(45, 38%, 95%);
      --black: #111111;

      --head-font: "Rubik", sans-serif;
      --body-font: -apple-system, BlinkMacSystemFont, "Segoe UI",
                   Roboto, Helvetica, Arial, sans-serif;
      --mono-font: ui-monospace, SFMono-Regular, "SF Mono",
                   Menlo, Consolas, monospace;
    }

    /* All sizing — fonts, padding, borders, radii — uses rem so a
       single change to the html font-size (or the user's browser
       font-size preference) scales the whole UI consistently. The
       only px-based scale is hairlines under 1rem (0.0625rem). */

    * { box-sizing: border-box; }

    /* Brand-tint all native form controls (sliders, checkboxes,
       progress bars). Per-element accent rules below remain as
       targeted overrides; this gives a sensible default for any
       new control. */
    html {
      accent-color: var(--p-500);
      /* Thematic pale-cream fills the whole canvas (incl. overscroll),
         site-wide — never the browser's pure white. */
      background: var(--white);
    }

    body {
      font-family: var(--body-font);
      /* Inherit from :root — no explicit px lock. This honors a
         user's browser font-size preference (accessibility) and is
         the anchor for every rem value below. */
      font-size: 1rem;
      line-height: 1.6;
      background: var(--white);
      color: var(--fg);
      margin: 0;
    }

    h1, h2, h3 { font-family: var(--head-font); font-weight: 600; }
    h1 { font-size: 2.25rem; line-height: 1.15; letter-spacing: -0.02em; color: var(--fg); margin: 0; }
    h2 {
      /* Section eyebrow — UPPERCASE, muted */
      font-size: 0.8125rem;
      line-height: 1.4;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 1.4rem 0 0.4rem 0;
    }
    h3 {
      font-size: 1.0625rem;
      line-height: 1.3;
      letter-spacing: -0.005em;
      color: var(--fg);
      margin: 0;
    }

    /* Default link styling — neutral. The page reserves coloured
       affordances for explicit CTAs (`.btn--primary`) and the
       single most-meaningful chart accent (P85). Body links read
       as text-with-underline-on-hover, not coloured-by-default. */
    a {
      color: inherit;
      text-decoration: underline;
      text-decoration-color: var(--border);
      text-underline-offset: 0.15em;
    }
    a:hover {
      text-decoration-color: var(--muted);
    }

    code, .mono { font-family: var(--mono-font); font-size: 0.84375rem; }
    code {
      background: var(--surface);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
    }

    .container {
      max-width: 75rem;
      margin: 0 auto;
      padding: 1.5rem 1.25rem;
    }

    /* ─────── Site header ─────── */
    header.site-header {
      background: var(--white);
      border-bottom: 0.0625rem solid var(--border);
    }
    header.site-header .container {
      display: flex;
      align-items: baseline;
      gap: 0.7rem;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
    header.site-header .brand {
      /* Brand mark — neutral. Chrome should fade into the
         background so colored elements (the import CTA, the P85
         commitment line) are unambiguous. */
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.625rem;
      letter-spacing: -0.01em;
      color: var(--fg);
      text-decoration: none;
    }
    header.site-header .brand:hover {
      color: var(--muted);
      text-decoration: none;
    }
    /* Workflow name in the breadcrumb — plain text in the
       tertiary hue, regular body font. No code-stamp styling
       (the mono font + surface chip read as a literal/code
       token, which the workflow name isn't). */
    header.site-header .stamp {
      /* Workflow name in the breadcrumb — matches the section
         h2 treatment (head font + brand plum) so the page's two
         brand-coloured anchors agree. */
      font-family: var(--head-font);
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--p-600);
      text-decoration: none;
    }
    header.site-header a.stamp:hover {
      text-decoration: underline;
    }
    header.site-header .stamp--current {
      color: var(--p-600);
    }
    header.site-header .header-sep {
      color: var(--border);
      font-size: 1.25rem;
      user-select: none;
    }
    header.site-header .header-metric-name {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.4375rem;
      letter-spacing: -0.005em;
      color: var(--fg);
    }

    /* ─────── Data source strip ───────
       A muted one-liner naming the data source + the latest
       materialise date. Lives inline in the site-header (pushed
       to the right edge by `margin-left: auto`), so it costs
       zero extra vertical space. Click to backfill. Replaces
       the old in-form stale banner. */
    .data-source-strip {
      margin: 0 0 0 auto;
      font-size: 0.8125rem;
      color: var(--muted);
    }
    .data-source-strip a {
      color: inherit;
      text-decoration: underline dotted;
    }
    .data-source-strip a:hover {
      color: var(--fg);
    }

    /* ─────── Dashboard scope sections ───────
       The dashboard groups tiles by what scope drives them. Each
       section's header IS the scope label — no per-tile icon, no
       explanatory text. See `dashboard.html.jinja`. */
    .scope-section {
      margin: 1.4rem 0 1.6rem 0;
    }
    .scope-section-h2 {
      font-family: var(--head-font);
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--p-600);
      margin: 0;
      padding: 0.4rem 0 0.2rem 0;
    }
    /* On the overview, the h3 metric titles ("Aging WIP",
       "Throughput", …) read AS subheadings under each scope h2 —
       smaller than the h2 above them. Detail pages keep the
       larger treatment defined on `.metric-summary-title`. */
    .scope-section .metric-summary-title {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0;
    }
    .scope-section-header {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.4rem 0;
      margin-bottom: 0.3rem;
    }
    .scope-section-label {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.6875rem;
      font-weight: 600;
    }
    .scope-section-value {
      color: var(--fg);
      font-size: 0.875rem;
    }
    .scope-section-aside {
      color: var(--muted);
      font-size: 0.78125rem;
      margin-left: 0.3rem;
    }
    /* The windowed section's header IS the period-filter row —
       no extra label, the controls are self-describing. */
    .scope-section-header--filter {
      padding: 0.4rem 0;
      flex-wrap: wrap;
    }

    /* ─────── Dashboard tile loading state ─────── */
    .metric-loading {
      min-height: 6.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--surface);
      border: 0.0625rem dashed var(--border);
      border-radius: 0.375rem;
      margin: 0.6rem 0;
      /* Pulse the placeholder so it doesn't feel inert while
         the chart request is in flight. */
      animation: metricLoadingPulse 1.4s ease-in-out infinite;
    }
    @keyframes metricLoadingPulse {
      0%, 100% { opacity: 0.6; }
      50%      { opacity: 1; }
    }
    .metric-loading-text {
      color: var(--muted);
      font-size: 0.875rem;
      margin: 0;
    }
    /* HTMX swap polish: the placeholder fades OUT before the
       real tile fades IN. `hx-swap="outerHTML transition:true"`
       on the stub flips on the View Transitions API path; for
       browsers without it we fall back to the .htmx-* class
       lifecycle. */
    .htmx-swapping {
      opacity: 0;
      transition: opacity 180ms ease-out;
    }
    /* Newly-added tile fragments fade in. HTMX briefly tags
       new elements with `.htmx-added` after the swap — pinning
       the animation on that class catches each piece of the
       fragment (summary + chart) without us enumerating them. */
    @keyframes metricTileAppear {
      from { opacity: 0; transform: translateY(0.25rem); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .htmx-added {
      animation: metricTileAppear 260ms ease-out;
    }

    /* ─────── Home page (workflow picker) ─────── */
    .home-intro {
      margin: 1.4rem 0 1rem 0;
    }
    .home-intro h1 {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.5rem;
      letter-spacing: -0.01em;
      margin: 0 0 0.3rem 0;
    }
    .home-subtitle {
      color: var(--muted);
      font-size: 0.9375rem;
      margin: 0;
    }
    .home-workflow-list {
      list-style: none;
      padding: 0;
      margin: 0.5rem 0;
    }
    .home-workflow-item {
      margin: 0;
      border-bottom: 0.0625rem solid var(--border);
      display: flex;
      align-items: stretch;
    }
    .home-workflow-link {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 0.3rem;
      color: var(--fg);
      text-decoration: none;
      font-size: 0.9375rem;
    }
    .home-workflow-link:hover {
      background: var(--surface);
    }
    .home-workflow-edit {
      display: flex;
      align-items: center;
      padding: 0 0.9rem;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.8125rem;
      border-left: 0.0625rem solid var(--border);
    }
    .home-workflow-edit:hover {
      background: var(--surface);
      color: var(--p-600);
    }
    .home-workflow-name {
      font-family: var(--head-font);
      font-weight: 600;
    }
    .home-workflow-id {
      color: var(--muted);
      font-family: var(--mono-font);
      font-size: 0.8125rem;
      margin-left: 0.6rem;
    }
    .home-workflow-arrow {
      color: var(--muted);
    }

    /* ─────── Filter bar ─────── */
    .filter-bar {
      position: sticky;
      top: 0;
      z-index: 10;
      background: var(--white);
      border-bottom: 0.0625rem solid var(--border);
    }
    .filter-bar .container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
      align-items: center;
      padding-top: 0.7rem;
      padding-bottom: 0.7rem;
      font-size: 0.875rem;
    }
    .filter-bar label {
      display: inline-flex;
      gap: 0.35rem;
      align-items: center;
      color: var(--muted);
    }
    .filter-bar input,
    .filter-bar select {
      font-size: 0.875rem;
      padding: 0.2rem 0.45rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      background: var(--white);
      font-family: inherit;
      color: var(--fg);
    }
    .filter-bar input:focus,
    .filter-bar select:focus {
      /* High-contrast neutral focus ring — meets WCAG's "focus
         indicator must be visible" without competing colours. */
      outline: 0.125rem solid var(--fg);
      outline-offset: -0.0625rem;
      border-color: var(--fg);
    }
    .filter-bar .note {
      color: var(--muted);
      font-style: italic;
      margin-left: auto;
      font-size: 0.75rem;
    }
    .filter-bar-form {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 0.75rem;
      align-items: center;
      width: 100%;
    }
    .filter-compact {
      display: inline-flex;
      gap: 0.3rem;
      align-items: center;
      color: var(--muted);
      font-size: 0.8125rem;
    }
    .filter-compact select,
    .filter-compact input {
      font-size: 0.8125rem;
      padding: 0.15rem 0.4rem;
    }
    .filter-advanced {
      flex-basis: 100%;
      margin-top: 0.3rem;
    }
    .filter-advanced summary {
      cursor: pointer;
      color: var(--muted);
      font-size: 0.78125rem;
      list-style: revert;
    }
    .filter-advanced summary:hover { color: var(--fg); }
    .filter-advanced > p {
      margin: 0.3rem 0;
      font-size: 0.78125rem;
    }
    .filter-custom {
      /* `display: contents` so Period Ending + View lay out as
         direct flex items of the bar. An author `display` beats
         the UA `[hidden]` rule, so the hidden state is re-stated. */
      display: contents;
    }
    .filter-custom[hidden] { display: none; }
    .filter-advanced .filter-compact { margin-top: 0.3rem; }
    .filter-hint {
      color: var(--muted);
      font-weight: 400;
      font-style: italic;
    }
    .filter-reset {
      color: var(--muted);
      font-size: 0.8125rem;
      text-decoration: none;
    }
    .filter-reset:hover { color: var(--fg); text-decoration: underline; }

    /* ─────── Metric summary (above charts) ─────── */
    .metric-summary {
      margin: 1.2rem 0 0.6rem 0;
      padding: 0 0.2rem;
    }
    .metric-summary-title {
      /* H3 with larger treatment for top-of-section presence.
         Explicit text-transform: none to defeat any cascade. */
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.5rem;
      line-height: 1.2;
      letter-spacing: -0.015em;
      color: var(--fg);
      margin: 0;
      text-transform: none;
    }
    .metric-summary-headline {
      margin: 0.25rem 0 0 0;
      color: var(--muted);
      font-size: 0.875rem;
    }
    /* Detail-page metric strip — boxed, brand-accented, mirrors
       the work-item lifecycle metric strip. The breadcrumb
       already names the metric, so this strip is the
       at-a-glance summary line. */
    .metric-strip {
      display: flex;
      align-items: baseline;
      gap: 0.7rem;
      flex-wrap: wrap;
      margin: 1.1rem 0 1rem 0;
      padding: 0.6rem 0.9rem;
      background: var(--p-50);
      border-left: 0.25rem solid var(--p-500);
      border-radius: 0.375rem;
    }
    .metric-strip-label {
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 0.6875rem;
      font-weight: 600;
      color: var(--p-600);
    }
    .metric-strip-headline {
      font-size: 0.9375rem;
      color: var(--fg);
    }

    /* ─────── Chart tile ─────── */
    .metric {
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      padding: 1rem 1.2rem 1.1rem 1.2rem;
      margin: 0.6rem 0 1.4rem 0;
    }
    .metric-header {
      display: flex;
      align-items: baseline;
      justify-content: flex-end;
      margin-bottom: 0.4rem;
      min-height: 1.6rem;
    }
    .metric-header-controls {
      display: flex;
      gap: 0.55rem;
      align-items: center;
    }
    .metric-chart {
      width: 100%;
    }
    /* Vega input bindings (the cap / floor range sliders) sit
       ABOVE the chart, not below it. Vega-Embed renders them last
       and sets `.vega-embed { display: inline-block }` from its
       own injected stylesheet — so the override needs the higher-
       specificity `.metric-chart.vega-embed` (both classes land on
       the same element) to win, then flex + order:-1 hoists the
       bindings to the top. */
    .metric-chart.vega-embed {
      display: flex; flex-direction: column;
    }
    .metric-chart.vega-embed .vega-bindings {
      order: -1;
      margin: 0 0 0.55rem 0;
      font-size: 0.8125rem;
      color: var(--muted);
    }
    .metric-chart.vega-embed .vega-bindings .vega-bind {
      display: flex; align-items: center; gap: 0.5rem;
    }
    .metric-chart.vega-embed .vega-bindings input[type="range"] {
      flex: 1;
      accent-color: var(--p-500);
    }
    .metric--link-only {
      /* Tile that's just a link, no chart. Keeps the border +
         padding so it looks like a tile, but no min-height. */
      padding: 0.8rem 1.2rem;
    }

    /* ─────── Buttons — ONE themed system, app-wide ─────── */
    /* Class-based (never element-qualified) so an <a class="btn"> and a
       <button class="btn"> render identically, with no link underline.
       Three intents: default = secondary (neutral), --primary = the
       green CTA, --danger = destructive. --sm shrinks. */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      font-family: inherit;
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1.2;
      padding: 0.45rem 0.9rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.3rem;
      background: var(--surface);
      color: var(--fg);
      text-decoration: none;
      cursor: pointer;
      transition: background-color 0.15s, border-color 0.15s, color 0.15s;
    }
    .btn:hover:not([disabled]) {
      border-color: var(--muted);
      background: var(--white);
      text-decoration: none;
    }
    .btn:focus-visible {
      outline: 0.1875rem solid var(--p-200);
      outline-offset: 0.125rem;
    }
    .btn[disabled], .btn.htmx-request { opacity: 0.55; cursor: not-allowed; }

    .btn--primary {
      background: var(--p-500);
      color: var(--white);
      border-color: var(--p-500);
      font-weight: 600;
    }
    .btn--primary:hover:not([disabled]) {
      background: var(--p-700);
      border-color: var(--p-900);
      color: var(--white);
    }
    .btn--primary:active { background: var(--p-900); }
    .btn--primary[disabled] {
      opacity: 1;
      background: var(--p-100);
      color: var(--muted);
      border-color: var(--p-100);
    }

    .btn--danger { color: var(--t-700); border-color: var(--t-700); }
    .btn--danger:hover:not([disabled]) {
      background: var(--t-700);
      color: var(--white);
      border-color: var(--t-700);
    }

    .btn--sm { font-size: 0.8rem; padding: 0.22rem 0.55rem; gap: 0.25rem; }

    /* Tiny inline reset link in tile headers — its own small style. */
    .reset-btn {
      font-family: inherit;
      font-size: 0.75rem;
      padding: 0.22rem 0.6rem;
      background: var(--white);
      color: var(--muted);
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      text-decoration: none;
      cursor: pointer;
    }
    .reset-btn:hover { color: var(--fg); border-color: var(--muted); }
    .reset-btn.htmx-request { opacity: 0.55; cursor: wait; }

    /* ─────── Links inside metric tiles ─────── */
    .details-link {
      /* The primary outbound action on a tile — pulls the reader
         into the detail page. Brand green at 600 weight gives it
         more pull than the neutral Reset chip beside it without
         tipping into full button territory. */
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--p-700);
      text-decoration: none;
      letter-spacing: 0.01em;
    }
    .details-link:hover {
      color: var(--p-900);
      text-decoration: underline;
      text-decoration-color: var(--p-500);
      text-underline-offset: 0.2em;
    }

    /* ─────── Detail page extras ─────── */
    .detail-extras h2 {
      /* Use the eyebrow style for in-page section headers */
      margin: 1.8rem 0 0.5rem 0;
    }
    .detail-extras p,
    .detail-extras ul {
      color: var(--fg);
      font-size: 0.9375rem;
      margin: 0.5rem 0;
    }
    .detail-extras p em {
      color: var(--muted);
    }

    .back-link {
      display: inline-block;
      margin-top: 1.6rem;
      color: var(--muted);
      font-size: 0.8125rem;
      text-decoration: none;
    }
    .back-link:hover {
      color: var(--fg);
      text-decoration: underline;
    }

    /* ─────── Work-items table ─────── */
    .work-items {
      margin: 0.6rem 0 1.4rem 0;
    }
    .work-items-controls {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 0.4rem;
    }

    /* Compact "Percentile Filter" slider. The two range inputs
       are stacked on the same row so their tracks overlay; pointer
       events still route to whichever handle the user grabs. */
    .ptile-slider {
      display: flex; flex-direction: column; gap: 0.1rem;
      flex: 0 1 22rem; min-width: 18rem;
      padding: 0.1rem 0.55rem 0.45rem 0.55rem;
      background: var(--surface);
      border: 0.0625rem solid var(--border);
      border-radius: 0.3rem;
    }
    .ptile-slider-label {
      display: flex; gap: 0.45rem; align-items: baseline;
      font-size: 0.7rem; color: var(--muted);
      letter-spacing: 0.02em;
    }
    .ptile-slider-label > span:first-child {
      text-transform: uppercase; font-weight: 600;
      letter-spacing: 0.06em;
    }
    .ptile-slider-label strong {
      font-family: var(--mono-font);
      color: var(--fg); font-weight: 600;
      font-size: 0.72rem;
      margin-left: auto;
    }
    .ptile-slider-handles {
      position: relative; height: 1.3rem;
    }
    .ptile-slider-handles > input[type="range"] {
      position: absolute; inset: 0;
      width: 100%; margin: 0;
      background: transparent;
      pointer-events: none;
      -webkit-appearance: none; appearance: none;
    }
    /* Hide the default track on each input so the two stacked
       ranges don't paint two faint tracks on top of each other. */
    .ptile-slider-handles > input[type="range"]::-webkit-slider-runnable-track {
      height: 0.3rem; background: transparent;
    }
    .ptile-slider-handles > input[type="range"]::-moz-range-track {
      height: 0.3rem; background: transparent;
    }
    /* Background track behind both handles. */
    .ptile-slider-handles::before {
      content: "";
      position: absolute; left: 0; right: 0;
      top: 50%; height: 0.3rem;
      transform: translateY(-50%);
      background: var(--bg);
      border: 0.0625rem solid var(--border);
      border-radius: 0.15rem;
    }
    /* WebKit thumb. */
    .ptile-slider-handles > input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; appearance: none;
      width: 0.8rem; height: 0.8rem; border-radius: 50%;
      background: var(--p-500); border: 0.125rem solid var(--white);
      box-shadow: 0 0 0 0.0625rem var(--border);
      pointer-events: auto; cursor: ew-resize;
    }
    .ptile-slider-handles > input[type="range"]::-moz-range-thumb {
      width: 0.8rem; height: 0.8rem; border-radius: 50%;
      background: var(--p-500); border: 0.125rem solid var(--white);
      box-shadow: 0 0 0 0.0625rem var(--border);
      pointer-events: auto; cursor: ew-resize;
    }
    .ptile-slider-ticks {
      position: absolute; left: 0; right: 0; top: 100%;
      pointer-events: none; height: 0.65rem;
    }
    .ptile-slider-ticks > span {
      position: absolute; transform: translateX(-50%);
      font-size: 0.55rem; color: var(--muted);
      font-family: var(--mono-font); top: 0;
    }
    /* P0 and P100 stick to the edges; keep the label inside the
       rail so they aren't clipped by the slider container's pad. */
    .ptile-slider-ticks > span:first-child { transform: translateX(0); }
    .ptile-slider-ticks > span:last-child { transform: translateX(-100%); }
    .ptile-slider-ticks > span::before {
      content: ""; display: block;
      position: absolute; left: 50%; top: -0.4rem;
      width: 0.0625rem; height: 0.3rem;
      background: var(--muted); transform: translateX(-50%);
    }
    .work-items-search {
      flex: 0 1 20rem;
      font-size: 0.875rem;
      padding: 0.3rem 0.55rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      background: var(--white);
      font-family: inherit;
      color: var(--fg);
    }
    .work-items-search:focus {
      outline: 0.125rem solid var(--fg);
      outline-offset: -0.0625rem;
      border-color: var(--fg);
    }
    .work-items-count {
      color: var(--muted);
      font-size: 0.75rem;
      margin-left: auto;
    }
    .work-items-active-filter {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.25rem 0.6rem;
      margin: 0 0 0.4rem 0;
      background: var(--surface);
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      font-size: 0.8125rem;
      color: var(--fg);
      width: fit-content;
    }
    .work-items-active-filter-label {
      color: var(--muted);
    }
    .work-items-active-filter-value {
      font-weight: 600;
    }
    .work-items-clear-filter {
      color: var(--muted);
      font-size: 0.75rem;
      margin-left: 0.3rem;
      cursor: pointer;
      text-decoration: underline;
    }
    .work-items-clear-filter:hover {
      color: var(--fg);
    }
    table.work-items-grid {
      width: 100%;
      border-collapse: collapse;
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      overflow: hidden;
      font-size: 0.875rem;
    }
    table.work-items-grid th {
      text-align: left;
      padding: 0.55rem 0.8rem;
      background: var(--surface);
      color: var(--muted);
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-bottom: 0.0625rem solid var(--border);
    }
    table.work-items-grid th a {
      color: inherit;
      text-decoration: none;
      display: inline-flex;
      gap: 0.25rem;
      align-items: center;
      cursor: pointer;
    }
    table.work-items-grid th a:hover {
      color: var(--fg);
    }
    table.work-items-grid th.sorted a {
      /* Active-sort column: stronger neutral, plus the arrow indicator
         carries the small accent. Avoid coloring the whole header in
         primary — the table should read as data, not decoration. */
      color: var(--fg);
    }
    table.work-items-grid th .sort-indicator {
      /* Neutral arrow — the sort column is the carrier of meaning
         on its own (active column gets stronger text contrast via
         th.sorted). Color here would compete with the page CTA. */
      font-size: 0.625rem;
      color: var(--muted);
    }
    table.work-items-grid td {
      padding: 0.5rem 0.8rem;
      border-bottom: 0.0625rem solid var(--border);
      vertical-align: top;
    }
    table.work-items-grid tr:last-child td {
      border-bottom: none;
    }
    table.work-items-grid td.num {
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-family: var(--mono-font);
    }
    table.work-items-grid td.id {
      font-family: var(--mono-font);
      font-size: 0.78125rem;
      color: var(--muted);
    }
    table.work-items-grid td.id a {
      /* Navigation link, not a CTA. Neutral so the page's single
         coloured action (the import button) reads as the obvious
         next step. Underline on hover preserves the affordance. */
      color: var(--fg);
      text-decoration: none;
    }
    table.work-items-grid td.id a:hover {
      text-decoration: underline;
    }
    table.work-items-grid td.title a {
      color: var(--fg);
    }
    table.work-items-grid td.title a:hover {
      color: var(--muted);
    }
    table.work-items-grid tr:hover td {
      /* Neutral surface for hover — the table is data, not chrome,
         so the hover affordance should not tint rows toward the
         brand color. */
      background: var(--surface);
    }
    /* ─────── Lifecycle metric strip ─────── */
    .lifecycle-metric-strip {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin: 0.4rem 0 0.8rem 0;
      padding: 0.5rem 0.8rem;
      background: var(--surface);
      border: 0.0625rem solid var(--border);
      border-radius: 0.375rem;
      font-size: 0.875rem;
    }
    .lifecycle-metric-strip-label {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.6875rem;
      font-weight: 600;
    }
    .lifecycle-metric-strip-value {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 1.25rem;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }

    /* ─────── Lifecycle summary (trivial-case alternative to chart) ─────── */
    .lifecycle-summary {
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      padding: 1.2rem 1.4rem;
      margin: 0.6rem 0 1.4rem 0;
    }
    .lifecycle-summary-duration {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }
    .lifecycle-summary-duration-value {
      font-family: var(--head-font);
      font-weight: 600;
      font-size: 2rem;
      line-height: 1.1;
      letter-spacing: -0.015em;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .lifecycle-summary-duration-label {
      color: var(--muted);
      font-size: 0.9375rem;
    }
    .lifecycle-summary-flow {
      margin-top: 0.8rem;
      padding-top: 0.7rem;
      border-top: 0.0625rem solid var(--border);
      color: var(--muted);
      font-size: 0.84375rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 0.8rem;
      align-items: baseline;
    }
    .lifecycle-summary-arrow {
      color: var(--muted);
    }
    .lifecycle-summary-to {
      color: var(--fg);
    }

    /* ─────── Forecast panels ─────── */
    .forecast-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(28rem, 1fr));
      gap: 1.4rem;
      margin: 1rem 0;
    }
    .forecast-panel {
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
      padding: 1rem 1.2rem 1.2rem 1.2rem;
    }
    .forecast-panel-header h3 {
      margin: 0 0 0.2rem 0;
      font-size: 1.0625rem;
    }
    .forecast-panel-sub {
      color: var(--muted);
      font-size: 0.875rem;
      margin: 0 0 0.6rem 0;
    }
    .forecast-panel-sub output {
      font-weight: 600;
      color: var(--fg);
      font-variant-numeric: tabular-nums;
    }
    .forecast-slider-label {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.8125rem;
      color: var(--muted);
      margin: 0.4rem 0 0.6rem 0;
    }
    .forecast-slider-label input[type="range"] {
      flex: 1;
      accent-color: var(--p-500);
    }
    .forecast-summary {
      color: var(--muted);
      font-size: 0.84375rem;
      margin: 0.2rem 0 0.6rem 0;
      line-height: 1.5;
    }
    .forecast-percentiles {
      border-collapse: collapse;
      margin: 0.3rem 0 0.7rem 0;
      font-size: 0.875rem;
      color: var(--fg);
    }
    .forecast-percentiles td,
    .forecast-percentiles th {
      padding: 0.15rem 0.6rem 0.15rem 0;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }
    .forecast-percentile-swatch {
      width: 2.5rem;
      padding-right: 0.5rem !important;
    }
    .forecast-percentile-swatch .forecast-dash {
      display: inline-block;
      width: 2.25rem;
      height: 0.625rem;
      vertical-align: middle;
    }
    .forecast-percentile-label {
      font-weight: 600;
      width: 2.5rem;
    }
    .forecast-percentile-value {
      color: var(--muted);
    }

    /* ─────── Aging empty states ───────
       - --real  neutral; the answer is genuinely empty.
       - --gap   plum-tinted action card; the picked window has
                 no data — links to the Data Source page. */
    .aging-empty {
      padding: 1.4rem 1.6rem;
      margin: 0.4rem 0;
      border-radius: 0.5rem;
      font-size: 0.875rem;
      border: 0.0625rem solid var(--border);
      background: var(--surface);
    }
    .aging-empty-headline {
      margin: 0 0 0.35rem 0;
      font-weight: 600;
      color: var(--fg);
      font-size: 0.9375rem;
    }
    .aging-empty-sub {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
    }
    .aging-empty-cmd {
      margin: 0.7rem 0 0 0;
      padding: 0.55rem 0.75rem;
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      font-family: var(--mono-font);
      font-size: 0.8125rem;
      color: var(--fg);
      overflow-x: auto;
    }
    .aging-empty--gap {
      /* Coverage gap — neutral box. The CTA inside (the import
         button, in plum) carries the attention; the box around it
         doesn't need to compete. */
      background: var(--surface);
      border-color: var(--border);
    }
    .aging-empty--real {
      background: var(--surface);
      border-color: var(--border);
    }
    .aging-empty--error {
      /* Error backdrop — stronger neutral border. We rely on text
         ("Import failed.") rather than colour to communicate
         "this is bad," so the page stays monochrome. */
      background: var(--surface);
      border-color: var(--fg);
    }
    .aging-empty-actions {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      margin: 0.8rem 0 0.4rem 0;
    }
    .aging-empty-progress {
      color: var(--muted);
      font-size: 0.8125rem;
      font-style: italic;
    }
    .htmx-indicator {
      opacity: 0;
      transition: opacity 0.2s;
    }
    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator {
      opacity: 1;
    }
    .aging-empty-cli {
      margin-top: 0.8rem;
      color: var(--muted);
      font-size: 0.8125rem;
    }
    .aging-empty-cli summary {
      cursor: pointer;
      color: var(--muted);
      text-decoration: underline;
    }
    .aging-empty-cli summary:hover {
      color: var(--fg);
    }
    .text-muted {
      color: var(--muted);
      font-style: italic;
    }

    /* ─────── Work-items pager ─────── */
    .work-items-pager {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 0.6rem 0.2rem 0.2rem 0.2rem;
      font-size: 0.8125rem;
      color: var(--muted);
    }
    .work-items-pager-info {
      font-variant-numeric: tabular-nums;
    }
    .work-items-pager-controls {
      display: inline-flex;
      gap: 0.8rem;
    }
    .work-items-pager-controls a {
      color: var(--fg);
      text-decoration: none;
      padding: 0.2rem 0.55rem;
      border: 0.0625rem solid var(--border);
      border-radius: 0.25rem;
      background: var(--white);
    }
    .work-items-pager-controls a:hover {
      border-color: var(--muted);
      color: var(--fg);
    }
    .work-items-pager-disabled {
      color: var(--border);
      padding: 0.2rem 0.55rem;
      border: 0.0625rem solid transparent;
    }

    .work-items-empty {
      padding: 1.5rem;
      color: var(--muted);
      text-align: center;
      font-size: 0.875rem;
      background: var(--white);
      border: 0.0625rem solid var(--border);
      border-radius: 0.5rem;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/vega@5"></script>
  <script src="https://cdn.jsdelivr.net/npm/vega-lite@5"></script>
  <script src="https://cdn.jsdelivr.net/npm/vega-embed@6"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <!-- Alpine: declarative client-side state for the rich forms
       (the contract builder). htmx drives the server-rendered
       dashboard tiles; Alpine drives stateful client widgets. -->
  <script defer src="https://unpkg.com/alpinejs@3.14.8/dist/cdn.min.js"></script>
  <script>
    /* Theme bridge — single source of truth for chart colors.
       The CSS at `:root` defines tokens (--p-500, --t-500, etc.)
       derived from `--hue`. Vega-Lite specs use placeholder strings
       like `__theme:p-500__`; `applyTheme(spec)` substitutes them
       with the current CSS-variable values before vegaEmbed.

       Change `--hue` (or any individual token) in CSS and every
       chart on every page picks up the new value on next render —
       no Python or template change needed. */
    (function () {
      const cs = getComputedStyle(document.documentElement);
      const tokens = [
        "p-50", "p-100", "p-200", "p-400", "p-500", "p-700", "p-900",
        "s-100", "s-500", "s-700",
        "t-100", "t-500", "t-700",
        "muted", "fg", "bg", "surface", "border",
        "cfd-1", "cfd-2", "cfd-3", "cfd-4", "cfd-5",
        "cfd-6", "cfd-7", "cfd-8", "cfd-9",
        "cfd-1-deep", "cfd-2-deep", "cfd-3-deep", "cfd-4-deep",
        "cfd-5-deep", "cfd-6-deep", "cfd-7-deep", "cfd-8-deep",
        "cfd-9-deep",
        "cfd-terminal", "cfd-above",
        "cfd-line-arrival", "cfd-line-throughput"
      ];
      const obj = {};
      for (const t of tokens) obj[t] = cs.getPropertyValue("--" + t).trim();
      window.flowmetricsTheme = obj;

      window.applyTheme = function (spec) {
        const s = JSON.stringify(spec);
        return JSON.parse(s.replace(
          /__theme:([a-z0-9-]+)__/g,
          function (_, key) { return window.flowmetricsTheme[key] || ""; }
        ));
      };
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/">flowmetrics</a>
      {% if contract %}
        <span class="header-sep" aria-hidden="true">›</span>
        {# Workflow label is a link to the workflow's dashboard,
           UNLESS we're already on that page (in which case it
           reads as the current breadcrumb). The `label` field
           is human-friendly prose ("Cassandra"); `name` stays
           the URL-safe ID ("apache-cassandra-week"). #}
        {% if metric_name %}
          <a class="stamp" href="{{ ('/workflows/' ~ contract.name) | keep_filters }}">{{ contract.label }}</a>
        {% else %}
          <span class="stamp stamp--current">{{ contract.label }}</span>
        {% endif %}
      {% endif %}
      {% if metric_name %}
        <span class="header-sep" aria-hidden="true">›</span>
        <span class="header-metric-name">{{ metric_name }}</span>
      {% endif %}
      {# Data-source freshness lives inline in the header — same
         row as the breadcrumb, pushed to the right edge by the
         flex layout. Eliminates the dead vertical band a separate
         strip-row was eating. #}
      {% block data_source_strip %}
        {% include "_partials/data_source_strip.html.jinja" %}
      {% endblock %}
    </div>
  </header>

  {% block filter_bar %}
  <nav class="filter-bar" aria-label="Filters">
    <div class="container">
      {% include "_partials/period_filter.html.jinja" %}
    </div>
  </nav>
  {% endblock %}

  <main class="container">
    {% block content %}{% endblock %}
  </main>
</body>
</html>
