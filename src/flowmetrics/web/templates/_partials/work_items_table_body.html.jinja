{# Work-items table body — count + table (or empty state).

   Column-driven: the route passes a `data.columns` list and the
   template iterates without metric-specific branching. New
   columns + new views land by editing the Python column set, not
   this template.

   Rendered into `#work-items-body` as innerHTML on every HTMX
   filter / sort / paginate round-trip. The search input lives
   OUTSIDE this partial (in work_items_table.html.jinja) so it
   keeps focus / caret across swaps.

   Required context:
     data            — WorkItemsTableData
     contract.name   — for building per-item links
#}
{%- macro sort_link(col) -%}
  {%- set is_active = (data.sort == col.sort_key) -%}
  {%- set next_dir = 'asc' if (is_active and data.direction == 'desc') else ('desc' if is_active else 'desc') -%}
  {%- set arrow = '↓' if (is_active and data.direction == 'desc') else ('↑' if is_active else '') -%}
  <a href="#"
     hx-get="/api/internal/work-items?workflow={{ contract.name }}&sort={{ col.sort_key }}&direction={{ next_dir }}&q={{ data.q|urlencode }}&completed_on={{ data.completed_on|urlencode }}&in_flight_at={{ data.in_flight_at|urlencode }}&page=1"
     hx-target="#work-items-body"
     hx-swap="innerHTML">
    {{ col.label }}{% if arrow %} <span class="sort-indicator">{{ arrow }}</span>{% endif %}
  </a>
{%- endmacro -%}

{%- macro header_cell(col) -%}
  <th{% if data.sort == col.sort_key %} class="sorted"{% endif %}
     {%- if col.align == 'right' %} style="text-align:right;"{% endif %}>
    {%- if col.sort_key %}{{ sort_link(col) }}{% else %}{{ col.label }}{% endif -%}
  </th>
{%- endmacro -%}

{%- macro body_cell(col, r) -%}
  {%- if col.kind == 'id-link' -%}
    <td class="id">
      {# Strip the GitHub `#` prefix from the URL path — `#` is
         the canonical id form in the warehouse, but `%23` reads
         as junk. The route accepts both forms; the cell shows
         `#19291`. #}
      <a href="{{ ('/workflows/' ~ contract.name ~ '/items/' ~ (r.item_id|replace('#', '')|urlencode)) | keep_filters }}">{{ r.item_id }}</a>
    </td>
  {%- elif col.kind == 'title-link' -%}
    <td class="title">
      {% if r.url -%}
        <a href="{{ r.url }}" target="_blank" rel="noopener">{{ r.title }}</a>
      {%- else -%}
        {{ r.title }}
      {%- endif %}
    </td>
  {%- elif col.kind == 'date' -%}
    <td>{{ r|attr(col.key) }}</td>
  {%- elif col.kind == 'in-flight-date' -%}
    {%- set v = r|attr(col.key) -%}
    <td>{% if v %}{{ v }}{% else %}<span class="text-muted">— in flight —</span>{% endif %}</td>
  {%- elif col.kind == 'int' -%}
    {%- set v = r|attr(col.key) -%}
    <td class="num">{% if v is not none %}{{ v|int }}{% else %}—{% endif %}</td>
  {%- else -%}
    <td>{{ r|attr(col.key) }}</td>
  {%- endif -%}
{%- endmacro -%}

{% if data.completed_on %}
<div class="work-items-active-filter">
  <span class="work-items-active-filter-label">Filtered to</span>
  <span class="work-items-active-filter-value">{{ data.completed_on_display }}</span>
  <a href="#"
     class="work-items-clear-filter"
     hx-get="/api/internal/work-items?workflow={{ contract.name }}&sort={{ data.sort }}&direction={{ data.direction }}&q={{ data.q|urlencode }}&in_flight_at={{ data.in_flight_at|urlencode }}&page=1"
     hx-target="#work-items-body"
     hx-swap="innerHTML"
     hx-on:click="document.getElementById('work-items-completed-on').value = ''"
     title="Show all items">clear</a>
</div>
{% endif %}

<div class="work-items-count">
  {{ data.count }} item{{ '' if data.count == 1 else 's' }}{% if data.q %} matching “{{ data.q }}”{% endif %}{% if data.completed_on %} on {{ data.completed_on_display }}{% endif %}
</div>

{% if data.rows %}
<table class="work-items-grid">
  <thead>
    <tr>
      {% for col in data.columns %}{{ header_cell(col) }}{% endfor %}
    </tr>
  </thead>
  <tbody>
    {% for r in data.rows %}
    <tr>
      {% for col in data.columns %}{{ body_cell(col, r) }}{% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>

{% if data.total_pages > 1 %}
<nav class="work-items-pager" aria-label="Pagination">
  {%- set base_url -%}
    /api/internal/work-items?workflow={{ contract.name }}&sort={{ data.sort }}&direction={{ data.direction }}&q={{ data.q|urlencode }}&completed_on={{ data.completed_on|urlencode }}&in_flight_at={{ data.in_flight_at|urlencode }}
  {%- endset -%}
  <span class="work-items-pager-info">
    Page {{ data.page }} of {{ data.total_pages }} · {{ data.page_size }} per page
  </span>
  <span class="work-items-pager-controls">
    {% if data.page > 1 %}
    <a href="#"
       hx-get="{{ base_url }}&page={{ data.page - 1 }}"
       hx-target="#work-items-body"
       hx-swap="innerHTML">← Prev</a>
    {% else %}
    <span class="work-items-pager-disabled" aria-disabled="true">← Prev</span>
    {% endif %}
    {% if data.page < data.total_pages %}
    <a href="#"
       hx-get="{{ base_url }}&page={{ data.page + 1 }}"
       hx-target="#work-items-body"
       hx-swap="innerHTML">Next →</a>
    {% else %}
    <span class="work-items-pager-disabled" aria-disabled="true">Next →</span>
    {% endif %}
  </span>
</nav>
{% endif %}

{% else %}
<p class="work-items-empty">
  No items{% if data.q %} matching “{{ data.q }}”{% endif %}.
</p>
{% endif %}
