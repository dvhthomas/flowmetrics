{# Forecast WWIBD-How-Many chart fragment.

   Required context:
     data           — HowManyModel (rendered via the vega_spec Jinja global)
     chart_height   — int pixels
     contract.name  — for any back-links
#}
{%- set chart_container_id = "forecast-how-many-chart" -%}
{%- set _h = chart_height|default(280) -%}

<div id="{{ chart_container_id }}-wrap">
  <p class="forecast-summary" id="forecast-how-many-summary">
    {{ data.headline }}
  </p>
  {% if data.percentile_rows %}
    <table class="forecast-percentiles">
      <tbody>
        {% for row in data.percentile_rows %}
          <tr>
            <td class="forecast-percentile-swatch">
              <span class="forecast-dash"
                    style="background-image: linear-gradient(to right, {{ row.color }} 50%, transparent 0%);
                           background-size: {{ (loop.index * 6) }}px 2px;
                           background-repeat: repeat-x;
                           background-position: 0 50%;"></span>
            </td>
            <th scope="row" class="forecast-percentile-label">{{ row.label }}</th>
            <td class="forecast-percentile-value">{{ row.value_display }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
  <div id="{{ chart_container_id }}" class="metric-chart"
       data-chart-height="{{ _h }}">
    {% if not data.histogram %}
      <p class="aging-empty">
        <strong class="aging-empty-headline">Not enough throughput history to forecast.</strong>
        <span class="aging-empty-sub">
          Monte Carlo needs daily completion counts inside the
          reference period. Widen the reference window above, or
          <a href="/workflows/{{ contract.name }}/data-source">backfill more data</a>.
        </span>
      </p>
    {% endif %}
  </div>
  {% if data.histogram %}
  <script>
    (function () {
      if (window.__flowmetricsForecastHowManyView) {
        try { window.__flowmetricsForecastHowManyView.finalize(); }
        catch (e) { /* finalize is best-effort */ }
        window.__flowmetricsForecastHowManyView = null;
      }
      const spec = {{ vega_spec(data) | safe }};
      spec.height = {{ _h }};
      // First-paint fix: same as the When-Done fragment. Even
      // though this chart's x is quantitative (and so doesn't
      // hit the categorical-step-sizing bug), we run the same
      // double-RAF pattern for consistency — sibling-chart
      // re-embeds also benefit from a fully-settled grid layout.
      function embedWhenSettled() {
        vegaEmbed("#{{ chart_container_id }}", window.applyTheme(spec), {
          actions: false,
          renderer: "svg"
        }).then(function (res) {
          window.__flowmetricsForecastHowManyView = res.view;
        }).catch(function (err) {
          const el = document.getElementById("{{ chart_container_id }}");
          el.innerText = "Chart render failed: " + err;
        });
      }
      requestAnimationFrame(function () {
        requestAnimationFrame(embedWhenSettled);
      });
    })();
  </script>
  {% endif %}
</div>
