{# CFD chart fragment: chart container + Vega-Lite embed.
   Used inside the tile partial AND returned from
   `/api/internal/cfd` as the HTMX swap payload.

   Required context:
     data           — CfdModel (rendered to a spec via the
                      `vega_spec` Jinja global)
     chart_height   — int pixels (~320 for tile, ~440 for detail)
     contract.name  — for any back-links
#}
{%- set chart_container_id = "cfd-chart" -%}
{%- set _h = chart_height|default(320) -%}

<div id="{{ chart_container_id }}" class="metric-chart"
     data-chart-height="{{ _h }}">
  {% if not data.daily %}
    <p class="aging-empty">
      No transitions captured yet.
    </p>
  {% endif %}
</div>
{% if data.daily %}
<script>
  (function () {
    if (window.__flowmetricsCfdView) {
      try { window.__flowmetricsCfdView.finalize(); }
      catch (e) { /* finalize is best-effort */ }
      window.__flowmetricsCfdView = null;
    }
    const METRICS = {{ cfd_daily_metrics(data) | safe }};
    const spec = {{ vega_spec(data) | safe }};
    spec.height = {{ _h }};
    function embed() {
      vegaEmbed("#{{ chart_container_id }}", window.applyTheme(spec), {
        actions: false,
        renderer: "svg"
      }).then(function (res) {
        window.__flowmetricsCfdView = res.view;
        setupCfdHover(res.view, METRICS);
      }).catch(function (err) {
        const el = document.getElementById("{{ chart_container_id }}");
        el.innerText = "Chart render failed: " + err;
      });
    }
    // Defer one frame so the side panel (parsed AFTER this inline script
    // on first load) is laid out before Vega measures the container —
    // otherwise the chart renders at full width and overflows the panel.
    if (window.requestAnimationFrame) { requestAnimationFrame(embed); }
    else { embed(); }

    // Vertical guideline + floating-panel readout linked to the
    // x-axis. Hovering snaps a dashed rule to the nearest day and
    // fills the floating panel with that day's flow metrics; the
    // panel always parks on the side of the rule with more room so
    // it can't occlude the date line itself. Clicking pins the
    // panel to that day (solid rule, outlined panel); clicking the
    // same day again releases. Reads the rendered SVG + Vega's x
    // scale — no extra round-trip.
    function setupCfdHover(view, metrics) {
      const container = document.getElementById("{{ chart_container_id }}");
      const svg = container && container.querySelector("svg");
      if (!svg) return;
      const ns = "http://www.w3.org/2000/svg";
      const rule = document.createElementNS(ns, "line");
      rule.setAttribute("data-flow", "x-guideline");
      rule.setAttribute("stroke", "#444");
      rule.setAttribute("stroke-width", "1");
      rule.setAttribute("stroke-dasharray", "3 3");
      rule.setAttribute("pointer-events", "none");
      rule.style.opacity = "0";
      rule.style.transition = "opacity 80ms";
      svg.appendChild(rule);

      let pinnedIso = null;

      function plotBox() {
        const bg = svg.querySelector(".role-frame .background");
        if (!bg) return null;
        const b = bg.getBBox();
        const ctm = bg.getCTM();
        const tx = ctm ? ctm.e : 0, ty = ctm ? ctm.f : 0;
        return {
          left: tx + b.x, top: ty + b.y,
          right: tx + b.x + b.width, bottom: ty + b.y + b.height,
        };
      }
      function nearestDay(svgX, box) {
        const xs = view.scale("x");
        if (!xs) return null;
        const domain = xs.domain();
        const bw = xs.bandwidth ? xs.bandwidth() : 0;
        let best = null, bestDist = Infinity, bestCx = 0;
        for (let i = 0; i < domain.length; i++) {
          const cx = box.left + xs(domain[i]) + bw / 2;
          const dist = Math.abs(svgX - cx);
          if (dist < bestDist) { bestDist = dist; best = domain[i]; bestCx = cx; }
        }
        return best === null ? null : { iso: best, cx: bestCx };
      }
      function val(n) { return (n === null || n === undefined) ? "—" : n; }
      function renderPanel(iso, isPinned) {
        // Look the panel up lazily — it may be parsed into the DOM after
        // this embed callback first runs.
        const panel = document.getElementById("cfd-hover-panel");
        if (!panel) return;
        const m = metrics[iso];
        if (!m) return;
        const bands = Object.keys(m.stages).map(function (s) {
          return "<tr><td>" + s + "</td><td>" + m.stages[s] + "</td></tr>";
        }).join("");
        const pinHeader = isPinned
          ? '<p class="cfd-panel-pin">📌 Pinned · click to release</p>'
          : '';
        panel.innerHTML = pinHeader +
          '<div class="cfd-panel-date">' + m.date_display + '</div>' +
          '<table class="cfd-panel-table"><thead><tr>' +
          '<th>Stage</th><th>Items</th></tr></thead><tbody>' + bands +
          '</tbody></table>' +
          '<table class="cfd-panel-table cfd-panel-flow"><tbody>' +
          '<tr><td>Total WIP</td><td>' + val(m.total_wip) + '</td></tr>' +
          '<tr><td>Arrivals (day)</td><td>' + val(m.arrivals) + '</td></tr>' +
          '<tr><td>Departures (day)</td><td>' + val(m.departures) + '</td></tr>' +
          '<tr><td>Throughput (avg/day)</td><td>' + val(m.throughput) + '</td></tr>' +
          '<tr><td>Avg cycle time (days)</td><td>' + val(m.avg_cycle_time) +
          '</td></tr></tbody></table>';
        if (isPinned) panel.classList.add("is-pinned");
        else panel.classList.remove("is-pinned");
      }
      function placePanel(cxSvg) {
        // Convert the SVG-coord x of the rule to a pixel offset
        // inside the .cfd-tile-wrap that owns the panel's position,
        // then park the panel on whichever side of the rule has more
        // room. Skip on the narrow-viewport breakpoint, where CSS
        // forces the panel back to static.
        const panel = document.getElementById("cfd-hover-panel");
        if (!panel) return;
        const cs = window.getComputedStyle(panel);
        if (cs.position !== "absolute") return;
        const wrap = panel.offsetParent;
        if (!wrap) return;
        const svgRect = svg.getBoundingClientRect();
        const wrapRect = wrap.getBoundingClientRect();
        const vb = svg.viewBox.baseVal;
        const vbw = (vb && vb.width) || svg.clientWidth || 1;
        const screenCx = svgRect.left + cxSvg * svgRect.width / vbw;
        const wrapCx = screenCx - wrapRect.left;
        const panelW = panel.offsetWidth || 200;
        const gap = 16;
        const pad = 12;
        // Prefer the right side of the rule; flip when the panel
        // would clip the chart's right edge.
        let left = wrapCx + gap;
        if (left + panelW > wrapRect.width - pad) {
          left = wrapCx - gap - panelW;
        }
        // Last-resort clamp — never run off the left edge either.
        if (left < pad) left = pad;
        panel.style.left = left + "px";
        panel.style.right = "auto";
      }
      function moveRule(cx, box) {
        rule.setAttribute("x1", cx);
        rule.setAttribute("x2", cx);
        rule.setAttribute("y1", box.top);
        rule.setAttribute("y2", box.bottom);
        rule.style.opacity = "1";
      }
      function onMove(e) {
        if (pinnedIso !== null) return;
        const rect = svg.getBoundingClientRect();
        const vb = svg.viewBox.baseVal;
        const vbw = (vb && vb.width) || svg.clientWidth;
        const vbh = (vb && vb.height) || svg.clientHeight;
        const svgX = (e.clientX - rect.left) * vbw / rect.width;
        const svgY = (e.clientY - rect.top) * vbh / rect.height;
        const box = plotBox();
        if (!box) return;
        if (svgX < box.left || svgX > box.right ||
            svgY < box.top || svgY > box.bottom) {
          rule.style.opacity = "0";
          return;
        }
        const nd = nearestDay(svgX, box);
        if (!nd) return;
        rule.setAttribute("stroke-dasharray", "3 3");
        moveRule(nd.cx, box);
        placePanel(nd.cx);
        renderPanel(nd.iso, false);
      }
      function onClick(e) {
        const rect = svg.getBoundingClientRect();
        const vb = svg.viewBox.baseVal;
        const vbw = (vb && vb.width) || svg.clientWidth;
        const svgX = (e.clientX - rect.left) * vbw / rect.width;
        const box = plotBox();
        if (!box) return;
        if (svgX < box.left || svgX > box.right) return;
        const nd = nearestDay(svgX, box);
        if (!nd) return;
        if (pinnedIso === nd.iso) {
          // Click the pinned day → release.
          pinnedIso = null;
          rule.setAttribute("stroke-dasharray", "3 3");
          moveRule(nd.cx, box);
          placePanel(nd.cx);
          renderPanel(nd.iso, false);
        } else {
          pinnedIso = nd.iso;
          rule.setAttribute("stroke-dasharray", "");
          moveRule(nd.cx, box);
          placePanel(nd.cx);
          renderPanel(nd.iso, true);
        }
      }
      // Default the panel to the most recent day so it's never an
      // empty block; restore that when the cursor leaves and nothing
      // is pinned.
      const dates = Object.keys(metrics);
      const defaultIso = dates.length ? dates[dates.length - 1] : null;
      function snapDefault() {
        if (!defaultIso) return;
        const xs = view.scale("x");
        const box = plotBox();
        if (!xs || !box) { renderPanel(defaultIso, false); return; }
        const bw = xs.bandwidth ? xs.bandwidth() / 2 : 0;
        const cx = box.left + xs(defaultIso) + bw;
        placePanel(cx);
        renderPanel(defaultIso, false);
      }
      // Two animation frames to let CSS layout settle before we
      // measure widths and place the panel.
      requestAnimationFrame(function () {
        requestAnimationFrame(snapDefault);
      });
      svg.addEventListener("mousemove", onMove);
      svg.addEventListener("mouseleave", function () {
        if (pinnedIso !== null) return;
        rule.style.opacity = "0";
        snapDefault();
      });
      svg.addEventListener("click", onClick);
      window.addEventListener("resize", function () {
        // Keep a pinned panel anchored to its rule across resizes.
        if (pinnedIso === null) { snapDefault(); return; }
        const xs = view.scale("x");
        const box = plotBox();
        if (!xs || !box) return;
        const bw = xs.bandwidth ? xs.bandwidth() / 2 : 0;
        const cx = box.left + xs(pinnedIso) + bw;
        moveRule(cx, box);
        placePanel(cx);
      });
    }
  })();
</script>
{% endif %}
