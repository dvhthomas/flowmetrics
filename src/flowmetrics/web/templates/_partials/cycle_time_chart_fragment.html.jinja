{# Chart-only fragment: the chart container div + its Vega-Lite
   embed script. Used both inside the tile partial AND returned
   from `/api/internal/cycle-time` as the HTMX swap payload.

   Required context:
     data           — CycleTimeModel (rendered to a spec via the
                      `vega_spec` Jinja global)
     chart_height   — int pixels (default ~320 for tile, ~480 for detail)
#}
{%- set chart_container_id = "cycle-time-chart" -%}
{%- set _h = chart_height|default(320) -%}

<div id="{{ chart_container_id }}" class="metric-chart"
     data-chart-height="{{ _h }}"
     {# Re-fetch on Percentile Filter slider change. The slider's
        work-items request returns with HX-Trigger: ptile-changed;
        the chart reads the current bounds out of #work-items-state
        and swaps its own outerHTML with the filtered fragment. #}
     hx-get="/api/internal/cycle-time?workflow={{ contract.name }}"
     hx-trigger="flowmetrics:ptile-changed from:body"
     hx-swap="outerHTML"
     hx-vals='js:{ptile_min: document.getElementById("work-items-state")?.dataset.ptileMin || "0", ptile_max: document.getElementById("work-items-state")?.dataset.ptileMax || "100"}'>
  {% if data.item_count == 0 %}
    <p class="aging-empty">
      <strong class="aging-empty-headline">No completed items in this window.</strong>
      <span class="aging-empty-sub">
        Try widening the view (or reference period) using the
        controls above — defaults are the most-recent 30 days
        of view and 14 days of reference.
      </span>
    </p>
  {% endif %}
</div>
{% if data.item_count > 0 %}
<script>
  (function () {
    // Finalize the previous View at this container to free its
    // signal listeners + data references before re-embedding.
    // Mirrors the pattern in throughput_chart_fragment.
    if (window.__flowmetricsCycleTimeView) {
      try { window.__flowmetricsCycleTimeView.finalize(); }
      catch (e) { /* finalize is best-effort */ }
      window.__flowmetricsCycleTimeView = null;
    }

    const spec = {{ vega_spec(data) | safe }};
    spec.height = {{ _h }};
    vegaEmbed("#{{ chart_container_id }}", window.applyTheme(spec), {
      actions: false,
      renderer: "svg"
    }).then(function (res) {
      window.__flowmetricsCycleTimeView = res.view;
      // Lift the Vega bindings (Max-cycle-time-shown slider) into
      // the tile header beside Reset.
      if (window.relocateBindings) {
        window.relocateBindings(
          document.getElementById("{{ chart_container_id }}")
        );
      }
      // Click a dot → navigate to that item's lifecycle page.
      // Hover keeps showing the tooltip (Vega-Lite default
      // behaviour for the `tooltip` encoding); click is the
      // explicit drill-down gesture. Same pattern on the aging
      // chart.
      res.view.addEventListener("click", function (_event, item) {
        if (!item || !item.datum || !item.datum.item_id) return;
        const cleanId = String(item.datum.item_id).replace(/^#/, "");
        // Carry the current view/reference window into the
        // item page so the filter persists across navigation.
        window.location.href =
          "/workflows/{{ contract.name }}/items/" +
          encodeURIComponent(cleanId) + window.location.search;
      });
    }).catch(function (err) {
      const el = document.getElementById("{{ chart_container_id }}");
      el.innerText = "Chart render failed: " + err;
    });
  })();
</script>
{% endif %}
