{# Aging chart tile.

   mode='tile'   → dashboard cell with "Details →" link
   mode='detail' → standalone page (no Details link)
#}
{%- set chart_container_id = "aging-chart" -%}
{%- set chart_height = 480 if mode == 'detail' else 320 -%}
{%- set _aging_reset = '/api/internal/aging?workflow=' ~ contract.name -%}
{%- if data.asof_iso %}{% set _aging_reset = _aging_reset ~ '&asof=' ~ data.asof_iso %}{% endif -%}

<section id="aging-tile" class="metric">
  <header class="metric-header">
    <div class="metric-header-controls">
      <button class="reset-btn"
              type="button"
              hx-get="{{ _aging_reset | keep_filters }}"
              hx-target="#{{ chart_container_id }}"
              hx-swap="outerHTML"
              title="Re-load this chart">↻ Reset</button>
      {% if mode == 'tile' %}
        <a class="details-link"
           href="{{ ("/workflows/" ~ contract.name ~ "/metrics/aging") | keep_filters }}">Details →</a>
      {% endif %}
    </div>
  </header>

  {% include "_partials/aging_chart_fragment.html.jinja" %}
</section>
