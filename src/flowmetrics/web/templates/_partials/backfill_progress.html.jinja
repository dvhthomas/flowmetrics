{# Backfill progress fragment.

   Rendered into #backfill-progress by the POST, embedded on the
   Data Source page on load, and — while a backfill runs — polls
   itself via /api/internal/backfill-status every 2s.

   Context: backfill (dict | None), workflow (str). #}
{%- if backfill -%}
{%- set st = backfill.status -%}
<div id="backfill-progress-row"
     class="backfill-progress backfill-progress--{{ st }}"
     {% if st == "running" -%}
     hx-get="/api/internal/backfill-status?workflow={{ workflow }}"
     hx-trigger="every 2s"
     hx-swap="outerHTML"
     {%- endif %}>
  {% if st == "running" %}
    <span class="backfill-spinner" aria-hidden="true"></span>
    <span>Backfilling{% if backfill.since and backfill.until %}
      {{ backfill.since }} → {{ backfill.until }}{% endif %} —
      this can take a minute. You can leave this page.</span>
  {% elif st == "done" %}
    <span>&check; Backfill complete.{% if backfill.message %}
      {{ backfill.message }}{% endif %}</span>
    <button type="button" class="backfill-dismiss"
            aria-label="Dismiss"
            data-dismiss-key="{{ workflow }}:{{ backfill.started_at }}"
            >&times;</button>
    {%- if poll %}
    {# Delivered by the 2s poll — the backfill just finished.
       Refresh the whole page so the coverage chart and the
       headline pick up the new data. The page-load render omits
       `poll`, so a page that opens on an already-done status
       never triggers this — no reload loop. #}
    <span class="backfill-spinner" aria-hidden="true"></span>
    <span>Refreshing the page&hellip;</span>
    <script>
      setTimeout(function () { window.location.reload(); }, 1500);
    </script>
    {%- endif %}
    <script>
      // Flash banner: per-run dismissal lives in localStorage so
      // a "done" notice the user already X'd never shows again,
      // even across reloads. Key is `workflow:started_at` so a
      // NEW backfill (new started_at) starts a fresh notice.
      (function () {
        var row = document.getElementById('backfill-progress-row');
        if (!row) return;
        var btn = row.querySelector('.backfill-dismiss');
        if (!btn) return;
        var key = (
          'flowmetricsBackfillDismissed:' + btn.dataset.dismissKey
        );
        if (localStorage.getItem(key) === '1') {
          row.remove();
          return;
        }
        btn.addEventListener('click', function () {
          localStorage.setItem(key, '1');
          row.remove();
        });
      })();
    </script>
  {% else %}
    <span>&cross; Backfill failed.{% if backfill.message %}
      {{ backfill.message }}{% endif %}</span>
  {% endif %}
</div>
{%- else -%}
<div id="backfill-progress-row"></div>
{%- endif -%}
