{# Page-level Percentile Filter — single-select chip bar.

   One click filters BOTH the chart's scatter AND the work-items
   table to items inside the chosen percentile bucket. `All` is
   the default and lifts the filter.

   Each chip carries `data-ptile-min` / `data-ptile-max` and
   posts to the work-items endpoint via HTMX on click. The
   response carries `HX-Trigger-After-Settle:
   flowmetrics:ptile-changed` so the chart fragment above
   refetches itself with the same bounds.

   Required context:
     data           — WorkItemsTableData (carries ptile_min /
                      ptile_max / ptile_values / ptile_unit).
     contract.name  — for the HTMX URL.
#}
{%- set unit = data.ptile_unit -%}
{%- set values = data.ptile_values -%}
{# Bucket label helper — renders e.g. "P50–P85" or with the
   actual metric value alongside when available. #}
{%- macro chip(label, lo, hi, current_lo, current_hi) -%}
  {%- set is_active = (lo == current_lo and hi == current_hi) -%}
  <button type="button"
          class="ptile-chip{% if is_active %} ptile-chip--active{% endif %}"
          data-ptile-min="{{ lo }}"
          data-ptile-max="{{ hi }}"
          hx-get="/api/internal/work-items?workflow={{ contract.name }}&from=slider&ptile_min={{ lo }}&ptile_max={{ hi }}"
          hx-target="#work-items-body"
          hx-swap="innerHTML"
          hx-vals='js:{sort: document.getElementById("work-items-state")?.dataset.sort || "", direction: document.getElementById("work-items-state")?.dataset.direction || ""}'
          hx-include="#work-items-search, #work-items-completed-on, #work-items-in-flight-at">
    {{ label }}
  </button>
{%- endmacro -%}
<div class="ptile-toolbar">
  <span class="ptile-toolbar-label">Percentile</span>
  <div class="ptile-chips" role="group" aria-label="Percentile filter">
    {{ chip("All", 0, 100, data.ptile_min, data.ptile_max) }}
    {{ chip("≤ P50", 0, 50, data.ptile_min, data.ptile_max) }}
    {{ chip("P50–P85", 50, 85, data.ptile_min, data.ptile_max) }}
    {{ chip("P85–P95", 85, 95, data.ptile_min, data.ptile_max) }}
    {{ chip("> P95", 95, 100, data.ptile_min, data.ptile_max) }}
  </div>
  <span class="ptile-toolbar-bounds">
    {%- set p50 = values.get(50) -%}
    {%- set p85 = values.get(85) -%}
    {%- set p95 = values.get(95) -%}
    {%- if p50 is not none -%}
      P50 {{ p50 | round(1) }}{{ unit }}
      · P85 {{ p85 | round(1) }}{{ unit }}
      · P95 {{ p95 | round(1) }}{{ unit }}
    {%- endif -%}
  </span>
</div>
