{# Page-level Percentile Filter slider.

   Two-handle range that narrows BOTH the chart's scatter AND the
   work-items table to items inside [ptile_min, ptile_max]. Lives
   above the chart so the reader sees it as a top-level page
   control, not a table-only filter.

   Handles snap to {0} ∪ {50, 55, 60, …, 100}. The script clamps
   min ≤ max, snaps off-ladder values, and writes a live
   "P50 (4d) – P85 (12d)" readout from `data.ptile_values`.

   On `change` the slider posts to the work-items endpoint with
   `from=slider` so the server fires `HX-Trigger-After-Settle:
   flowmetrics:ptile-changed`. The chart fragment listens for
   that event and re-fetches itself with the same bounds out of
   #work-items-state. Sort + direction come from that meta too,
   so the table's current ordering survives a slider move.

   Required context:
     data           — WorkItemsTableData (carries ptile_min /
                      ptile_max / ptile_values / ptile_unit).
     contract.name  — for the HTMX URL.
#}
<div class="ptile-toolbar">
  <div class="ptile-slider">
    <div class="ptile-slider-label">
      <span>Percentile Filter</span>
      <strong id="ptile-display">
        P<span id="ptile-min-disp">{{ data.ptile_min }}</span>
        (<span id="ptile-min-val">—</span>)
        – P<span id="ptile-max-disp">{{ data.ptile_max }}</span>
        (<span id="ptile-max-val">—</span>)
      </strong>
    </div>
    <script type="application/json" id="ptile-values">
      {"unit": {{ data.ptile_unit | tojson }},
       "values": {{ data.ptile_values | tojson }}}
    </script>
    <div class="ptile-slider-handles">
      <input type="range" min="0" max="100" step="5"
             id="ptile-min" name="ptile_min"
             value="{{ data.ptile_min }}"
             hx-get="/api/internal/work-items?workflow={{ contract.name }}&from=slider"
             hx-target="#work-items-body"
             hx-swap="innerHTML"
             hx-trigger="change"
             hx-vals='js:{sort: document.getElementById("work-items-state")?.dataset.sort || "", direction: document.getElementById("work-items-state")?.dataset.direction || ""}'
             hx-include="#ptile-max, #work-items-search, #work-items-completed-on, #work-items-in-flight-at">
      <input type="range" min="0" max="100" step="5"
             id="ptile-max" name="ptile_max"
             value="{{ data.ptile_max }}"
             hx-get="/api/internal/work-items?workflow={{ contract.name }}&from=slider"
             hx-target="#work-items-body"
             hx-swap="innerHTML"
             hx-trigger="change"
             hx-vals='js:{sort: document.getElementById("work-items-state")?.dataset.sort || "", direction: document.getElementById("work-items-state")?.dataset.direction || ""}'
             hx-include="#ptile-min, #work-items-search, #work-items-completed-on, #work-items-in-flight-at">
      <div class="ptile-slider-ticks" aria-hidden="true">
        <span style="left: 0%">P0</span>
        <span style="left: 50%">P50</span>
        <span style="left: 85%">P85</span>
        <span style="left: 95%">P95</span>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const pmin = document.getElementById('ptile-min');
    const pmax = document.getElementById('ptile-max');
    const minDisp = document.getElementById('ptile-min-disp');
    const maxDisp = document.getElementById('ptile-max-disp');
    const minVal = document.getElementById('ptile-min-val');
    const maxVal = document.getElementById('ptile-max-val');
    const ptileMeta = JSON.parse(
      document.getElementById('ptile-values').textContent
    );
    const unit = ptileMeta.unit || '';
    const values = ptileMeta.values || {};
    function snap(v) {
      v = parseInt(v, 10);
      if (v <= 25) return 0;
      if (v < 50) return 50;
      return Math.round(v / 5) * 5;
    }
    function fmtValue(p) {
      const v = values[String(p)];
      if (v === undefined || v === null) return '—';
      const rounded = v >= 10 ? Math.round(v) : Math.round(v * 10) / 10;
      return rounded + unit;
    }
    function clampAndShow() {
      let lo = snap(pmin.value);
      let hi = snap(pmax.value);
      if (lo > hi) {
        if (document.activeElement === pmin) hi = lo;
        else lo = hi;
      }
      pmin.value = lo;
      pmax.value = hi;
      minDisp.textContent = lo;
      maxDisp.textContent = hi;
      minVal.textContent = fmtValue(lo);
      maxVal.textContent = fmtValue(hi);
    }
    pmin.addEventListener('input', clampAndShow);
    pmax.addEventListener('input', clampAndShow);
    clampAndShow();
  })();
</script>
