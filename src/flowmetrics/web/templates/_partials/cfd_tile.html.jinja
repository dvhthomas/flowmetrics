{# CFD chart tile.

   mode='tile'   → dashboard cell with "Details →" link
   mode='detail' → standalone page (no Details link)
#}
{%- set chart_container_id = "cfd-chart" -%}
{%- set chart_height = 440 if mode == 'detail' else 320 -%}

<section id="cfd-tile" class="metric">
  <header class="metric-header">
    <div class="metric-header-controls">
      <button class="reset-btn"
              type="button"
              hx-get="{{ ('/api/internal/cfd?workflow=' ~ contract.name) | keep_filters }}"
              hx-target="#{{ chart_container_id }}"
              hx-swap="outerHTML"
              title="Re-load this chart">↻ Reset</button>
      {% if mode == 'tile' %}
        <a class="details-link"
           href="{{ ("/workflows/" ~ contract.name ~ "/metrics/cfd") | keep_filters }}">Details →</a>
      {% endif %}
    </div>
  </header>

  {% include "_partials/cfd_chart_fragment.html.jinja" %}
</section>
